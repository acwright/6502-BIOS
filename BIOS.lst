001327r 2  A5 0B          lda BAS_ACC + 1
001329r 2  9D 01 04       sta BAS_VARS + 1,x
00132Cr 2               
00132Cr 2                 ; Expect TO
00132Cr 2  20 rr rr       jsr BasSkipSpaces
00132Fr 2  20 rr rr       jsr BasGetTokChar
001332r 2  C9 89          cmp #TOK_TO
001334r 2  D0 6B          bne @ForErr
001336r 2  20 rr rr       jsr BasAdvTxtPtr
001339r 2               
001339r 2                 ; Evaluate limit — store temporarily in SCRATCH
001339r 2  20 rr rr       jsr BasExpr
00133Cr 2  A5 0A          lda BAS_ACC
00133Er 2  85 1C          sta BAS_SCRATCH
001340r 2  A5 0B          lda BAS_ACC + 1
001342r 2  85 1D          sta BAS_SCRATCH + 1
001344r 2               
001344r 2                 ; Check room on FOR stack
001344r 2  A6 1B          ldx BAS_FORSP
001346r 2  8A             txa
001347r 2  18             clc
001348r 2  69 10          adc #BAS_FOR_ENTRY
00134Ar 2  C9 81          cmp #BAS_FORSTK_SIZE + 1
00134Cr 2  B0 4E          bcs @ForStackFull
00134Er 2               
00134Er 2                 ; Build FOR stack entry (16 bytes per entry):
00134Er 2                 ;  +0: var_offset (1)
00134Er 2                 ;  +1: limit_lo (1)
00134Er 2                 ;  +2: limit_hi (1)
00134Er 2                 ;  +3: step_lo (1)
00134Er 2                 ;  +4: step_hi (1)
00134Er 2                 ;  +5: body_start_lo (1) — first line of loop body (next line after FOR)
00134Er 2                 ;  +6: body_start_hi (1)
00134Er 2                 ; +7..+15: unused padding
00134Er 2               
00134Er 2                 ; Save var offset and limit to stack entry NOW, before evaluating STEP,
00134Er 2                 ; because BasExpr clobbers BAS_SCRATCH during number parsing.
00134Er 2  A5 21          lda BAS_TEMP
001350r 2  9D 80 05       sta BAS_FORSTK,x               ; +0: var offset
001353r 2  A5 1C          lda BAS_SCRATCH
001355r 2  9D 81 05       sta BAS_FORSTK + 1,x           ; +1: limit lo
001358r 2  A5 1D          lda BAS_SCRATCH + 1
00135Ar 2  9D 82 05       sta BAS_FORSTK + 2,x           ; +2: limit hi
00135Dr 2               
00135Dr 2                 ; Check for optional STEP — default is 1
00135Dr 2  A9 01          lda #$01
00135Fr 2  9D 83 05       sta BAS_FORSTK + 3,x           ; +3: step lo (default 1)
001362r 2  9E 84 05       stz BAS_FORSTK + 4,x           ; +4: step hi (default 0)
001365r 2               
001365r 2  20 rr rr       jsr BasSkipSpaces
001368r 2  20 rr rr       jsr BasGetTokChar
00136Br 2  C9 8A          cmp #TOK_STEP
00136Dr 2  D0 12          bne @ForNoStep
00136Fr 2  20 rr rr       jsr BasAdvTxtPtr
001372r 2  DA             phx                            ; Preserve FOR stack index
001373r 2  20 rr rr       jsr BasExpr
001376r 2  FA             plx                            ; Restore FOR stack index
001377r 2  A5 0A          lda BAS_ACC
001379r 2  9D 83 05       sta BAS_FORSTK + 3,x           ; +3: step lo
00137Cr 2  A5 0B          lda BAS_ACC + 1
00137Er 2  9D 84 05       sta BAS_FORSTK + 4,x           ; +4: step hi
001381r 2               @ForNoStep:
001381r 2                 ; Save loop body start: current line and TXTPTR
001381r 2                 ; (TXTPTR points right after the FOR statement — at ':' or end of line)
001381r 2  A5 06          lda BAS_CURLINE
001383r 2  9D 85 05       sta BAS_FORSTK + 5,x           ; +5: body_line lo
001386r 2  A5 07          lda BAS_CURLINE + 1
001388r 2  9D 86 05       sta BAS_FORSTK + 6,x           ; +6: body_line hi
00138Br 2  A5 04          lda BAS_TXTPTR
00138Dr 2  9D 87 05       sta BAS_FORSTK + 7,x           ; +7: body_txtptr lo
001390r 2  A5 05          lda BAS_TXTPTR + 1
001392r 2  9D 88 05       sta BAS_FORSTK + 8,x           ; +8: body_txtptr hi
001395r 2               
001395r 2  8A             txa
001396r 2  18             clc
001397r 2  69 10          adc #BAS_FOR_ENTRY
001399r 2  85 1B          sta BAS_FORSP
00139Br 2  60             rts
00139Cr 2               
00139Cr 2               @ForStackFull:
00139Cr 2  A9 03          lda #ERR_OUT_OF_MEM
00139Er 2  4C rr rr       jmp BasError
0013A1r 2               
0013A1r 2               @ForErr:
0013A1r 2  A9 00          lda #ERR_SYNTAX
0013A3r 2  4C rr rr       jmp BasError
0013A6r 2               
0013A6r 2               ; --- NEXT ---
0013A6r 2               BasCmdNext:
0013A6r 2  20 rr rr       jsr BasSkipSpaces
0013A9r 2  20 rr rr       jsr BasGetTokChar
0013ACr 2               
0013ACr 2                 ; Must be a variable
0013ACr 2  C9 41          cmp #'A'
0013AEr 2  B0 03          bcs @NextVarOk1
0013B0r 2  4C rr rr       jmp @NextErr
0013B3r 2               @NextVarOk1:
0013B3r 2  C9 5B          cmp #'Z' + 1
0013B5r 2  90 03          bcc @NextVarOk2
0013B7r 2  4C rr rr       jmp @NextErr
0013BAr 2               @NextVarOk2:
0013BAr 2               
0013BAr 2  38             sec
0013BBr 2  E9 41          sbc #'A'
0013BDr 2  0A             asl
0013BEr 2  85 21          sta BAS_TEMP                   ; Variable offset
0013C0r 2  20 rr rr       jsr BasAdvTxtPtr
0013C3r 2               
0013C3r 2                 ; Search FOR stack from top for matching variable
0013C3r 2  A6 1B          ldx BAS_FORSP
0013C5r 2  D0 03          bne :+
0013C7r 2  4C rr rr       jmp @NextNoFor
0013CAr 2               :
0013CAr 2               
0013CAr 2               @NextSearch:
0013CAr 2  CA             dex                            ; Back up past padding and entries
0013CBr 2  8A             txa
0013CCr 2  38             sec
0013CDr 2  E9 0F          sbc #BAS_FOR_ENTRY - 1         ; Point to start of this entry
0013CFr 2  AA             tax
0013D0r 2  30 78          bmi @NextNoFor
0013D2r 2  BD 80 05       lda BAS_FORSTK,x               ; var_offset
0013D5r 2  C5 21          cmp BAS_TEMP
0013D7r 2  F0 02          beq @NextFound
0013D9r 2                 ; Not this entry — keep searching
0013D9r 2  80 EF          bra @NextSearch
0013DBr 2               
0013DBr 2               @NextFound:
0013DBr 2                 ; Add step to variable
0013DBr 2  BD 83 05       lda BAS_FORSTK + 3,x           ; step lo
0013DEr 2  85 0C          sta BAS_AUX
0013E0r 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
0013E3r 2  85 0D          sta BAS_AUX + 1
0013E5r 2               
0013E5r 2  A4 21          ldy BAS_TEMP                   ; var offset
0013E7r 2  18             clc
0013E8r 2  B9 00 04       lda BAS_VARS,y
0013EBr 2  65 0C          adc BAS_AUX
0013EDr 2  99 00 04       sta BAS_VARS,y
0013F0r 2  85 0A          sta BAS_ACC
0013F2r 2  B9 01 04       lda BAS_VARS + 1,y
0013F5r 2  65 0D          adc BAS_AUX + 1
0013F7r 2  99 01 04       sta BAS_VARS + 1,y
0013FAr 2  85 0B          sta BAS_ACC + 1
0013FCr 2               
0013FCr 2                 ; Load limit into AUX for comparison
0013FCr 2  BD 81 05       lda BAS_FORSTK + 1,x           ; limit lo
0013FFr 2  85 0C          sta BAS_AUX
001401r 2  BD 82 05       lda BAS_FORSTK + 2,x           ; limit hi
001404r 2  85 0D          sta BAS_AUX + 1
001406r 2               
001406r 2                 ; Check if loop is done:
001406r 2                 ; If step > 0: done when var > limit (AUX)
001406r 2                 ; If step < 0: done when var < limit (AUX)
001406r 2  BD 84 05       lda BAS_FORSTK + 4,x           ; step hi
001409r 2  30 07          bmi @NextStepNeg
00140Br 2               
00140Br 2                 ; Step positive: compare var (ACC) vs limit (AUX)
00140Br 2                 ; Done if ACC > AUX (i.e., AUX < ACC)
00140Br 2  20 rr rr       jsr BasCmpAuxAcc
00140Er 2  30 37          bmi @NextDone                  ; AUX < ACC means var > limit
001410r 2  80 07          bra @NextLoop                  ; Continue loop
001412r 2               
001412r 2               @NextStepNeg:
001412r 2                 ; Step negative: done if var < limit
001412r 2                 ; Done if ACC < AUX (i.e., AUX > ACC)
001412r 2  20 rr rr       jsr BasCmpAuxAcc
001415r 2  F0 02          beq @NextLoop
001417r 2  10 2E          bpl @NextDone                  ; AUX > ACC means var < limit
001419r 2               
001419r 2               @NextLoop:
001419r 2                 ; Continue loop — restore to saved body start
001419r 2                 ; Keep the FOR entry on the stack (FORSP stays where it is)
001419r 2  BD 85 05       lda BAS_FORSTK + 5,x           ; body_line lo
00141Cr 2  85 06          sta BAS_CURLINE
00141Er 2  BD 86 05       lda BAS_FORSTK + 6,x           ; body_line hi
001421r 2  85 07          sta BAS_CURLINE + 1
001423r 2  BD 87 05       lda BAS_FORSTK + 7,x           ; body_txtptr lo
001426r 2  85 04          sta BAS_TXTPTR
001428r 2  BD 88 05       lda BAS_FORSTK + 8,x           ; body_txtptr hi
00142Br 2  85 05          sta BAS_TXTPTR + 1
00142Dr 2                 ; Skip past ':' separator if present
00142Dr 2  20 rr rr       jsr BasSkipSpaces
001430r 2  20 rr rr       jsr BasGetTokChar
001433r 2  C9 3A          cmp #CH_COLON
001435r 2  D0 03          bne :+
001437r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ':'
00143Ar 2               : ; Set flag so run loop preserves TXTPTR
00143Ar 2  A5 17          lda BAS_FLAGS
00143Cr 2  09 04          ora #BAS_FLAG_TXTSET
00143Er 2  85 17          sta BAS_FLAGS
001440r 2                 ; Invalidate saved CURLINE so run loop always detects the change
001440r 2  A9 FF          lda #$FF
001442r 2  85 14          sta BAS_VARPTR
001444r 2  85 15          sta BAS_VARPTR + 1
001446r 2  60             rts
001447r 2               
001447r 2               @NextDone:
001447r 2                 ; Loop complete — remove this FOR entry from stack
001447r 2  86 1B          stx BAS_FORSP                  ; Pop down to this entry (removes it)
001449r 2  60             rts
00144Ar 2               
00144Ar 2               @NextNoFor:
00144Ar 2               @NextErr:
00144Ar 2  A9 05          lda #ERR_NEXT_NO_FOR
00144Cr 2  4C rr rr       jmp BasError
00144Fr 2               
00144Fr 2               ; --- END ---
00144Fr 2               BasCmdEnd:
00144Fr 2  64 17          stz BAS_FLAGS                  ; Clear run flag
001451r 2  60             rts                            ; Returns to BasRunLoop which checks flags
001452r 2               
001452r 2               ; --- SYS ---
001452r 2               ; SYS <address> — Call machine code at 16-bit address, RTS returns to BASIC
001452r 2               BasCmdSys:
001452r 2  20 rr rr       jsr BasExpr                    ; Evaluate address expression → BAS_ACC
001455r 2                 ; Use BAS_TMP2 as the indirect jump target
001455r 2  A5 0A          lda BAS_ACC
001457r 2  85 10          sta BAS_TMP2
001459r 2  A5 0B          lda BAS_ACC + 1
00145Br 2  85 11          sta BAS_TMP2 + 1
00145Dr 2  6C 10 00       jmp (BAS_TMP2)                 ; JSR-like: callee RTSes back to caller
001460r 2               
001460r 2               ; --- LOAD ---
001460r 2               ; LOAD "filename" — Load from CF filesystem
001460r 2               ; LOAD (no arg)   — Load via serial ASCII transfer
001460r 2               BasCmdLoad:
001460r 2  20 rr rr       jsr BasSkipSpaces
001463r 2  20 rr rr       jsr BasGetTokChar
001466r 2  C9 22          cmp #CH_QUOTE
001468r 2  F0 5B          beq @LoadCF
00146Ar 2               
00146Ar 2                 ; No filename — serial XModem load
00146Ar 2  AD 0D 03       lda HW_PRESENT
00146Dr 2  29 10          and #HW_SC
00146Fr 2  F0 51          beq @LoadNoDev
001471r 2                 ; Set destination to PROGRAM_START
001471r 2  A9 00          lda #<PROGRAM_START
001473r 2  85 2A          sta XFER_PTR
001475r 2  A9 08          lda #>PROGRAM_START
001477r 2  85 2B          sta XFER_PTR + 1
001479r 2  20 rr rr       jsr XModemLoad
00147Cr 2  90 03          bcc :+
00147Er 2  4C rr rr       jmp @LoadErr
001481r 2               :
001481r 2                 ; Walk next-line pointer chain to find true BAS_PRGEND
001481r 2  A9 00          lda #<BAS_PRG_START
001483r 2  85 0E          sta BAS_TMP1
001485r 2  A9 08          lda #>BAS_PRG_START
001487r 2  85 0F          sta BAS_TMP1 + 1
001489r 2               @LoadSerWalk:
001489r 2  A0 00          ldy #LINE_NEXT
00148Br 2  B1 0E          lda (BAS_TMP1),y
00148Dr 2  85 10          sta BAS_TMP2
00148Fr 2  C8             iny
001490r 2  B1 0E          lda (BAS_TMP1),y
001492r 2  85 11          sta BAS_TMP2 + 1
001494r 2  05 10          ora BAS_TMP2
001496r 2  F0 0A          beq @LoadSerEnd
001498r 2  A5 10          lda BAS_TMP2
00149Ar 2  85 0E          sta BAS_TMP1
00149Cr 2  A5 11          lda BAS_TMP2 + 1
00149Er 2  85 0F          sta BAS_TMP1 + 1
0014A0r 2  80 E7          bra @LoadSerWalk
0014A2r 2               @LoadSerEnd:
0014A2r 2                 ; BAS_TMP1 points to the last line (next=$0000).
0014A2r 2                 ; Scan past its payload to find the true program end.
0014A2r 2  A0 04          ldy #LINE_PAYLOAD
0014A4r 2               @LoadSerScan:
0014A4r 2  B1 0E          lda (BAS_TMP1),y
0014A6r 2  F0 03          beq @LoadSerGotEnd
0014A8r 2  C8             iny
0014A9r 2  80 F9          bra @LoadSerScan
0014ABr 2               @LoadSerGotEnd:
0014ABr 2  C8             iny                            ; Past null terminator
0014ACr 2  98             tya
0014ADr 2  18             clc
0014AEr 2  65 0E          adc BAS_TMP1
0014B0r 2  85 12          sta BAS_PRGEND
0014B2r 2  A5 0F          lda BAS_TMP1 + 1
0014B4r 2  69 00          adc #$00
0014B6r 2  85 13          sta BAS_PRGEND + 1
0014B8r 2                 ; Write end sentinel at BAS_PRGEND
0014B8r 2  A0 00          ldy #$00
0014BAr 2  A9 00          lda #$00
0014BCr 2  91 12          sta (BAS_PRGEND),y
0014BEr 2  C8             iny
0014BFr 2  91 12          sta (BAS_PRGEND),y
0014C1r 2  60             rts
0014C2r 2               
0014C2r 2               @LoadNoDev:
0014C2r 2  4C rr rr       jmp BasPrintNoDevice
0014C5r 2               
0014C5r 2               @LoadCF:
0014C5r 2  AD 0D 03       lda HW_PRESENT
0014C8r 2  29 08          and #HW_CF
0014CAr 2  F0 F6          beq @LoadNoDev
0014CCr 2                 ; Parse quoted filename into STR_PTR for FsLoadFile
0014CCr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
0014CFr 2                 ; Point STR_PTR at current position in tokenized text
0014CFr 2  A5 04          lda BAS_TXTPTR
0014D1r 2  85 02          sta STR_PTR
0014D3r 2  A5 05          lda BAS_TXTPTR + 1
0014D5r 2  85 03          sta STR_PTR + 1
0014D7r 2                 ; Advance TXTPTR past the filename to closing quote
0014D7r 2               @LoadScanName:
0014D7r 2  20 rr rr       jsr BasGetTokChar
0014DAr 2  F0 12          beq @LoadNameDone              ; End of line (unterminated — use what we have)
0014DCr 2  C9 22          cmp #CH_QUOTE
0014DEr 2  F0 05          beq @LoadNameEnd
0014E0r 2  20 rr rr       jsr BasAdvTxtPtr
0014E3r 2  80 F2          bra @LoadScanName
0014E5r 2               @LoadNameEnd:
0014E5r 2                 ; Null-terminate the filename in the token buffer (overwrite closing quote)
0014E5r 2  A0 00          ldy #$00
0014E7r 2  A9 00          lda #$00
0014E9r 2  91 04          sta (BAS_TXTPTR),y
0014EBr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
0014EEr 2               @LoadNameDone:
0014EEr 2                 ; Call filesystem load
0014EEr 2  20 rr rr       jsr FsLoadFile
0014F1r 2  B0 41          bcs @LoadErr
0014F3r 2                 ; Walk next-line pointer chain to find true BAS_PRGEND
0014F3r 2                 ; (file may contain machine code after the BASIC program end sentinel)
0014F3r 2  A9 00          lda #<BAS_PRG_START
0014F5r 2  85 0E          sta BAS_TMP1
0014F7r 2  A9 08          lda #>BAS_PRG_START
0014F9r 2  85 0F          sta BAS_TMP1 + 1
0014FBr 2               @LoadWalkChain:
0014FBr 2  A0 00          ldy #LINE_NEXT
0014FDr 2  B1 0E          lda (BAS_TMP1),y               ; lo byte of next-line pointer
0014FFr 2  85 10          sta BAS_TMP2
001501r 2  C8             iny
001502r 2  B1 0E          lda (BAS_TMP1),y               ; hi byte of next-line pointer
001504r 2  85 11          sta BAS_TMP2 + 1
001506r 2  05 10          ora BAS_TMP2                   ; lo | hi — zero means end sentinel
001508r 2  F0 0A          beq @LoadChainEnd
00150Ar 2                 ; Advance to next line
00150Ar 2  A5 10          lda BAS_TMP2
00150Cr 2  85 0E          sta BAS_TMP1
00150Er 2  A5 11          lda BAS_TMP2 + 1
001510r 2  85 0F          sta BAS_TMP1 + 1
001512r 2  80 E7          bra @LoadWalkChain
001514r 2               @LoadChainEnd:
001514r 2                 ; BAS_TMP1 points to the last line (next=$0000).
001514r 2                 ; Scan past its payload to find the true program end.
001514r 2  A0 04          ldy #LINE_PAYLOAD
001516r 2               @LoadCFScan:
001516r 2  B1 0E          lda (BAS_TMP1),y
