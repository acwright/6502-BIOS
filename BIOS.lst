00151Er 2  98             tya
00151Fr 2  18             clc
001520r 2  65 0E          adc BAS_TMP1
001522r 2  85 12          sta BAS_PRGEND
001524r 2  A5 0F          lda BAS_TMP1 + 1
001526r 2  69 00          adc #$00
001528r 2  85 13          sta BAS_PRGEND + 1
00152Ar 2                 ; Write end sentinel at BAS_PRGEND
00152Ar 2  A0 00          ldy #$00
00152Cr 2  A9 00          lda #$00
00152Er 2  91 12          sta (BAS_PRGEND),y
001530r 2  C8             iny
001531r 2  91 12          sta (BAS_PRGEND),y
001533r 2  60             rts
001534r 2               
001534r 2               @LoadErr:
