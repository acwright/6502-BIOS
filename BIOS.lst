001536r 2  85 0E          sta BAS_TMP1
001538r 2  A9 rr          lda #>BasStrLoadErr
00153Ar 2  85 0F          sta BAS_TMP1 + 1
00153Cr 2  20 rr rr       jsr BasPrintStr
00153Fr 2  60             rts
001540r 2               
001540r 2               ; --- SAVE ---
001540r 2               ; SAVE "filename" — Save to CF filesystem
001540r 2               ; SAVE (no arg)   — Save via serial XModem transfer
001540r 2               BasCmdSave:
001540r 2  20 rr rr       jsr BasSkipSpaces
001543r 2  20 rr rr       jsr BasGetTokChar
001546r 2  C9 22          cmp #CH_QUOTE
001548r 2  F0 25          beq @SaveCF
00154Ar 2               
00154Ar 2                 ; No filename — serial XModem save
00154Ar 2  AD 0D 03       lda HW_PRESENT
00154Dr 2  29 10          and #HW_SC
00154Fr 2  F0 1B          beq @SaveNoDev
001551r 2                 ; Set source to PROGRAM_START
001551r 2  A9 00          lda #<PROGRAM_START
001553r 2  85 2A          sta XFER_PTR
001555r 2  A9 08          lda #>PROGRAM_START
001557r 2  85 2B          sta XFER_PTR + 1
001559r 2                 ; Calculate byte count = BAS_PRGEND - PROGRAM_START
001559r 2  A5 12          lda BAS_PRGEND
00155Br 2  38             sec
00155Cr 2  E9 00          sbc #<PROGRAM_START
00155Er 2  8D 17 03       sta XFER_REMAIN
001561r 2  A5 13          lda BAS_PRGEND + 1
001563r 2  E9 08          sbc #>PROGRAM_START
001565r 2  8D 18 03       sta XFER_REMAIN + 1
001568r 2  20 rr rr       jsr XModemSave
00156Br 2  60             rts
00156Cr 2               
00156Cr 2               @SaveNoDev:
00156Cr 2  4C rr rr       jmp BasPrintNoDevice
00156Fr 2               
00156Fr 2               @SaveCF:
00156Fr 2  AD 0D 03       lda HW_PRESENT
001572r 2  29 08          and #HW_CF
001574r 2  F0 F6          beq @SaveNoDev
001576r 2                 ; Parse quoted filename into STR_PTR for FsSaveFile
001576r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip opening quote
001579r 2  A5 04          lda BAS_TXTPTR
00157Br 2  85 02          sta STR_PTR
00157Dr 2  A5 05          lda BAS_TXTPTR + 1
00157Fr 2  85 03          sta STR_PTR + 1
001581r 2                 ; Advance TXTPTR past the filename to closing quote
001581r 2               @SaveScanName:
001581r 2  20 rr rr       jsr BasGetTokChar
001584r 2  F0 12          beq @SaveNameDone
001586r 2  C9 22          cmp #CH_QUOTE
001588r 2  F0 05          beq @SaveNameEnd
00158Ar 2  20 rr rr       jsr BasAdvTxtPtr
00158Dr 2  80 F2          bra @SaveScanName
00158Fr 2               @SaveNameEnd:
00158Fr 2  A0 00          ldy #$00
001591r 2  A9 00          lda #$00
001593r 2  91 04          sta (BAS_TXTPTR),y
001595r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip past the closing quote
001598r 2               @SaveNameDone:
001598r 2                 ; Calculate file size = BAS_PRGEND - PROGRAM_START
001598r 2  A5 12          lda BAS_PRGEND
00159Ar 2  38             sec
00159Br 2  E9 00          sbc #<PROGRAM_START
00159Dr 2  8D 4A 03       sta FS_FILE_SIZE
