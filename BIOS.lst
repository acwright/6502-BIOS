0015C0r 2  4C rr rr       jmp BasPrintNoDevice
0015C3r 2               @DirHasCF:
0015C3r 2  20 rr rr       jsr FsDirectory
0015C6r 2  60             rts
0015C7r 2               
0015C7r 2               ; --- DEL ---
0015C7r 2               ; DEL "filename" — Delete a file from CF
0015C7r 2               BasCmdDel:
0015C7r 2  AD 0D 03       lda HW_PRESENT
0015CAr 2  29 08          and #HW_CF
0015CCr 2  D0 03          bne @DelHasCF
0015CEr 2  4C rr rr       jmp BasPrintNoDevice
0015D1r 2               @DelHasCF:
0015D1r 2  20 rr rr       jsr BasSkipSpaces
0015D4r 2  20 rr rr       jsr BasGetTokChar
