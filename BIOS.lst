000BCCr 2  20 rr rr       jsr BasExpectChar
000BCFr 2  4C rr rr       jmp BasFuncSqr
000BD2r 2               @NotSqr:
000BD2r 2               
000BD2r 2                 ; MIN(a,b) — Return smaller of two values
000BD2r 2  C9 B7          cmp #TOK_MIN
000BD4r 2  D0 33          bne @NotMin
000BD6r 2  20 rr rr       jsr BasAdvTxtPtr
000BD9r 2  A9 28          lda #CH_LPAREN
000BDBr 2  20 rr rr       jsr BasExpectChar
000BDEr 2  20 rr rr       jsr BasExpr                    ; a -> BAS_ACC
000BE1r 2  A5 0A          lda BAS_ACC
000BE3r 2  48             pha
000BE4r 2  A5 0B          lda BAS_ACC + 1
000BE6r 2  48             pha
000BE7r 2  A9 2C          lda #CH_COMMA
000BE9r 2  20 rr rr       jsr BasExpectChar
000BECr 2  20 rr rr       jsr BasExpr                    ; b -> BAS_ACC
000BEFr 2  A9 29          lda #CH_RPAREN
000BF1r 2  20 rr rr       jsr BasExpectChar
000BF4r 2                 ; Pop a into AUX
000BF4r 2  68             pla
000BF5r 2  85 0D          sta BAS_AUX + 1
000BF7r 2  68             pla
000BF8r 2  85 0C          sta BAS_AUX
000BFAr 2  20 rr rr       jsr BasCmpAuxAcc               ; compare AUX(a) vs ACC(b)
000BFDr 2  30 01          bmi @MinDone                   ; AUX < ACC, use AUX
000BFFr 2  60             rts                            ; ACC is smaller or equal
000C00r 2               @MinDone:
000C00r 2  A5 0C          lda BAS_AUX
000C02r 2  85 0A          sta BAS_ACC
000C04r 2  A5 0D          lda BAS_AUX + 1
000C06r 2  85 0B          sta BAS_ACC + 1
000C08r 2  60             rts
000C09r 2               @NotMin:
000C09r 2               
000C09r 2                 ; MAX(a,b) — Return larger of two values
000C09r 2  C9 B8          cmp #TOK_MAX
000C0Br 2  D0 35          bne @NotMax
000C0Dr 2  20 rr rr       jsr BasAdvTxtPtr
000C10r 2  A9 28          lda #CH_LPAREN
000C12r 2  20 rr rr       jsr BasExpectChar
000C15r 2  20 rr rr       jsr BasExpr                    ; a -> BAS_ACC
000C18r 2  A5 0A          lda BAS_ACC
000C1Ar 2  48             pha
000C1Br 2  A5 0B          lda BAS_ACC + 1
000C1Dr 2  48             pha
000C1Er 2  A9 2C          lda #CH_COMMA
000C20r 2  20 rr rr       jsr BasExpectChar
000C23r 2  20 rr rr       jsr BasExpr                    ; b -> BAS_ACC
000C26r 2  A9 29          lda #CH_RPAREN
000C28r 2  20 rr rr       jsr BasExpectChar
000C2Br 2                 ; Pop a into AUX
000C2Br 2  68             pla
000C2Cr 2  85 0D          sta BAS_AUX + 1
000C2Er 2  68             pla
000C2Fr 2  85 0C          sta BAS_AUX
000C31r 2  20 rr rr       jsr BasCmpAuxAcc               ; compare AUX(a) vs ACC(b)
000C34r 2  F0 02          beq @MaxKeepAcc                ; equal, either is fine
000C36r 2  10 01          bpl @MaxUseAux                 ; AUX > ACC, use AUX
000C38r 2               @MaxKeepAcc:
000C38r 2  60             rts                            ; ACC is larger or equal
000C39r 2               @MaxUseAux:
000C39r 2  A5 0C          lda BAS_AUX
000C3Br 2  85 0A          sta BAS_ACC
000C3Dr 2  A5 0D          lda BAS_AUX + 1
000C3Fr 2  85 0B          sta BAS_ACC + 1
000C41r 2  60             rts
000C42r 2               @NotMax:
000C42r 2               
000C42r 2                 ; POW(b,e) — Integer exponentiation
000C42r 2  C9 B9          cmp #TOK_POW
000C44r 2  D0 2F          bne @NotPow
000C46r 2  20 rr rr       jsr BasAdvTxtPtr
000C49r 2  A9 28          lda #CH_LPAREN
000C4Br 2  20 rr rr       jsr BasExpectChar
000C4Er 2  20 rr rr       jsr BasExpr                    ; base -> BAS_ACC
000C51r 2  A5 0A          lda BAS_ACC
000C53r 2  48             pha
000C54r 2  A5 0B          lda BAS_ACC + 1
000C56r 2  48             pha
000C57r 2  A9 2C          lda #CH_COMMA
000C59r 2  20 rr rr       jsr BasExpectChar
000C5Cr 2  20 rr rr       jsr BasExpr                    ; exponent -> BAS_ACC
000C5Fr 2  A9 29          lda #CH_RPAREN
000C61r 2  20 rr rr       jsr BasExpectChar
000C64r 2                 ; ACC = exponent, stack has base
000C64r 2                 ; Move exponent to AUX, pop base to ACC
000C64r 2  A5 0A          lda BAS_ACC
000C66r 2  85 0C          sta BAS_AUX
000C68r 2  A5 0B          lda BAS_ACC + 1
000C6Ar 2  85 0D          sta BAS_AUX + 1
000C6Cr 2  68             pla
000C6Dr 2  85 0B          sta BAS_ACC + 1
000C6Fr 2  68             pla
000C70r 2  85 0A          sta BAS_ACC
000C72r 2  4C rr rr       jmp BasFuncPow                 ; ACC=base, AUX=exponent
000C75r 2               @NotPow:
000C75r 2               
000C75r 2                 ; INKEY — non-blocking keyboard read (no parentheses)
000C75r 2  C9 BA          cmp #TOK_INKEY
000C77r 2  D0 22          bne @NotInkey
000C79r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip INKEY token
000C7Cr 2                 ; Check pending key buffer (saved by BasCheckBreak)
000C7Cr 2  AD 0E 03       lda BAS_PENDKEY
000C7Fr 2  F0 08          beq @InkeyChrin                ; No pending key — try Chrin
000C81r 2  9C 0E 03       stz BAS_PENDKEY               ; Consume pending key
000C84r 2  85 0A          sta BAS_ACC
000C86r 2  64 0B          stz BAS_ACC + 1
000C88r 2  60             rts
000C89r 2               @InkeyChrin:
000C89r 2  20 rr rr       jsr BufferSize                 ; Non-echoing buffer check
000C8Cr 2  F0 08          beq @InkeyNone                 ; No char available
000C8Er 2  20 rr rr       jsr ReadBuffer                 ; Read without echo
000C91r 2  85 0A          sta BAS_ACC
000C93r 2  64 0B          stz BAS_ACC + 1
000C95r 2  60             rts
000C96r 2               @InkeyNone:
000C96r 2  64 0A          stz BAS_ACC
000C98r 2  64 0B          stz BAS_ACC + 1
000C9Ar 2  60             rts
000C9Br 2               @NotInkey:
000C9Br 2               
000C9Br 2                 ; ASC(n) — identity function (returns value unchanged)
000C9Br 2  C9 BD          cmp #TOK_ASC
000C9Dr 2  D0 11          bne @NotAsc
000C9Fr 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_ASC
000CA2r 2  A9 28          lda #CH_LPAREN
000CA4r 2  20 rr rr       jsr BasExpectChar
000CA7r 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
000CAAr 2  A9 29          lda #CH_RPAREN
000CACr 2  20 rr rr       jsr BasExpectChar
000CAFr 2  60             rts                            ; BAS_ACC already holds n
000CB0r 2               @NotAsc:
000CB0r 2               
000CB0r 2                 ; FREE — returns free bytes (no parentheses, like INKEY)
000CB0r 2  C9 BE          cmp #TOK_FREE
000CB2r 2  D0 20          bne @NotFree
000CB4r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_FREE
000CB7r 2  38             sec
000CB8r 2  AD 8F 03       lda BAS_ARYTOP
000CBBr 2  E9 01          sbc #$01
000CBDr 2  85 0A          sta BAS_ACC
000CBFr 2  AD 90 03       lda BAS_ARYTOP + 1
000CC2r 2  E9 00          sbc #$00
000CC4r 2  85 0B          sta BAS_ACC + 1
000CC6r 2  38             sec
000CC7r 2  A5 0A          lda BAS_ACC
000CC9r 2  E5 12          sbc BAS_PRGEND
000CCBr 2  85 0A          sta BAS_ACC
000CCDr 2  A5 0B          lda BAS_ACC + 1
000CCFr 2  E5 13          sbc BAS_PRGEND + 1
000CD1r 2  85 0B          sta BAS_ACC + 1
000CD3r 2  60             rts
000CD4r 2               @NotFree:
000CD4r 2               
000CD4r 2                 ; NVRAM(addr) — read byte from RTC NVRAM
000CD4r 2  C9 C1          cmp #TOK_NVRAM
000CD6r 2  D0 26          bne @NotNvramFunc
000CD8r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip TOK_NVRAM
000CDBr 2  A9 28          lda #CH_LPAREN
000CDDr 2  20 rr rr       jsr BasExpectChar
000CE0r 2  20 rr rr       jsr BasExpr                    ; addr -> BAS_ACC
000CE3r 2  A9 29          lda #CH_RPAREN
000CE5r 2  20 rr rr       jsr BasExpectChar
000CE8r 2  AD 0D 03       lda HW_PRESENT
000CEBr 2  29 04          and #HW_RTC
000CEDr 2  F0 0A          beq @NvramFuncNoDev
000CEFr 2  A6 0A          ldx BAS_ACC                   ; X = NVRAM address
