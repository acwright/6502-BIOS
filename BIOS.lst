0018BDr 2  A5 0B          lda BAS_ACC + 1
0018BFr 2  D0 27          bne @OnFallthrough             ; Index > 255 — out of range
0018C1r 2  A6 0A          ldx BAS_ACC
0018C3r 2  F0 23          beq @OnFallthrough             ; Index = 0 — out of range
0018C5r 2               
0018C5r 2                 ; X = 1-based index; skip (index-1) comma-separated line numbers
0018C5r 2  CA             dex                            ; X = items to skip
0018C6r 2  F0 15          beq @OnFound
0018C8r 2               
0018C8r 2               @OnSkip:
0018C8r 2  DA             phx
0018C9r 2  20 rr rr       jsr BasExpr                    ; Parse and discard line number
0018CCr 2  20 rr rr       jsr BasSkipSpaces
0018CFr 2  20 rr rr       jsr BasGetTokChar
0018D2r 2  FA             plx
0018D3r 2  C9 2C          cmp #CH_COMMA
0018D5r 2  D0 11          bne @OnFallthrough             ; Not enough items — fall through
0018D7r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip comma
0018DAr 2  CA             dex
0018DBr 2  D0 EB          bne @OnSkip
0018DDr 2               
0018DDr 2               @OnFound:
0018DDr 2  68             pla                            ; Restore keyword token
0018DEr 2  C9 84          cmp #TOK_GOSUB
0018E0r 2  F0 03          beq @OnDoGosub
0018E2r 2  4C rr rr       jmp BasCmdGoto                 ; Evaluate target line and GOTO
0018E5r 2               
0018E5r 2               @OnDoGosub:
0018E5r 2  4C rr rr       jmp BasCmdGosub                ; Evaluate target line and GOSUB
0018E8r 2               
0018E8r 2               @OnFallthrough:
0018E8r 2                 ; Index out of range — clean stack and silently continue
0018E8r 2  68             pla
0018E9r 2  60             rts
0018EAr 2               
0018EAr 2               ; ============================================================================
0018EAr 2               ; READ var[,var,...] — Read values from DATA statements
0018EAr 2               ; ============================================================================
0018EAr 2               
0018EAr 2               BasCmdRead:
0018EAr 2               @ReadLoop:
0018EAr 2                 ; Ensure DATA pointer is initialized
0018EAr 2  AD 1A 03       lda BAS_DATAPTR
0018EDr 2  0D 1B 03       ora BAS_DATAPTR + 1
0018F0r 2  D0 05          bne @ReadHaveData
0018F2r 2  20 rr rr       jsr BasDataFindFirst           ; Find first DATA line (errors if none)
0018F5r 2  80 0C          bra @ReadDataOk
0018F7r 2               
0018F7r 2               @ReadHaveData:
0018F7r 2                 ; Check for exhausted DATA sentinel ($FFFF)
0018F7r 2  AD 1B 03       lda BAS_DATAPTR + 1
0018FAr 2  C9 FF          cmp #$FF
0018FCr 2  D0 05          bne @ReadDataOk
0018FEr 2  A9 0A          lda #ERR_OUT_OF_DATA
001900r 2  4C rr rr       jmp BasError
001903r 2               
001903r 2               @ReadDataOk:
001903r 2                 ; Parse variable name (A-Z)
001903r 2  20 rr rr       jsr BasSkipSpaces
001906r 2  20 rr rr       jsr BasGetTokChar
001909r 2  C9 41          cmp #'A'
00190Br 2  90 6A          bcc @ReadSyntax
00190Dr 2  C9 5B          cmp #'Z' + 1
00190Fr 2  B0 66          bcs @ReadSyntax
001911r 2               
001911r 2                 ; Compute variable offset and advance past variable letter
001911r 2  38             sec
001912r 2  E9 41          sbc #'A'
001914r 2  0A             asl                            ; ×2 for 16-bit vars
001915r 2  48             pha                            ; Save var offset on stack
001916r 2  20 rr rr       jsr BasAdvTxtPtr
001919r 2               
001919r 2                 ; Save current TXTPTR on stack
001919r 2  A5 05          lda BAS_TXTPTR + 1
00191Br 2  48             pha
00191Cr 2  A5 04          lda BAS_TXTPTR
00191Er 2  48             pha
00191Fr 2               
00191Fr 2                 ; Switch TXTPTR to DATA read position
00191Fr 2  AD 1A 03       lda BAS_DATAPTR
001922r 2  85 04          sta BAS_TXTPTR
001924r 2  AD 1B 03       lda BAS_DATAPTR + 1
001927r 2  85 05          sta BAS_TXTPTR + 1
001929r 2               
001929r 2                 ; Parse the next data value
001929r 2  20 rr rr       jsr BasSkipSpaces
00192Cr 2  20 rr rr       jsr BasExpr                    ; → BAS_ACC
00192Fr 2               
00192Fr 2                 ; Check what follows: comma (more data), null/colon (end of DATA)
00192Fr 2  20 rr rr       jsr BasSkipSpaces
001932r 2  20 rr rr       jsr BasGetTokChar
001935r 2  C9 2C          cmp #CH_COMMA
001937r 2  D0 0F          bne @ReadEndOfData
001939r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip comma — DATA pointer past it
00193Cr 2               
00193Cr 2               @ReadSavePtr:
00193Cr 2                 ; Update DATA pointer to current TXTPTR position
00193Cr 2  A5 04          lda BAS_TXTPTR
00193Er 2  8D 1A 03       sta BAS_DATAPTR
001941r 2  A5 05          lda BAS_TXTPTR + 1
001943r 2  8D 1B 03       sta BAS_DATAPTR + 1
001946r 2  80 0D          bra @ReadRestore
001948r 2               
001948r 2               @ReadEndOfData:
001948r 2                 ; At end of this DATA line — find next DATA for future READs
001948r 2  20 rr rr       jsr BasDataFindNext            ; Updates BAS_DATAPTR (or carry set)
00194Br 2  90 08          bcc @ReadRestore               ; Found next DATA line — continue
00194Dr 2                 ; No more DATA lines — set exhausted sentinel ($FFFF)
00194Dr 2  A9 FF          lda #$FF
00194Fr 2  8D 1A 03       sta BAS_DATAPTR
001952r 2  8D 1B 03       sta BAS_DATAPTR + 1
001955r 2               
001955r 2               @ReadRestore:
001955r 2                 ; Restore original TXTPTR
001955r 2  68             pla
001956r 2  85 04          sta BAS_TXTPTR
001958r 2  68             pla
001959r 2  85 05          sta BAS_TXTPTR + 1
00195Br 2               
00195Br 2                 ; Store value into variable
00195Br 2  FA             plx                            ; Variable offset
00195Cr 2  A5 0A          lda BAS_ACC
00195Er 2  9D 00 04       sta BAS_VARS,x
001961r 2  A5 0B          lda BAS_ACC + 1
001963r 2  9D 01 04       sta BAS_VARS + 1,x
001966r 2               
001966r 2                 ; Check for comma → READ A,B,C support
001966r 2  20 rr rr       jsr BasSkipSpaces
001969r 2  20 rr rr       jsr BasGetTokChar
00196Cr 2  C9 2C          cmp #CH_COMMA
00196Er 2  D0 06          bne @ReadDone
001970r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip comma
001973r 2  4C rr rr       jmp @ReadLoop
001976r 2               
001976r 2               @ReadDone:
001976r 2  60             rts
001977r 2               
001977r 2               @ReadSyntax:
001977r 2  A9 00          lda #ERR_SYNTAX
001979r 2  4C rr rr       jmp BasError
00197Cr 2               
00197Cr 2               ; ============================================================================
00197Cr 2               ; RESTORE — Reset DATA read pointer to beginning
00197Cr 2               ; ============================================================================
00197Cr 2               
00197Cr 2               BasCmdRestore:
00197Cr 2  9C 1A 03       stz BAS_DATAPTR
00197Fr 2  9C 1B 03       stz BAS_DATAPTR + 1
001982r 2  60             rts
001983r 2               
001983r 2               ; ============================================================================
001983r 2               ; DATA Scanning Helpers
001983r 2               ; ============================================================================
001983r 2               
001983r 2               ; BasDataFindFirst — Find first DATA line from program start
001983r 2               ; Sets BAS_DATAPTR to first value in the first DATA statement
001983r 2               ; Errors ERR_OUT_OF_DATA if no DATA found.
001983r 2               
001983r 2               BasDataFindFirst:
001983r 2  A9 00          lda #<BAS_PRG_START
001985r 2  85 0E          sta BAS_TMP1
001987r 2  A9 08          lda #>BAS_PRG_START
001989r 2  85 0F          sta BAS_TMP1 + 1
00198Br 2  20 rr rr       jsr BasDataScan
00198Er 2  90 05          bcc @FindFirstOk
001990r 2  A9 0A          lda #ERR_OUT_OF_DATA
001992r 2  4C rr rr       jmp BasError
001995r 2               @FindFirstOk:
001995r 2  60             rts
001996r 2               
001996r 2               ; BasDataFindNext — Find next DATA line after current position
001996r 2               ; BAS_DATAPTR points into current DATA line; scans forward to null,
001996r 2               ; then searches subsequent lines for TOK_DATA.
001996r 2               ; Sets BAS_DATAPTR to first value in the next DATA statement.
001996r 2               ; Errors ERR_OUT_OF_DATA if no more DATA found.
001996r 2               
001996r 2               BasDataFindNext:
001996r 2  AD 1A 03       lda BAS_DATAPTR
001999r 2  85 0E          sta BAS_TMP1
00199Br 2  AD 1B 03       lda BAS_DATAPTR + 1
00199Er 2  85 0F          sta BAS_TMP1 + 1
0019A0r 2                 ; Scan to end of current line (null terminator)
0019A0r 2  A0 00          ldy #$00
0019A2r 2               @ScanToNull:
0019A2r 2  B1 0E          lda (BAS_TMP1),y
0019A4r 2  F0 07          beq @GotNull
0019A6r 2  C8             iny
0019A7r 2  D0 F9          bne @ScanToNull
0019A9r 2  E6 0F          inc BAS_TMP1 + 1
0019ABr 2  80 F5          bra @ScanToNull
0019ADr 2               @GotNull:
0019ADr 2                 ; Advance past null to start of next line
0019ADr 2  C8             iny
0019AEr 2  98             tya
0019AFr 2  18             clc
0019B0r 2  65 0E          adc BAS_TMP1
0019B2r 2  85 0E          sta BAS_TMP1
0019B4r 2  A9 00          lda #$00
0019B6r 2  65 0F          adc BAS_TMP1 + 1
0019B8r 2  85 0F          sta BAS_TMP1 + 1
0019BAr 2                 ; Fall through to scan
0019BAr 2               
0019BAr 2               ; BasDataScan — Scan program lines starting at BAS_TMP1 for TOK_DATA
0019BAr 2               ; Sets BAS_DATAPTR to point past the DATA token (first value byte)
0019BAr 2               ; Errors ERR_OUT_OF_DATA if no DATA found before end of program.
0019BAr 2               
0019BAr 2               BasDataScan:
0019BAr 2               @ScanLoop:
0019BAr 2                 ; At end of program?
0019BAr 2  A5 0E          lda BAS_TMP1
0019BCr 2  C5 12          cmp BAS_PRGEND
0019BEr 2  D0 06          bne @ScanNotEnd
0019C0r 2  A5 0F          lda BAS_TMP1 + 1
0019C2r 2  C5 13          cmp BAS_PRGEND + 1
0019C4r 2  F0 2E          beq @ScanNotFound
0019C6r 2               @ScanNotEnd:
0019C6r 2                 ; Check first token of this line
0019C6r 2  A0 04          ldy #LINE_PAYLOAD
0019C8r 2  B1 0E          lda (BAS_TMP1),y
0019CAr 2  C9 B3          cmp #TOK_DATA
0019CCr 2  F0 16          beq @ScanFound
0019CEr 2                 ; Skip to next line by scanning for null terminator
0019CEr 2               @ScanSkipLine:
0019CEr 2  B1 0E          lda (BAS_TMP1),y
0019D0r 2  F0 03          beq @ScanSkipDone
0019D2r 2  C8             iny
0019D3r 2  80 F9          bra @ScanSkipLine
0019D5r 2               @ScanSkipDone:
0019D5r 2  C8             iny                            ; Past null
0019D6r 2  98             tya
0019D7r 2  18             clc
0019D8r 2  65 0E          adc BAS_TMP1
0019DAr 2  85 0E          sta BAS_TMP1
0019DCr 2  A9 00          lda #$00
0019DEr 2  65 0F          adc BAS_TMP1 + 1
0019E0r 2  85 0F          sta BAS_TMP1 + 1
0019E2r 2  80 D6          bra @ScanLoop
0019E4r 2               
0019E4r 2               @ScanFound:
0019E4r 2                 ; Point DATAPTR past the DATA token
0019E4r 2  18             clc
0019E5r 2  A5 0E          lda BAS_TMP1
0019E7r 2  69 05          adc #(LINE_PAYLOAD + 1)
0019E9r 2  8D 1A 03       sta BAS_DATAPTR
0019ECr 2  A5 0F          lda BAS_TMP1 + 1
0019EEr 2  69 00          adc #$00
0019F0r 2  8D 1B 03       sta BAS_DATAPTR + 1
0019F3r 2  60             rts
0019F4r 2               
0019F4r 2               @ScanNotFound:
0019F4r 2  38             sec                            ; Carry set = not found
0019F5r 2  60             rts
0019F6r 2               
0019F6r 2               ; ============================================================================
0019F6r 2               ; SQR(n) — Integer square root (16-bit unsigned)
0019F6r 2               ; ============================================================================
0019F6r 2               ; Input: BAS_ACC = n (signed; negative → ILLEGAL QTY error)
0019F6r 2               ; Output: BAS_ACC = floor(sqrt(n))
0019F6r 2               ; Algorithm: Newton's method — guess = n/2, iterate guess = (guess + n/guess)/2
0019F6r 2               ; Uses BAS_AUX as "n" copy, BAS_NUMTMP to save current guess across division
0019F6r 2               
0019F6r 2               BasFuncSqr:
0019F6r 2                 ; Negative → error
0019F6r 2  A5 0B          lda BAS_ACC + 1
0019F8r 2  30 66          bmi @SqrErr
0019FAr 2                 ; n = 0 or 1 → result is n
0019FAr 2  A5 0B          lda BAS_ACC + 1
0019FCr 2  D0 06          bne @SqrBig
0019FEr 2  A5 0A          lda BAS_ACC
001A00r 2  C9 02          cmp #2
001A02r 2  90 59          bcc @SqrDone                   ; 0 or 1 → return as-is
001A04r 2               @SqrBig:
001A04r 2                 ; Copy n to AUX
001A04r 2  A5 0A          lda BAS_ACC
001A06r 2  85 0C          sta BAS_AUX
001A08r 2  A5 0B          lda BAS_ACC + 1
001A0Ar 2  85 0D          sta BAS_AUX + 1
001A0Cr 2                 ; Initial guess = n / 2 (unsigned shift right)
001A0Cr 2  46 0B          lsr BAS_ACC + 1
001A0Er 2  66 0A          ror BAS_ACC
001A10r 2                 ; If guess becomes 0 (n was 1, already handled), set to 1
001A10r 2  A5 0A          lda BAS_ACC
001A12r 2  05 0B          ora BAS_ACC + 1
001A14r 2  D0 04          bne @SqrLoop
001A16r 2  A9 01          lda #$01
001A18r 2  85 0A          sta BAS_ACC
001A1Ar 2               @SqrLoop:
001A1Ar 2                 ; Save current guess in NUMTMP (survives BasMathDiv)
001A1Ar 2  A5 0A          lda BAS_ACC
001A1Cr 2  85 22          sta BAS_NUMTMP
001A1Er 2  A5 0B          lda BAS_ACC + 1
001A20r 2  85 23          sta BAS_NUMTMP + 1
001A22r 2                 ; Compute n / guess: AUX / ACC → ACC
001A22r 2                 ; BasMathDiv clobbers AUX — save n on stack
001A22r 2  A5 0C          lda BAS_AUX
001A24r 2  48             pha
001A25r 2  A5 0D          lda BAS_AUX + 1
001A27r 2  48             pha
001A28r 2  20 rr rr       jsr BasMathDiv                 ; ACC = AUX / ACC
001A2Br 2                 ; new_guess = (guess + n/guess) / 2
001A2Br 2  18             clc
001A2Cr 2  A5 0A          lda BAS_ACC
001A2Er 2  65 22          adc BAS_NUMTMP
001A30r 2  85 0A          sta BAS_ACC
001A32r 2  A5 0B          lda BAS_ACC + 1
001A34r 2  65 23          adc BAS_NUMTMP + 1
001A36r 2  85 0B          sta BAS_ACC + 1
001A38r 2                 ; Unsigned divide by 2
001A38r 2  46 0B          lsr BAS_ACC + 1
001A3Ar 2  66 0A          ror BAS_ACC
001A3Cr 2                 ; Restore n to AUX
001A3Cr 2  68             pla
001A3Dr 2  85 0D          sta BAS_AUX + 1
001A3Fr 2  68             pla
001A40r 2  85 0C          sta BAS_AUX
001A42r 2                 ; Converged? Compare new_guess with old guess (NUMTMP)
001A42r 2  A5 0A          lda BAS_ACC
001A44r 2  C5 22          cmp BAS_NUMTMP
001A46r 2  D0 06          bne @SqrNotSame
001A48r 2  A5 0B          lda BAS_ACC + 1
001A4Ar 2  C5 23          cmp BAS_NUMTMP + 1
001A4Cr 2  F0 0F          beq @SqrDone                   ; Converged
001A4Er 2               @SqrNotSame:
001A4Er 2                 ; Check if new_guess = old_guess - 1 (oscillation)
001A4Er 2  38             sec
001A4Fr 2  A5 22          lda BAS_NUMTMP
001A51r 2  E5 0A          sbc BAS_ACC
001A53r 2  C9 01          cmp #$01
001A55r 2  D0 C3          bne @SqrLoop
001A57r 2  A5 23          lda BAS_NUMTMP + 1
001A59r 2  E5 0B          sbc BAS_ACC + 1
001A5Br 2  D0 BD          bne @SqrLoop
001A5Dr 2                 ; Oscillating between guess and guess-1; take the smaller (ACC)
001A5Dr 2               @SqrDone:
001A5Dr 2  64 0B          stz BAS_ACC + 1                ; Result fits in low byte for values ≤255
001A5Fr 2  60             rts                            ; For larger roots, high byte already correct from loop
001A60r 2               
001A60r 2               @SqrErr:
001A60r 2  A9 08          lda #ERR_ILLEGAL_QTY
001A62r 2  4C rr rr       jmp BasError
001A65r 2               
001A65r 2               ; ============================================================================
001A65r 2               ; POW(b,e) — Integer exponentiation
001A65r 2               ; ============================================================================
001A65r 2               ; Input: BAS_ACC = base, BAS_AUX = exponent
001A65r 2               ; Output: BAS_ACC = base^exponent
001A65r 2               ; Negative exponent → return 0 (integer truncation)
001A65r 2               ; Uses BAS_SCRATCH2 for base (safe across BasMathMul),
001A65r 2               ;      BAS_NUMTMP for exponent counter (safe across BasMathMul)
001A65r 2               
001A65r 2               BasFuncPow:
001A65r 2                 ; If exponent is negative → result is 0
001A65r 2  A5 0D          lda BAS_AUX + 1
001A67r 2  30 41          bmi @PowZero
001A69r 2                 ; If exponent = 0 → return 1
001A69r 2  A5 0C          lda BAS_AUX
001A6Br 2  05 0D          ora BAS_AUX + 1
001A6Dr 2  D0 07          bne @PowStart
001A6Fr 2  A9 01          lda #$01
001A71r 2  85 0A          sta BAS_ACC
001A73r 2  64 0B          stz BAS_ACC + 1
001A75r 2  60             rts
001A76r 2               @PowStart:
001A76r 2                 ; Save base in SCRATCH2 (survives BasMathMul which only uses SCRATCH)
001A76r 2  A5 0A          lda BAS_ACC
001A78r 2  85 1E          sta BAS_SCRATCH2
001A7Ar 2  A5 0B          lda BAS_ACC + 1
001A7Cr 2  85 1F          sta BAS_SCRATCH2 + 1
001A7Er 2                 ; Save exponent counter in NUMTMP (survives BasMathMul)
001A7Er 2  A5 0C          lda BAS_AUX
001A80r 2  85 22          sta BAS_NUMTMP
001A82r 2  A5 0D          lda BAS_AUX + 1
001A84r 2  85 23          sta BAS_NUMTMP + 1
001A86r 2                 ; Decrement counter: ACC already holds base^1
001A86r 2  A5 22          lda BAS_NUMTMP
001A88r 2  D0 02          bne :+
001A8Ar 2  C6 23          dec BAS_NUMTMP + 1
001A8Cr 2  C6 22        : dec BAS_NUMTMP
001A8Er 2               @PowMulLoop:
001A8Er 2                 ; Counter = 0? done
001A8Er 2  A5 22          lda BAS_NUMTMP
001A90r 2  05 23          ora BAS_NUMTMP + 1
001A92r 2  F0 15          beq @PowDone
001A94r 2                 ; Set AUX = base for multiplication
001A94r 2  A5 1E          lda BAS_SCRATCH2
001A96r 2  85 0C          sta BAS_AUX
001A98r 2  A5 1F          lda BAS_SCRATCH2 + 1
001A9Ar 2  85 0D          sta BAS_AUX + 1
001A9Cr 2  20 rr rr       jsr BasMathMul                 ; ACC = ACC * base
001A9Fr 2                 ; Decrement counter
001A9Fr 2  A5 22          lda BAS_NUMTMP
001AA1r 2  D0 02          bne :+
001AA3r 2  C6 23          dec BAS_NUMTMP + 1
001AA5r 2  C6 22        : dec BAS_NUMTMP
001AA7r 2  80 E5          bra @PowMulLoop
001AA9r 2               @PowDone:
001AA9r 2  60             rts
001AAAr 2               @PowZero:
001AAAr 2  64 0A          stz BAS_ACC
001AACr 2  64 0B          stz BAS_ACC + 1
001AAEr 2  60             rts
001AAFr 2               
001AAFr 2               ; ============================================================================
001AAFr 2               ; SETTIME hh, mm, ss — Set RTC time
001AAFr 2               ; ============================================================================
001AAFr 2               
001AAFr 2               BasCmdSettime:
001AAFr 2  AD 0D 03       lda HW_PRESENT
001AB2r 2  29 04          and #HW_RTC
001AB4r 2  D0 03          bne @SettimeStart
001AB6r 2  4C rr rr       jmp BasPrintNoDevice
001AB9r 2               @SettimeStart:
001AB9r 2  20 rr rr       jsr BasExpr                    ; hh -> BAS_ACC
001ABCr 2  A5 0A          lda BAS_ACC
001ABEr 2  48             pha                            ; save hours
001ABFr 2  20 rr rr       jsr BasSkipSpaces
001AC2r 2  A9 2C          lda #CH_COMMA
001AC4r 2  20 rr rr       jsr BasExpectChar
001AC7r 2  20 rr rr       jsr BasExpr                    ; mm -> BAS_ACC
001ACAr 2  A5 0A          lda BAS_ACC
001ACCr 2  48             pha                            ; save minutes
001ACDr 2  20 rr rr       jsr BasSkipSpaces
001AD0r 2  A9 2C          lda #CH_COMMA
001AD2r 2  20 rr rr       jsr BasExpectChar
001AD5r 2  20 rr rr       jsr BasExpr                    ; ss -> BAS_ACC
001AD8r 2                 ; Stack: top=minutes, bottom=hours. BAS_ACC has seconds.
001AD8r 2                 ; RtcWriteTime wants: A=hours, X=minutes, Y=seconds
001AD8r 2  A4 0A          ldy BAS_ACC                   ; Y = seconds
001ADAr 2  FA             plx                            ; X = minutes (was pushed last)
001ADBr 2  68             pla                            ; A = hours (was pushed first)
001ADCr 2  20 rr rr       jsr RtcWriteTime
001ADFr 2  60             rts
001AE0r 2               
001AE0r 2               ; ============================================================================
001AE0r 2               ; SETDATE cc, yy, mm, dd — Set RTC date
001AE0r 2               ; ============================================================================
001AE0r 2               
001AE0r 2               BasCmdSetdate:
001AE0r 2  AD 0D 03       lda HW_PRESENT
001AE3r 2  29 04          and #HW_RTC
001AE5r 2  D0 03          bne @SetdateStart
001AE7r 2  4C rr rr       jmp BasPrintNoDevice
001AEAr 2               @SetdateStart:
001AEAr 2  20 rr rr       jsr BasExpr                    ; cc -> BAS_ACC
001AEDr 2  A5 0A          lda BAS_ACC
001AEFr 2  8D 0B 03       sta RTC_BUF_CENT               ; Store century for RtcWriteDate
001AF2r 2  20 rr rr       jsr BasSkipSpaces
001AF5r 2  A9 2C          lda #CH_COMMA
001AF7r 2  20 rr rr       jsr BasExpectChar
001AFAr 2  20 rr rr       jsr BasExpr                    ; yy -> BAS_ACC
001AFDr 2  A5 0A          lda BAS_ACC
001AFFr 2  48             pha                            ; push year (1st on stack)
001B00r 2  20 rr rr       jsr BasSkipSpaces
001B03r 2  A9 2C          lda #CH_COMMA
001B05r 2  20 rr rr       jsr BasExpectChar
001B08r 2  20 rr rr       jsr BasExpr                    ; mm -> BAS_ACC
001B0Br 2  A5 0A          lda BAS_ACC
001B0Dr 2  48             pha                            ; push month (2nd on stack)
001B0Er 2  20 rr rr       jsr BasSkipSpaces
001B11r 2  A9 2C          lda #CH_COMMA
001B13r 2  20 rr rr       jsr BasExpectChar
001B16r 2  20 rr rr       jsr BasExpr                    ; dd -> BAS_ACC
001B19r 2                 ; Stack: top=month, bottom=year. BAS_ACC has day.
001B19r 2                 ; RtcWriteDate wants: A=day, X=month, Y=year
001B19r 2  A5 0A          lda BAS_ACC                   ; A = day
001B1Br 2  FA             plx                            ; X = month (was pushed last)
001B1Cr 2  7A             ply                            ; Y = year (was pushed first)
001B1Dr 2  20 rr rr       jsr RtcWriteDate
001B20r 2  60             rts
001B21r 2               
001B21r 2               ; ============================================================================
001B21r 2               ; NVRAM addr, value — Write byte to RTC NVRAM
001B21r 2               ; ============================================================================
001B21r 2               
001B21r 2               BasCmdNvramW:
001B21r 2  AD 0D 03       lda HW_PRESENT
001B24r 2  29 04          and #HW_RTC
001B26r 2  D0 03          bne @NvramWStart
001B28r 2  4C rr rr       jmp BasPrintNoDevice
001B2Br 2               @NvramWStart:
001B2Br 2  20 rr rr       jsr BasExpr                    ; addr -> BAS_ACC
001B2Er 2  A5 0A          lda BAS_ACC
001B30r 2  85 21          sta BAS_TEMP                   ; save address
001B32r 2  20 rr rr       jsr BasSkipSpaces
001B35r 2  A9 2C          lda #CH_COMMA
001B37r 2  20 rr rr       jsr BasExpectChar
001B3Ar 2  20 rr rr       jsr BasExpr                    ; value -> BAS_ACC
001B3Dr 2  A6 21          ldx BAS_TEMP                   ; X = address
001B3Fr 2  A5 0A          lda BAS_ACC                    ; A = value
001B41r 2  20 rr rr       jsr RtcWriteNVRAM
001B44r 2  60             rts
001B45r 2               
001B45r 2               ; ============================================================================
001B45r 2               ; MEM — Print system info
001B45r 2               ; ============================================================================
001B45r 2               
001B45r 2               BasCmdMem:
001B45r 2                 ; Print free bytes
001B45r 2  20 rr rr       jsr BasPrintFree
001B48r 2                 ; Print HW: $xx
001B48r 2  A9 rr          lda #<BasStrMemHW
001B4Ar 2  85 0E          sta BAS_TMP1
001B4Cr 2  A9 rr          lda #>BasStrMemHW
001B4Er 2  85 0F          sta BAS_TMP1 + 1
001B50r 2  20 rr rr       jsr BasPrintStr                ; CR+LF+"HW: $"
001B53r 2  AD 0D 03       lda HW_PRESENT
001B56r 2  20 rr rr       jsr BasMemHexByte
001B59r 2                 ; Print IO mode
001B59r 2  A9 rr          lda #<BasStrMemIO
001B5Br 2  85 0E          sta BAS_TMP1
001B5Dr 2  A9 rr          lda #>BasStrMemIO
001B5Fr 2  85 0F          sta BAS_TMP1 + 1
001B61r 2  20 rr rr       jsr BasPrintStr                ; CR+LF+"IO: "
001B64r 2  AD 06 03       lda IO_MODE
001B67r 2  29 01          and #$01
001B69r 2  D0 11          bne @MemSerial
001B6Br 2  A9 56          lda #'V'
001B6Dr 2  20 rr rr       jsr Chrout
001B70r 2  A9 49          lda #'I'
001B72r 2  20 rr rr       jsr Chrout
001B75r 2  A9 44          lda #'D'
001B77r 2  20 rr rr       jsr Chrout
001B7Ar 2  80 0F          bra @MemIODone
001B7Cr 2               @MemSerial:
001B7Cr 2  A9 53          lda #'S'
001B7Er 2  20 rr rr       jsr Chrout
001B81r 2  A9 45          lda #'E'
001B83r 2  20 rr rr       jsr Chrout
001B86r 2  A9 52          lda #'R'
001B88r 2  20 rr rr       jsr Chrout
