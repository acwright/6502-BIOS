000A48r 2  48             pha
000A49r 2  A5 0B          lda BAS_ACC + 1
000A4Br 2  48             pha
000A4Cr 2  20 rr rr       jsr BasExprUnary
000A4Fr 2  68             pla
000A50r 2  85 0D          sta BAS_AUX + 1
000A52r 2  68             pla
000A53r 2  85 0C          sta BAS_AUX
000A55r 2  20 rr rr       jsr BasMathDiv
000A58r 2                 ; MOD result is the remainder
000A58r 2  A5 1E          lda BAS_SCRATCH2
000A5Ar 2  85 0A          sta BAS_ACC
000A5Cr 2  A5 1F          lda BAS_SCRATCH2 + 1
000A5Er 2  85 0B          sta BAS_ACC + 1
000A60r 2  4C rr rr       jmp @MulLoop
000A63r 2               
000A63r 2               ; BasExprUnary — Handle unary minus
000A63r 2               BasExprUnary:
000A63r 2  20 rr rr       jsr BasSkipSpaces
000A66r 2  20 rr rr       jsr BasGetTokChar
000A69r 2  C9 2D          cmp #CH_MINUS
000A6Br 2  D0 09          bne @UnaryPos
000A6Dr 2  20 rr rr       jsr BasAdvTxtPtr
000A70r 2  20 rr rr       jsr BasExprPrimary
000A73r 2  4C rr rr       jmp BasMathNeg
000A76r 2               @UnaryPos:
000A76r 2  4C rr rr       jmp BasExprPrimary
000A79r 2               
000A79r 2               ; BasExprPrimary — Numbers, variables, parens, functions
000A79r 2               BasExprPrimary:
000A79r 2  20 rr rr       jsr BasSkipSpaces
000A7Cr 2  20 rr rr       jsr BasGetTokChar
000A7Fr 2               
000A7Fr 2                 ; Number literal?
000A7Fr 2  C9 30          cmp #'0'
000A81r 2  90 07          bcc @NotNum
000A83r 2  C9 3A          cmp #'9' + 1
000A85r 2  B0 03          bcs @NotNum
000A87r 2  4C rr rr       jmp @IsNum                     ; Digit found — parse number
000A8Ar 2               @NotNum:
000A8Ar 2               
000A8Ar 2                 ; Variable A-Z?
000A8Ar 2  C9 41          cmp #'A'
000A8Cr 2  90 21          bcc @NotVar
000A8Er 2  C9 5B          cmp #'Z' + 1
000A90r 2  B0 1D          bcs @NotVar
000A92r 2                 ; Variable — compute index: (ch - 'A') * 2
000A92r 2  38             sec
000A93r 2  E9 41          sbc #'A'
000A95r 2  0A             asl                            ; ×2 for 16-bit
000A96r 2  AA             tax
000A97r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
000A9Ar 2                 ; Check for '(' → array access
000A9Ar 2  20 rr rr       jsr BasGetTokChar
000A9Dr 2  C9 28          cmp #CH_LPAREN
000A9Fr 2  F0 0B          beq @AryRead
000AA1r 2                 ; Scalar variable read
000AA1r 2  BD 00 04       lda BAS_VARS,x
000AA4r 2  85 0A          sta BAS_ACC
000AA6r 2  BD 01 04       lda BAS_VARS + 1,x
000AA9r 2  85 0B          sta BAS_ACC + 1
000AABr 2  60             rts
000AACr 2               @AryRead:
000AACr 2  4C rr rr       jmp BasArrayRead               ; X = var_offset, will return with BAS_ACC set
000AAFr 2               @NotVar:
000AAFr 2               
000AAFr 2                 ; Parenthesized expression?
000AAFr 2  C9 28          cmp #CH_LPAREN
000AB1r 2  D0 0B          bne @NotParen
000AB3r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
000AB6r 2  20 rr rr       jsr BasExpr
000AB9r 2  A9 29          lda #CH_RPAREN
000ABBr 2  4C rr rr       jmp BasExpectChar              ; Expect and skip ')'
000ABEr 2               @NotParen:
000ABEr 2               
000ABEr 2                 ; PEEK(expr)?
000ABEr 2  C9 92          cmp #TOK_PEEK
000AC0r 2  D0 21          bne @NotPeek
000AC2r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip PEEK token
000AC5r 2  A9 28          lda #CH_LPAREN
000AC7r 2  20 rr rr       jsr BasExpectChar
000ACAr 2  20 rr rr       jsr BasExpr
000ACDr 2  A9 29          lda #CH_RPAREN
000ACFr 2  20 rr rr       jsr BasExpectChar
000AD2r 2                 ; Load byte from address in ACC
000AD2r 2  A5 0A          lda BAS_ACC
000AD4r 2  85 10          sta BAS_TMP2
000AD6r 2  A5 0B          lda BAS_ACC + 1
000AD8r 2  85 11          sta BAS_TMP2 + 1
000ADAr 2  A0 00          ldy #$00
000ADCr 2  B1 10          lda (BAS_TMP2),y
000ADEr 2  85 0A          sta BAS_ACC
000AE0r 2  64 0B          stz BAS_ACC + 1
000AE2r 2  60             rts
000AE3r 2               @NotPeek:
000AE3r 2               
000AE3r 2                 ; ABS(expr)?
000AE3r 2  C9 94          cmp #TOK_ABS
