000AFAr 2               
000AFAr 2                 ; RND(expr)?
000AFAr 2  C9 95          cmp #TOK_RND
000AFCr 2  D0 50          bne @NotRnd
000AFEr 2  20 rr rr       jsr BasAdvTxtPtr
000B01r 2  A9 28          lda #CH_LPAREN
000B03r 2  20 rr rr       jsr BasExpectChar
000B06r 2  20 rr rr       jsr BasExpr
000B09r 2  A9 29          lda #CH_RPAREN
000B0Br 2  20 rr rr       jsr BasExpectChar
000B0Er 2                 ; Save modulus (ACC) and generate random number
000B0Er 2  A5 0A          lda BAS_ACC
000B10r 2  48             pha
000B11r 2  A5 0B          lda BAS_ACC + 1
000B13r 2  48             pha
000B14r 2                 ; Galois LFSR step
000B14r 2  A5 18          lda BAS_RNDSEED
000B16r 2  0A             asl
000B17r 2  26 19          rol BAS_RNDSEED + 1
000B19r 2  90 02          bcc @RndNoTap
000B1Br 2  49 2D          eor #$2D                      ; Tap polynomial
000B1Dr 2               @RndNoTap:
000B1Dr 2  85 18          sta BAS_RNDSEED
000B1Fr 2                 ; Use seed as raw random value
000B1Fr 2  A5 18          lda BAS_RNDSEED
000B21r 2  85 0C          sta BAS_AUX
000B23r 2  A5 19          lda BAS_RNDSEED + 1
000B25r 2                 ; Make positive
000B25r 2  29 7F          and #$7F
000B27r 2  85 0D          sta BAS_AUX + 1
000B29r 2                 ; Restore modulus
000B29r 2  68             pla
000B2Ar 2  85 0B          sta BAS_ACC + 1
000B2Cr 2  68             pla
000B2Dr 2  85 0A          sta BAS_ACC
000B2Fr 2                 ; If modulus <= 0, just return raw number
000B2Fr 2  A5 0A          lda BAS_ACC
000B31r 2  05 0B          ora BAS_ACC + 1
000B33r 2  F0 10          beq @RndRaw
000B35r 2  A5 0B          lda BAS_ACC + 1
000B37r 2  30 0C          bmi @RndRaw
000B39r 2                 ; ACC = AUX MOD ACC
000B39r 2  20 rr rr       jsr BasMathDiv
000B3Cr 2  A5 1E          lda BAS_SCRATCH2
000B3Er 2  85 0A          sta BAS_ACC
000B40r 2  A5 1F          lda BAS_SCRATCH2 + 1
000B42r 2  85 0B          sta BAS_ACC + 1
000B44r 2  60             rts
000B45r 2               @RndRaw:
000B45r 2  A5 0C          lda BAS_AUX
000B47r 2  85 0A          sta BAS_ACC
000B49r 2  A5 0D          lda BAS_AUX + 1
000B4Br 2  85 0B          sta BAS_ACC + 1
000B4Dr 2  60             rts
000B4Er 2               @NotRnd:
000B4Er 2               
000B4Er 2                 ; JOY(n) — read joystick port
000B4Er 2  C9 A6          cmp #TOK_JOY
