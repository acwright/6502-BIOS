000B79r 2  20 rr rr       jsr BasAdvTxtPtr               ; skip TOK_SGN
000B7Cr 2  A9 28          lda #CH_LPAREN
000B7Er 2  20 rr rr       jsr BasExpectChar
000B81r 2  20 rr rr       jsr BasExpr                    ; x -> BAS_ACC
000B84r 2  A9 29          lda #CH_RPAREN
000B86r 2  20 rr rr       jsr BasExpectChar
000B89r 2  A5 0A          lda BAS_ACC
000B8Br 2  05 0B          ora BAS_ACC + 1
000B8Dr 2  F0 12          beq @SgnZero
000B8Fr 2  A5 0B          lda BAS_ACC + 1
000B91r 2  30 07          bmi @SgnNeg
000B93r 2  A9 01          lda #$01
000B95r 2  85 0A          sta BAS_ACC
000B97r 2  64 0B          stz BAS_ACC + 1
000B99r 2  60             rts
000B9Ar 2               @SgnNeg:
000B9Ar 2  A9 FF          lda #$FF
000B9Cr 2  85 0A          sta BAS_ACC
000B9Er 2  85 0B          sta BAS_ACC + 1                ; $FFFF = -1 (signed)
000BA0r 2  60             rts
000BA1r 2               @SgnZero:
000BA1r 2  64 0A          stz BAS_ACC
000BA3r 2  64 0B          stz BAS_ACC + 1
000BA5r 2  60             rts
000BA6r 2               @NotSgn:
000BA6r 2               
000BA6r 2                 ; CHR(n) — return value (identity in expression context)
000BA6r 2  C9 AF          cmp #TOK_CHR
000BA8r 2  D0 11          bne @NotChr
000BAAr 2  20 rr rr       jsr BasAdvTxtPtr               ; skip TOK_CHR
000BADr 2  A9 28          lda #CH_LPAREN
000BAFr 2  20 rr rr       jsr BasExpectChar
000BB2r 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
000BB5r 2  A9 29          lda #CH_RPAREN
000BB7r 2  20 rr rr       jsr BasExpectChar
000BBAr 2  60             rts                            ; BAS_ACC already holds n
000BBBr 2               @NotChr:
000BBBr 2               
000BBBr 2                 ; SQR(n) — Integer square root
000BBBr 2  C9 B6          cmp #TOK_SQR
000BBDr 2  D0 13          bne @NotSqr
000BBFr 2  20 rr rr       jsr BasAdvTxtPtr
000BC2r 2  A9 28          lda #CH_LPAREN
000BC4r 2  20 rr rr       jsr BasExpectChar
000BC7r 2  20 rr rr       jsr BasExpr
