000000r 1               
000000r 1               .segment "KERNAL"
000000r 1               .include "Kernal.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   KERNAL    ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               ; Main entry point
000000r 2               Reset:
000000r 2  D8             cld                           ; Clear decimal mode
000001r 2  78             sei                           ; Disable interrupts
000002r 2               
000002r 2  A2 FF          ldx #$ff
000004r 2  9A             txs                           ; Reset the stack pointer
000005r 2               
000005r 2  A9 rr          lda #<Irq                     ; Initialize the IRQ pointer
000007r 2  8D 00 03       sta IRQ_PTR
00000Ar 2  A9 rr          lda #>Irq
00000Cr 2  8D 01 03       sta IRQ_PTR + 1
00000Fr 2               
00000Fr 2  A9 rr          lda #<Nmi                     ; Initialize the NMI pointer
000011r 2  8D 04 03       sta NMI_PTR
000014r 2  A9 rr          lda #>Nmi
000016r 2  8D 05 03       sta NMI_PTR + 1
000019r 2               
000019r 2  20 rr rr       jsr InitBuffer                ; Initialize the input buffer
00001Cr 2  20 rr rr       jsr InitSC                    ; Initialize the Serial Card (6551)
00001Fr 2  20 rr rr       jsr InitSID                   ; Initialize the Sound Card (6581)
000022r 2  20 rr rr       jsr InitVideo                 ; Initialize the Video Card (TMS9918)
000025r 2  20 rr rr       jsr InitCharacters            ; Initialize the character set
000028r 2               
000028r 2  20 rr rr       jsr Beep                      ; Play the startup beep
00002Br 2  20 rr rr       jsr Splash                    ; Draw the splash screen
00002Er 2               
00002Er 2  58             cli                           ; Enable interrupts
00002Fr 2               
00002Fr 2  4C rr rr       jmp WozMon                    ; Jump to Wozmon
000032r 2               
000032r 2               ; Initialize the Serial Card (6551)
000032r 2               ; Modifies: Flags, A
000032r 2               InitSC:
000032r 2  A9 1F          lda     #$1F                  ; 8-N-1, 19200 baud
000034r 2  8D 03 90       sta     SC_CTRL
000037r 2  A9 09          lda     #$09                  ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
000039r 2  8D 02 90       sta     SC_CMD
00003Cr 2  60             rts
00003Dr 2               
00003Dr 2               ; Initialze the Sound Card (6581)
00003Dr 2               ; Modifies: Flags, A, X
00003Dr 2               InitSID:
00003Dr 2  A9 00          lda #$00
00003Fr 2  A2 1D          ldx #$1D                      ; Clear all 29 SID registers
000041r 2               @InitSIDLoop:
000041r 2  9D 00 98       sta SID_V1_FREQ_LO,x          ; Clear register
000044r 2  CA             dex
000045r 2  10 FA          bpl @InitSIDLoop              ; Loop until all registers cleared
000047r 2  A9 0F          lda #$0F                      ; Set volume to maximum
000049r 2  8D 18 98       sta SID_MODE_VOL
00004Cr 2  60             rts
00004Dr 2               
00004Dr 2               ; Initialize the Video Card (TMS9918)
00004Dr 2               ; Modifies: Flags, A, X
00004Dr 2               InitVideo:
00004Dr 2  A2 00          ldx #$00                      ; Start with register 0
00004Fr 2               @InitVideoLoop:
00004Fr 2  BD rr rr       lda @InitVideoRegData,x       ; Load register value
000052r 2  8D 01 9C       sta VC_REG                    ; Write data byte
000055r 2  8A             txa
000056r 2  09 80          ora #$80                      ; Set bit 7 to indicate register write
000058r 2  8D 01 9C       sta VC_REG                    ; Write register number
00005Br 2  E8             inx
00005Cr 2  E0 08          cpx #$08                      ; Check if all 8 registers written
00005Er 2  D0 EF          bne @InitVideoLoop            ; Continue until done
000060r 2  60             rts
000061r 2               @InitVideoRegData:
000061r 2  00             .byte $00                     ; R0: Mode control (no external video)
000062r 2  D0             .byte $D0                     ; R1: 16K, display on, interrupt off, text mode M1
000063r 2  00             .byte $00                     ; R2: Name table at $0000 (0x00 * 0x400)
000064r 2  00             .byte $00                     ; R3: Color table (not used in text mode)
000065r 2  01             .byte $01                     ; R4: Pattern table at $0800 (0x01 * 0x800)
000066r 2  00             .byte $00                     ; R5: Sprite attribute table (not used in text mode)
000067r 2  00             .byte $00                     ; R6: Sprite pattern table (not used in text mode)
000068r 2  F0             .byte $F0                     ; R7: White text on black background
000069r 2               
000069r 2               ; Initialize the character set
000069r 2               ; Modifies: Flags, A, X, Y
000069r 2               InitCharacters:
000069r 2                 ; Set VRAM write address to $0800 (pattern table base)
000069r 2  A9 00          lda #$00                      ; Low byte of address
00006Br 2  8D 01 9C       sta VC_REG
00006Er 2  A9 48          lda #$48                      ; High byte ($08) OR $40 for write mode
000070r 2  8D 01 9C       sta VC_REG
000073r 2                 ; Set up source pointer
000073r 2  A9 rr          lda #<CharacterSet
000075r 2  85 02          sta STR_PTR                   ; Use STR_PTR ($02-$03) for character set pointer
000077r 2  A9 rr          lda #>CharacterSet
000079r 2  85 03          sta STR_PTR + 1
00007Br 2                 ; Copy 2048 bytes (8 pages of 256 bytes each)
00007Br 2  A2 08          ldx #$08                      ; 8 pages to copy
00007Dr 2  A0 00          ldy #$00                      ; Byte counter within page
00007Fr 2               @InitCharPageLoop:
00007Fr 2  B1 02          lda (STR_PTR),y               ; Load from character set
000081r 2  8D 00 9C       sta VC_DATA                   ; Write to VRAM
000084r 2  C8             iny
000085r 2  D0 F8          bne @InitCharPageLoop         ; Loop until page complete (256 bytes)
000087r 2  E6 03          inc STR_PTR + 1               ; Move to next page
000089r 2  CA             dex
00008Ar 2  D0 F3          bne @InitCharPageLoop         ; Loop for all 8 pages
00008Cr 2  60             rts
00008Dr 2               
00008Dr 2               ; Initialize the INPUT_BUFFER
00008Dr 2               ; Modifies: Flags, A
00008Dr 2               InitBuffer:
00008Dr 2  A9 00          lda #$00
00008Fr 2  85 00          sta READ_PTR                  ; Init read and write pointers
000091r 2  85 01          sta WRITE_PTR
000093r 2  60             rts
000094r 2               
000094r 2               ; Write a character from the A register to the INPUT_BUFFER
000094r 2               ; Modifies: Flags, X
000094r 2               WriteBuffer:
000094r 2  A6 01          ldx WRITE_PTR
000096r 2  9D 00 02       sta INPUT_BUFFER,x
000099r 2  E6 01          inc WRITE_PTR
00009Br 2  60             rts
00009Cr 2               
00009Cr 2               ; Read a character from the INPUT_BUFFER and store it in A register
00009Cr 2               ; Modifies: Flags, X, A
00009Cr 2               ReadBuffer:
00009Cr 2  A6 00          ldx READ_PTR
00009Er 2  BD 00 02       lda INPUT_BUFFER,x
0000A1r 2  E6 00          inc READ_PTR
0000A3r 2  60             rts
0000A4r 2               
0000A4r 2               ; Return in A register the number of unread bytes in the INPUT_BUFFER
0000A4r 2               ; Modifies: Flags, A
0000A4r 2               BufferSize:
0000A4r 2  A5 01          lda WRITE_PTR
0000A6r 2  38             sec
0000A7r 2  E5 00          sbc READ_PTR
0000A9r 2  60             rts
0000AAr 2               
0000AAr 2               ; Get a character from the INPUT_BUFFER if available
0000AAr 2               ; On return, carry flag indicates whether a character was available
0000AAr 2               ; If character available the character will be in the A register
0000AAr 2               ; Modifies: Flags, A
0000AAr 2               Chrin:
0000AAr 2  DA             phx
0000ABr 2  20 rr rr       jsr BufferSize                ; Check for character available
0000AEr 2  F0 1E          beq @ChrinNoChar              ; Branch if no character available
0000B0r 2  20 rr rr       jsr ReadBuffer                ; Read the character from the buffer
0000B3r 2  20 rr rr       jsr Chrout                    ; Echo
0000B6r 2  48             pha
0000B7r 2  20 rr rr       jsr BufferSize
0000BAr 2  C9 B0          cmp #$B0                      ; Check if buffer is mostly full
0000BCr 2  90 07          bcc @ChrinNotFull             ; Branch if buffer size < $B0
0000BEr 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
0000C0r 2  8D 02 90       sta SC_CMD
0000C3r 2  80 05          bra @ChrinExit
0000C5r 2               @ChrinNotFull:
0000C5r 2  A9 09          lda #$09                      ; No parity, no echo, RTSB low, TX interrupts disabled, RX interrupts enabled
0000C7r 2  8D 02 90       sta SC_CMD
0000CAr 2               @ChrinExit:
0000CAr 2  68             pla
0000CBr 2  FA             plx
0000CCr 2  38             sec
0000CDr 2  60             rts
0000CEr 2               @ChrinNoChar:
0000CEr 2  FA             plx
0000CFr 2  18             clc
0000D0r 2  60             rts
0000D1r 2               
0000D1r 2               ; Output a character from the A register to the Serial Card
0000D1r 2               ; Modifies: Flags
0000D1r 2               Chrout:
0000D1r 2  8D 00 90       sta SC_DATA
0000D4r 2  48             pha
0000D5r 2               @ChroutWait:
0000D5r 2  AD 01 90       lda SC_STATUS
0000D8r 2  29 10          and #SC_STATUS_TDRE           ; Check if TX buffer not empty
0000DAr 2  F0 F9          beq @ChroutWait               ; Loop if TX buffer not empty
0000DCr 2  68             pla
0000DDr 2  60             rts
0000DEr 2               
0000DEr 2               ; Play a short beep sound
0000DEr 2               ; Modifies: Flags, A, X, Y
0000DEr 2               Beep:
0000DEr 2  A9 09          lda #$09                      ; Set Attack = 0, Decay = 9 (fast)
0000E0r 2  8D 05 98       sta SID_V1_AD
0000E3r 2  A9 00          lda #$00                      ; Set Sustain = 0, Release = 0
0000E5r 2  8D 06 98       sta SID_V1_SR
0000E8r 2  A9 20          lda #$20                      ; Frequency low byte (~8000 Hz / 1000 Hz tone)
0000EAr 2  8D 00 98       sta SID_V1_FREQ_LO
0000EDr 2  A9 1F          lda #$1F                      ; Frequency high byte (for ~1000 Hz)
0000EFr 2  8D 01 98       sta SID_V1_FREQ_HI
0000F2r 2  A9 11          lda #$11                      ; Triangle wave + Gate on
0000F4r 2  8D 04 98       sta SID_V1_CTRL
0000F7r 2                 ; Delay for beep duration
0000F7r 2  A2 F0          ldx #$F0                      ; Outer loop counter
0000F9r 2               @BeepDelay1:
0000F9r 2  A0 FF          ldy #$FF                      ; Inner loop counter
0000FBr 2               @BeepDelay2:
0000FBr 2  88             dey
0000FCr 2  D0 FD          bne @BeepDelay2
0000FEr 2  CA             dex
0000FFr 2  D0 F8          bne @BeepDelay1
000101r 2  A9 10          lda #$10                      ; Gate off (stop sound)
000103r 2  8D 04 98       sta SID_V1_CTRL
000106r 2  60             rts
000107r 2               
000107r 2               ; Draw the splash screen
000107r 2               ; Modifies: Flags, A, X, Y
000107r 2               Splash:
000107r 2                 ; Set VRAM write address to center of screen
000107r 2                 ; Name table base = $0000, center position = row 11, col 10
000107r 2                 ; Address = $0000 + (11 * 40) + 6 = $01B8 + $0A = $01C2
000107r 2  A9 C2          lda #$C2                      ; Low byte of address
000109r 2  8D 01 9C       sta VC_REG
00010Cr 2  A9 41          lda #$41                      ; High byte ($01) OR $40 for write mode
00010Er 2  8D 01 9C       sta VC_REG
000111r 2                 ; Set up string pointer
000111r 2  A9 rr          lda #<@SplashText
000113r 2  85 02          sta STR_PTR
000115r 2  A9 rr          lda #>@SplashText
000117r 2  85 03          sta STR_PTR + 1
000119r 2                 ; Write string to VRAM
000119r 2  A0 00          ldy #$00
00011Br 2               @SplashLoop:
00011Br 2  B1 02          lda (STR_PTR),y
00011Dr 2  F0 06          beq @SplashDone               ; Exit if null terminator
00011Fr 2  8D 00 9C       sta VC_DATA                   ; Write character to VRAM
000122r 2  C8             iny
000123r 2  D0 F6          bne @SplashLoop
000125r 2               @SplashDone:
000125r 2  60             rts
000126r 2  2D 2D 20 54  @SplashText: .asciiz "-- The 'COB' v1.0 --"
00012Ar 2  68 65 20 27  
00012Er 2  43 4F 42 27  
00013Br 2               
00013Br 2               ; NMI Handler
00013Br 2               Nmi:
00013Br 2  40             rti
00013Cr 2               
00013Cr 2               ; IRQ Handler
00013Cr 2               Irq:
00013Cr 2  48             pha
00013Dr 2  5A             phy
00013Er 2  DA             phx
00013Fr 2  AD 01 90       lda SC_STATUS
000142r 2  29 80          and #SC_STATUS_IRQ            ; Check if serial data caused the interrupt
000144r 2  F0 12          beq @IrqExit                  ; If not, exit
000146r 2  AD 00 90       lda SC_DATA                   ; Read the data from serial register
000149r 2  20 rr rr       jsr WriteBuffer               ; Store to the input buffer
00014Cr 2  20 rr rr       jsr BufferSize
00014Fr 2  C9 F0          cmp #$F0                      ; Is the buffer almost full?
000151r 2  90 05          bcc @IrqExit                  ; If not, exit
000153r 2  A9 01          lda #$01                      ; No parity, no echo, RTSB high, TX interrupts disabled, RX interrupts enabled
000155r 2  8D 02 90       sta SC_CMD                    ; Otherwise, signal not ready for receiving (RTSB high)
000158r 2               @IrqExit:
000158r 2  FA             plx
000159r 2  7A             ply
00015Ar 2  68             pla
00015Br 2  40             rti
00015Cr 2               
00015Cr 2               ; NMI Vector
00015Cr 2               NmiVec:
00015Cr 2  6C 04 03       jmp (NMI_PTR)                 ; Indirect jump through NMI pointer to the NMI handler
00015Fr 2               
00015Fr 2               ; Reset Vector
00015Fr 2               ResetVec:
00015Fr 2  4C rr rr       jmp Reset                     ; Initialize the system
000162r 2               
000162r 2               ; IRQ Vector
000162r 2               IrqVec:
000162r 2  6C 00 03       jmp (IRQ_PTR)                 ; Indirect jump through IRQ pointer to the IRQ handler
000165r 2               
000165r 1               .segment "CHARACTERS"
000000r 1               .include "Characters.asm"
000000r 2               ; IBM Code Page 437 Character Set
000000r 2               ; 6x8 pixel font in 8x8 area, 8 bytes per character (256 characters total)
000000r 2               ; Each byte represents one horizontal row of pixels (6 pixels centered in 8-bit space)
000000r 2               
000000r 2               CharacterSet:
000000r 2                   ; Character $00 - NULL (blank)
000000r 2  00 00 00 00      .byte $00, $00, $00, $00, $00, $00, $00, $00
000004r 2  00 00 00 00  
