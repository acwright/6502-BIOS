001E44r 2  4E 4F 54 00    .byte "NOT",    $00, TOK_NOT
001E48r 2  96           
001E49r 2  41 4E 44 00    .byte "AND",    $00, TOK_AND
001E4Dr 2  97           
001E4Er 2  4D 4F 44 00    .byte "MOD",    $00, TOK_MOD
001E52r 2  99           
001E53r 2  44 49 4D 00    .byte "DIM",    $00, TOK_DIM
001E57r 2  C3           
001E58r 2  4D 45 4D 00    .byte "MEM",    $00, TOK_MEM
001E5Cr 2  C2           
001E5Dr 2  53 59 53 00    .byte "SYS",    $00, TOK_SYS
001E61r 2  9E           
001E62r 2  44 49 52 00    .byte "DIR",    $00, TOK_DIR
001E66r 2  A1           
001E67r 2  44 45 4C 00    .byte "DEL",    $00, TOK_DEL
001E6Br 2  A2           
001E6Cr 2  42 52 4B 00    .byte "BRK",    $00, TOK_BRK
001E70r 2  9D           
001E71r 2  43 4C 53 00    .byte "CLS",    $00, TOK_CLS
001E75r 2  A3           
001E76r 2  56 4F 4C 00    .byte "VOL",    $00, TOK_VOL
001E7Ar 2  A8           
001E7Br 2  4A 4F 59 00    .byte "JOY",    $00, TOK_JOY
001E7Fr 2  A6           
001E80r 2  53 47 4E 00    .byte "SGN",    $00, TOK_SGN
001E84r 2  AE           
001E85r 2  43 48 52 00    .byte "CHR",    $00, TOK_CHR
001E89r 2  AF           
001E8Ar 2  53 51 52 00    .byte "SQR",    $00, TOK_SQR
001E8Er 2  B6           
001E8Fr 2  4D 49 4E 00    .byte "MIN",    $00, TOK_MIN
001E93r 2  B7           
001E94r 2  4D 41 58 00    .byte "MAX",    $00, TOK_MAX
001E98r 2  B8           
001E99r 2  50 4F 57 00    .byte "POW",    $00, TOK_POW
001E9Dr 2  B9           
001E9Er 2  54 41 42 00    .byte "TAB",    $00, TOK_TAB
001EA2r 2  BB           
001EA3r 2  48 45 58 00    .byte "HEX",    $00, TOK_HEX
001EA7r 2  BC           
001EA8r 2  41 53 43 00    .byte "ASC",    $00, TOK_ASC
001EACr 2  BD           
001EADr 2  4F 4E 00 B2    .byte "ON",     $00, TOK_ON
001EB1r 2  49 46 00 86    .byte "IF",     $00, TOK_IF
001EB5r 2  54 4F 00 89    .byte "TO",     $00, TOK_TO
001EB9r 2  4F 52 00 98    .byte "OR",     $00, TOK_OR
001EBDr 2  00             .byte $00                       ; End of table sentinel
001EBEr 2               
001EBEr 2               ; ============================================================================
001EBEr 2               ; BasPrintNoDevice — Print "?NO DEVICE" and return
001EBEr 2               ; Used by hardware-guarded commands when device is absent
001EBEr 2               ; ============================================================================
001EBEr 2               BasPrintNoDevice:
001EBEr 2  A9 rr          lda #<BasStrNoDevice
001EC0r 2  85 0E          sta BAS_TMP1
001EC2r 2  A9 rr          lda #>BasStrNoDevice
001EC4r 2  85 0F          sta BAS_TMP1 + 1
001EC6r 2  20 rr rr       jsr BasPrintStr
001EC9r 2  60             rts
001ECAr 2               
001ECAr 2               ; ============================================================================
001ECAr 2               ; String Data
001ECAr 2               ; ============================================================================
001ECAr 2               
001ECAr 2  0D 0A 36 35  BasStrWelcome:  .byte CH_CR, CH_LF, "6502 BASIC v1.0", CH_CR, CH_LF, $00
001ECEr 2  30 32 20 42  
001ED2r 2  41 53 49 43  
001EDEr 2  0D 0A 4F 4B  BasStrOK:       .byte CH_CR, CH_LF, "OK", CH_CR, CH_LF, $00
001EE2r 2  0D 0A 00     
001EE5r 2  20 42 59 54  BasStrFree:     .byte " BYTES FREE", $00
001EE9r 2  45 53 20 46  
001EEDr 2  52 45 45 00  
001EF1r 2  20 45 52 52  BasStrError:    .byte " ERROR", $00
001EF5r 2  4F 52 00     
001EF8r 2  20 49 4E 20  BasStrIn:       .byte " IN ", $00
001EFCr 2  00           
001EFDr 2  3F 52 45 44  BasStrRedo:     .byte "?REDO", CH_CR, CH_LF, $00
001F01r 2  4F 0D 0A 00  
001F05r 2  3F 20 00     BasStrPrompt:   .byte "? ", $00
001F08r 2  0D 0A 3F 4C  BasStrLoadErr:  .byte CH_CR, CH_LF, "?LOAD ERROR", CH_CR, CH_LF, $00
001F0Cr 2  4F 41 44 20  
001F10r 2  45 52 52 4F  
001F18r 2  0D 0A 3F 53  BasStrSaveErr:  .byte CH_CR, CH_LF, "?SAVE ERROR", CH_CR, CH_LF, $00
001F1Cr 2  41 56 45 20  
001F20r 2  45 52 52 4F  
001F28r 2  0D 0A 3F 44  BasStrDelErr:   .byte CH_CR, CH_LF, "?DEL ERROR", CH_CR, CH_LF, $00
001F2Cr 2  45 4C 20 45  
001F30r 2  52 52 4F 52  
001F37r 2  0D 0A 3F 4E  BasStrNoDevice: .byte CH_CR, CH_LF, "?NO DEVICE", CH_CR, CH_LF, $00
001F3Br 2  4F 20 44 45  
001F3Fr 2  56 49 43 45  
001F46r 2               
001F46r 2               ; MEM command strings
001F46r 2  0D 0A 48 57  BasStrMemHW:    .byte CH_CR, CH_LF, "HW: $", $00
001F4Ar 2  3A 20 24 00  
001F4Er 2  0D 0A 49 4F  BasStrMemIO:    .byte CH_CR, CH_LF, "IO: ", $00
001F52r 2  3A 20 00     
001F55r 2               
001F55r 2               
001F55r 1               .segment "MONITOR"
000000r 1               .include "Monitor.asm"
000000r 2               ; ***             ***
000000r 2               ; ***   MONITOR   ***
000000r 2               ; ***             ***
000000r 2               
000000r 2               ; Machine Code Monitor — Supermon-style command set
000000r 2               ; Segment: $E800-$FEFF (~6KB)
000000r 2               ;
000000r 2               ; Entry points:
000000r 2               ;   MonitorEntry    ($E800) — Cold entry from boot menu or X return
000000r 2               ;   MonitorBrkEntry ($E803) — BRK entry with register display
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Monitor Constants
000000r 2               ; ============================================================================
000000r 2               
000000r 2               MON_LINBUF          = BAS_LINBUF         ; Share BASIC's line buffer ($0434)
000000r 2               MON_LINBUF_SIZE     = 200                ; Max input line length
000000r 2               MON_PROMPT          = '.'                ; Supermon-style prompt character
000000r 2               
000000r 2               ; Mnemonic Indices (for disassembler)
000000r 2               MN_ADC = 0
000000r 2               MN_AND = 1
000000r 2               MN_ASL = 2
000000r 2               MN_BBR = 3
000000r 2               MN_BBS = 4
000000r 2               MN_BCC = 5
000000r 2               MN_BCS = 6
000000r 2               MN_BEQ = 7
000000r 2               MN_BIT = 8
000000r 2               MN_BMI = 9
000000r 2               MN_BNE = 10
000000r 2               MN_BPL = 11
000000r 2               MN_BRA = 12
000000r 2               MN_BRK = 13
000000r 2               MN_BVC = 14
000000r 2               MN_BVS = 15
000000r 2               MN_CLC = 16
000000r 2               MN_CLD = 17
000000r 2               MN_CLI = 18
000000r 2               MN_CLV = 19
000000r 2               MN_CMP = 20
000000r 2               MN_CPX = 21
000000r 2               MN_CPY = 22
000000r 2               MN_DEC = 23
000000r 2               MN_DEX = 24
000000r 2               MN_DEY = 25
000000r 2               MN_EOR = 26
000000r 2               MN_INC = 27
000000r 2               MN_INX = 28
000000r 2               MN_INY = 29
000000r 2               MN_JMP = 30
000000r 2               MN_JSR = 31
000000r 2               MN_LDA = 32
000000r 2               MN_LDX = 33
000000r 2               MN_LDY = 34
000000r 2               MN_LSR = 35
000000r 2               MN_NOP = 36
000000r 2               MN_ORA = 37
000000r 2               MN_PHA = 38
000000r 2               MN_PHP = 39
000000r 2               MN_PHX = 40
000000r 2               MN_PHY = 41
000000r 2               MN_PLA = 42
000000r 2               MN_PLP = 43
000000r 2               MN_PLX = 44
000000r 2               MN_PLY = 45
000000r 2               MN_RMB = 46
000000r 2               MN_ROL = 47
000000r 2               MN_ROR = 48
000000r 2               MN_RTI = 49
000000r 2               MN_RTS = 50
000000r 2               MN_SBC = 51
000000r 2               MN_SEC = 52
000000r 2               MN_SED = 53
000000r 2               MN_SEI = 54
000000r 2               MN_SMB = 55
000000r 2               MN_STA = 56
000000r 2               MN_STP = 57
000000r 2               MN_STX = 58
000000r 2               MN_STY = 59
000000r 2               MN_STZ = 60
000000r 2               MN_TAX = 61
000000r 2               MN_TAY = 62
000000r 2               MN_TRB = 63
000000r 2               MN_TSB = 64
000000r 2               MN_TSX = 65
000000r 2               MN_TXA = 66
000000r 2               MN_TXS = 67
000000r 2               MN_TYA = 68
000000r 2               MN_WAI = 69
000000r 2               MN_UND = 70
000000r 2               
000000r 2               ; Addressing Mode Indices
000000r 2               AM_IMP = 0
000000r 2               AM_ACC = 1
000000r 2               AM_IMM = 2
000000r 2               AM_ZP  = 3
000000r 2               AM_ZPX = 4
000000r 2               AM_ZPY = 5
000000r 2               AM_ABS = 6
000000r 2               AM_ABX = 7
000000r 2               AM_ABY = 8
000000r 2               AM_IND = 9
000000r 2               AM_IZX = 10
000000r 2               AM_IZY = 11
000000r 2               AM_ZPI = 12
000000r 2               AM_REL = 13
000000r 2               AM_ZPR = 14
000000r 2               AM_AIX = 15
000000r 2               
000000r 2               ; ============================================================================
000000r 2               ; Entry Points
000000r 2               ; ============================================================================
000000r 2               
000000r 2               MonitorEntry:
000000r 2  4C rr rr       jmp MonColdEntry              ; $E800 - Cold entry (boot menu / return)
000003r 2               
000003r 2               MonitorBrkEntry:
000003r 2  4C rr rr       jmp MonBrkEntry               ; $C003 - BRK entry (register display)
000006r 2               
000006r 2               ; ============================================================================
000006r 2               ; Cold Entry — print banner and enter command loop
000006r 2               ; ============================================================================
000006r 2               
000006r 2               MonColdEntry:
000006r 2  A2 FF          ldx #$FF
000008r 2  9A             txs                           ; Reset stack pointer
000009r 2  D8             cld                           ; Ensure binary mode
00000Ar 2  20 rr rr       jsr VideoClear                ; Clear screen
00000Dr 2  20 rr rr       jsr MonPrintBanner            ; Print "MONITOR" banner
000010r 2  4C rr rr       jmp MonCmdLoop
000013r 2               
000013r 2               ; ============================================================================
000013r 2               ; BRK Entry — print BRK address, display registers, enter command loop
000013r 2               ; ============================================================================
000013r 2               
000013r 2               MonBrkEntry:
000013r 2  A2 FF          ldx #$FF
000015r 2  9A             txs                           ; Reset stack pointer
000016r 2  D8             cld
000017r 2  20 rr rr       jsr VideoClear                ; Clear screen
00001Ar 2  20 rr rr       jsr MonPrintBanner            ; Print "MONITOR" banner
00001Dr 2                 ; Print "BRK AT $"
00001Dr 2  A2 00          ldx #0
00001Fr 2               @BrkMsgLoop:
00001Fr 2  BD rr rr       lda MonStrBrk,x
000022r 2  F0 06          beq @BrkMsgDone
000024r 2  20 rr rr       jsr Chrout
000027r 2  E8             inx
000028r 2  80 F5          bra @BrkMsgLoop
00002Ar 2               @BrkMsgDone:
00002Ar 2                 ; Print PC address (adjusted: BRK_PC points to BRK+2, subtract 2 for actual BRK location)
00002Ar 2  38             sec
00002Br 2  AD 11 03       lda BRK_PCL
00002Er 2  E9 02          sbc #2
000030r 2  85 2E          sta MON_ADDR
000032r 2  AD 12 03       lda BRK_PCH
000035r 2  E9 00          sbc #0
000037r 2  85 2F          sta MON_ADDR + 1
000039r 2  20 rr rr       jsr MonPrintHex4
00003Cr 2  20 rr rr       jsr MonPrintCRLF
00003Fr 2                 ; Display registers
00003Fr 2  20 rr rr       jsr MonShowRegs
000042r 2  4C rr rr       jmp MonCmdLoop
000045r 2               
000045r 2               ; ============================================================================
000045r 2               ; Command Loop — prompt, read, parse, dispatch
000045r 2               ; ============================================================================
000045r 2               
000045r 2               MonCmdLoop:
000045r 2                 ; Print prompt
000045r 2  A9 2E          lda #MON_PROMPT
000047r 2  20 rr rr       jsr Chrout
00004Ar 2  A9 20          lda #' '
00004Cr 2  20 rr rr       jsr Chrout
00004Fr 2               
00004Fr 2                 ; Read input line
00004Fr 2  20 rr rr       jsr MonReadLine
000052r 2               
000052r 2                 ; Parse and dispatch
000052r 2  20 rr rr       jsr MonParseLine
000055r 2               
000055r 2                 ; Loop back for next command
000055r 2  4C rr rr       jmp MonCmdLoop
000058r 2               
000058r 2               ; ============================================================================
000058r 2               ; MonReadLine — Read a line of input into MON_LINBUF
000058r 2               ; Returns: MON_LINBUF contains null-terminated input, Y = length
000058r 2               ; ============================================================================
000058r 2               
000058r 2               MonReadLine:
000058r 2  A0 00          ldy #0                        ; Index into line buffer
00005Ar 2               @ReadWait:
00005Ar 2  20 rr rr       jsr Chrin                     ; Try to read a character (carry set = got one)
00005Dr 2  90 FB          bcc @ReadWait                 ; No char available, keep waiting
00005Fr 2                 ; Got a character in A
00005Fr 2  C9 0D          cmp #$0D                      ; Carriage return?
000061r 2  F0 21          beq @ReadDone
000063r 2  C9 0A          cmp #$0A                      ; Line feed? (treat same as CR)
000065r 2  F0 1D          beq @ReadDone
000067r 2  C9 08          cmp #$08                      ; Backspace?
000069r 2  F0 12          beq @ReadBS
00006Br 2  C9 7F          cmp #$7F                      ; Delete? (treat as backspace)
00006Dr 2  F0 0E          beq @ReadBS
00006Fr 2                 ; Skip non-printable characters ($00-$1F)
00006Fr 2  C9 20          cmp #$20
000071r 2  90 E7          bcc @ReadWait
000073r 2                 ; Printable character — store if room
000073r 2  C0 C8          cpy #MON_LINBUF_SIZE
000075r 2  B0 E3          bcs @ReadWait                 ; Buffer full, ignore
000077r 2  99 34 04       sta MON_LINBUF,y
00007Ar 2  C8             iny
00007Br 2  80 DD          bra @ReadWait
00007Dr 2               @ReadBS:
00007Dr 2  C0 00          cpy #0                        ; Anything to delete?
00007Fr 2  F0 D9          beq @ReadWait                 ; No, ignore
000081r 2  88             dey                           ; Back up one position
000082r 2  80 D6          bra @ReadWait
000084r 2               @ReadDone:
000084r 2  A9 0D          lda #$0D                      ; Echo CR
000086r 2  20 rr rr       jsr Chrout
000089r 2  A9 0A          lda #$0A                      ; Echo LF
00008Br 2  20 rr rr       jsr Chrout
00008Er 2  A9 00          lda #0
000090r 2  99 34 04       sta MON_LINBUF,y              ; Null-terminate
000093r 2  60             rts
000094r 2               
000094r 2               ; ============================================================================
000094r 2               ; MonParseLine — Parse first char and dispatch to command handler
000094r 2               ; ============================================================================
000094r 2               
000094r 2               MonParseLine:
000094r 2  64 35          stz MON_IDX                   ; Reset parse index
000096r 2  20 rr rr       jsr MonSkipSpaces             ; Skip leading whitespace
000099r 2  A4 35          ldy MON_IDX
00009Br 2  B9 34 04       lda MON_LINBUF,y              ; Get command character
00009Er 2  F0 2A          beq @ParseDone                ; Empty line — just return
0000A0r 2                 ; Convert to uppercase
0000A0r 2  C9 61          cmp #'a'
0000A2r 2  90 06          bcc @ParseNoConv
0000A4r 2  C9 7B          cmp #'z'+1
0000A6r 2  B0 02          bcs @ParseNoConv
0000A8r 2  29 DF          and #$DF                      ; Convert lowercase to uppercase
0000AAr 2               @ParseNoConv:
0000AAr 2  E6 35          inc MON_IDX                   ; Advance past command char
0000ACr 2                 ; Search dispatch table
0000ACr 2  A2 00          ldx #0
0000AEr 2               @DispatchLoop:
0000AEr 2  BC rr rr       ldy MonCmdTable,x             ; Load command character from table
0000B1r 2  F0 14          beq @ParseError               ; End of table (null terminator) — unknown command
0000B3r 2  DD rr rr       cmp MonCmdTable,x             ; Compare with input character
0000B6r 2  F0 05          beq @DispatchFound
0000B8r 2  E8             inx                           ; Skip char
0000B9r 2  E8             inx                           ; Skip address low
0000BAr 2  E8             inx                           ; Skip address high
0000BBr 2  80 F1          bra @DispatchLoop
0000BDr 2               @DispatchFound:
0000BDr 2  E8             inx                           ; Point to address low byte
0000BEr 2  BD rr rr       lda MonCmdTable+1,x           ; Handler address high byte — push first (big-endian on stack)
0000C1r 2  48             pha
0000C2r 2  BD rr rr       lda MonCmdTable,x             ; Handler address low byte
0000C5r 2  48             pha
0000C6r 2  60             rts                           ; "Return" to handler address (RTS adds 1 to address)
0000C7r 2               @ParseError:
0000C7r 2  20 rr rr       jsr MonPrintError
0000CAr 2               @ParseDone:
0000CAr 2  60             rts
0000CBr 2               
0000CBr 2               ; ============================================================================
0000CBr 2               ; Command Dispatch Table
0000CBr 2               ; Format: command char (1 byte), handler address - 1 (2 bytes, low/high for RTS trick)
0000CBr 2               ; ============================================================================
0000CBr 2               
0000CBr 2               MonCmdTable:
0000CBr 2  58             .byte 'X'
0000CCr 2  rr rr          .word MonCmdX - 1
0000CEr 2  52             .byte 'R'
0000CFr 2  rr rr          .word MonCmdR - 1
0000D1r 2  4D             .byte 'M'
0000D2r 2  rr rr          .word MonCmdM - 1
0000D4r 2  44             .byte 'D'
0000D5r 2  rr rr          .word MonCmdD - 1
0000D7r 2  3E             .byte '>'
0000D8r 2  rr rr          .word MonCmdDeposit - 1
0000DAr 2  46             .byte 'F'
0000DBr 2  rr rr          .word MonCmdFill - 1
0000DDr 2  54             .byte 'T'
0000DEr 2  rr rr          .word MonCmdTransfer - 1
0000E0r 2  48             .byte 'H'
0000E1r 2  rr rr          .word MonCmdHunt - 1
0000E3r 2  43             .byte 'C'
0000E4r 2  rr rr          .word MonCmdCompare - 1
0000E6r 2  47             .byte 'G'
0000E7r 2  rr rr          .word MonCmdGo - 1
0000E9r 2  4A             .byte 'J'
0000EAr 2  rr rr          .word MonCmdJsr - 1
0000ECr 2  3B             .byte ';'
0000EDr 2  rr rr          .word MonCmdModRegs - 1
0000EFr 2  4C             .byte 'L'
0000F0r 2  rr rr          .word MonCmdLoad - 1
0000F2r 2  53             .byte 'S'
0000F3r 2  rr rr          .word MonCmdSave - 1
0000F5r 2  40             .byte '@'
0000F6r 2  rr rr          .word MonCmdDir - 1
0000F8r 2  4E             .byte 'N'
0000F9r 2  rr rr          .word MonCmdNum - 1
0000FBr 2  00             .byte 0                       ; End of table sentinel
0000FCr 2               
0000FCr 2               ; ============================================================================
0000FCr 2               ; MonCmdX — Exit to BASIC
0000FCr 2               ; ============================================================================
0000FCr 2               
0000FCr 2               MonCmdX:
0000FCr 2  20 rr rr       jsr VideoClear                ; Clear screen before entering BASIC
0000FFr 2  4C rr rr       jmp BasColdStart
000102r 2               
000102r 2               ; ============================================================================
000102r 2               ; MonCmdR — Display CPU registers
000102r 2               ; ============================================================================
000102r 2               
000102r 2               MonCmdR:
000102r 2  20 rr rr       jsr MonShowRegs
000105r 2  60             rts
000106r 2               
000106r 2               ; ============================================================================
000106r 2               ; MonCmdDeposit — Deposit (write) bytes to memory
000106r 2               ; Syntax: > ADDR XX [XX XX ...]
000106r 2               ; ============================================================================
000106r 2               
000106r 2               MonCmdDeposit:
000106r 2  20 rr rr       jsr MonSkipSpaces
000109r 2  20 rr rr       jsr MonParseHex4              ; Parse target address into MON_ADDR
00010Cr 2  90 16          bcc @DepError                 ; No address → error
00010Er 2  A0 00          ldy #0                        ; Byte offset from MON_ADDR
000110r 2               @DepLoop:
000110r 2  5A             phy                           ; Save byte offset (Y clobbered by parse routines)
000111r 2  20 rr rr       jsr MonSkipSpaces
000114r 2  20 rr rr       jsr MonParseHex2              ; Parse next byte into A
000117r 2  7A             ply                           ; Restore byte offset (PLY doesn't affect carry)
000118r 2  90 05          bcc @DepDone                  ; No more bytes → done
00011Ar 2  91 2E          sta (MON_ADDR),y
00011Cr 2  C8             iny
00011Dr 2  D0 F1          bne @DepLoop                  ; Up to 256 bytes (Y wraps)
00011Fr 2               @DepDone:
00011Fr 2  C0 00          cpy #0                        ; Did we deposit at least one byte?
000121r 2  F0 01          beq @DepError                 ; No bytes given → error
000123r 2  60             rts
000124r 2               @DepError:
000124r 2  4C rr rr       jmp MonPrintError
000127r 2               
000127r 2               ; ============================================================================
000127r 2               ; MonCmdFill — Fill memory range with a byte value
000127r 2               ; Syntax: F ADDR1 ADDR2 XX
000127r 2               ; ============================================================================
000127r 2               
000127r 2               MonCmdFill:
000127r 2  20 rr rr       jsr MonSkipSpaces
00012Ar 2  20 rr rr       jsr MonParseHex4              ; Parse start address → MON_ADDR
00012Dr 2  90 43          bcc @FillError
00012Fr 2  A5 2E          lda MON_ADDR
000131r 2  85 32          sta MON_TMP
000133r 2  A5 2F          lda MON_ADDR+1
000135r 2  85 33          sta MON_TMP+1                 ; Save start in MON_TMP
000137r 2  20 rr rr       jsr MonSkipSpaces
00013Ar 2  20 rr rr       jsr MonParseHex4              ; Parse end address → MON_ADDR
00013Dr 2  90 33          bcc @FillError
00013Fr 2  A5 2E          lda MON_ADDR
000141r 2  85 30          sta MON_END
000143r 2  A5 2F          lda MON_ADDR+1
000145r 2  85 31          sta MON_END+1                 ; Save end in MON_END
000147r 2                 ; Restore start into MON_ADDR
000147r 2  A5 32          lda MON_TMP
000149r 2  85 2E          sta MON_ADDR
00014Br 2  A5 33          lda MON_TMP+1
00014Dr 2  85 2F          sta MON_ADDR+1
00014Fr 2  20 rr rr       jsr MonSkipSpaces
000152r 2  20 rr rr       jsr MonParseHex2              ; Parse fill byte → A
000155r 2  90 1B          bcc @FillError
000157r 2                 ; A = fill byte, MON_ADDR = start, MON_END = end (inclusive)
000157r 2  A0 00          ldy #0
000159r 2               @FillLoop:
000159r 2  91 2E          sta (MON_ADDR),y
00015Br 2                 ; Check if MON_ADDR == MON_END
00015Br 2  A6 2F          ldx MON_ADDR+1
00015Dr 2  E4 31          cpx MON_END+1
00015Fr 2  D0 06          bne @FillNext
000161r 2  A6 2E          ldx MON_ADDR
000163r 2  E4 30          cpx MON_END
000165r 2  F0 0A          beq @FillDone
000167r 2               @FillNext:
000167r 2                 ; Advance MON_ADDR
000167r 2  48             pha                           ; Save fill byte
000168r 2  E6 2E          inc MON_ADDR
00016Ar 2  D0 02          bne @FillNoHi
00016Cr 2  E6 2F          inc MON_ADDR+1
00016Er 2               @FillNoHi:
00016Er 2  68             pla                           ; Restore fill byte
00016Fr 2  80 E8          bra @FillLoop
000171r 2               @FillDone:
000171r 2  60             rts
000172r 2               @FillError:
000172r 2  4C rr rr       jmp MonPrintError
000175r 2               
000175r 2               ; ============================================================================
000175r 2               ; MonCmdTransfer — Copy memory block (handles overlapping regions)
000175r 2               ; Syntax: T SRC_START SRC_END DEST
000175r 2               ; ============================================================================
000175r 2               
000175r 2               MonCmdTransfer:
000175r 2  20 rr rr       jsr MonSkipSpaces
000178r 2  20 rr rr       jsr MonParseHex4              ; Parse source start → MON_ADDR
00017Br 2  B0 03          bcs @XferGotStart
00017Dr 2  4C rr rr       jmp @XferError                ; No address → error
000180r 2               @XferGotStart:
000180r 2  A5 2E          lda MON_ADDR
000182r 2  85 32          sta MON_TMP
000184r 2  A5 2F          lda MON_ADDR+1
000186r 2  85 33          sta MON_TMP+1                 ; MON_TMP = source start
000188r 2  20 rr rr       jsr MonSkipSpaces
00018Br 2  20 rr rr       jsr MonParseHex4              ; Parse source end → MON_ADDR
00018Er 2  B0 03          bcs @XferGotEnd
000190r 2  4C rr rr       jmp @XferError
000193r 2               @XferGotEnd:
000193r 2  A5 2E          lda MON_ADDR
000195r 2  85 30          sta MON_END
000197r 2  A5 2F          lda MON_ADDR+1
000199r 2  85 31          sta MON_END+1                 ; MON_END = source end (inclusive)
00019Br 2  20 rr rr       jsr MonSkipSpaces
00019Er 2  20 rr rr       jsr MonParseHex4              ; Parse dest → MON_ADDR
0001A1r 2  B0 03          bcs @XferGotDest
0001A3r 2  4C rr rr       jmp @XferError
0001A6r 2               @XferGotDest:
0001A6r 2                 ; MON_ADDR = dest, MON_TMP = src start, MON_END = src end
0001A6r 2                 ; Determine copy direction: if dest > src_start, copy backward to handle overlap
0001A6r 2  A5 2F          lda MON_ADDR+1
0001A8r 2  C5 33          cmp MON_TMP+1
0001AAr 2  90 5C          bcc @CopyForward              ; dest < src → forward is safe
0001ACr 2  D0 08          bne @CopyBackward             ; dest > src → need backward
0001AEr 2  A5 2E          lda MON_ADDR
0001B0r 2  C5 32          cmp MON_TMP
0001B2r 2  90 54          bcc @CopyForward
0001B4r 2  F0 72          beq @XferDone                 ; dest == src → nothing to do
0001B6r 2               @CopyBackward:
0001B6r 2                 ; Compute offset = src_end - src_start
0001B6r 2  38             sec
0001B7r 2  A5 30          lda MON_END
0001B9r 2  E5 32          sbc MON_TMP
0001BBr 2  85 34          sta MON_BYTE                  ; low byte of offset
0001BDr 2  A5 31          lda MON_END+1
0001BFr 2  E5 33          sbc MON_TMP+1
0001C1r 2  85 35          sta MON_IDX                   ; high byte of offset (reuse MON_IDX as scratch)
0001C3r 2                 ; Point MON_TMP to src_end, MON_ADDR to dest + offset
0001C3r 2                 ; MON_TMP already needs to be src_end (currently src_start)
0001C3r 2                 ; Swap: MON_TMP = MON_END (src_end)
0001C3r 2  A5 30          lda MON_END
0001C5r 2  48             pha
0001C6r 2  A5 31          lda MON_END+1
0001C8r 2  48             pha
0001C9r 2                 ; MON_END = src_start (save for later comparison)
0001C9r 2  A5 32          lda MON_TMP
0001CBr 2  85 30          sta MON_END
0001CDr 2  A5 33          lda MON_TMP+1
0001CFr 2  85 31          sta MON_END+1
0001D1r 2                 ; MON_TMP = src_end
0001D1r 2  68             pla
0001D2r 2  85 33          sta MON_TMP+1
0001D4r 2  68             pla
0001D5r 2  85 32          sta MON_TMP
0001D7r 2                 ; dest_end = MON_ADDR + offset
0001D7r 2  18             clc
0001D8r 2  A5 2E          lda MON_ADDR
0001DAr 2  65 34          adc MON_BYTE
0001DCr 2  85 2E          sta MON_ADDR
0001DEr 2  A5 2F          lda MON_ADDR+1
0001E0r 2  65 35          adc MON_IDX
0001E2r 2  85 2F          sta MON_ADDR+1
0001E4r 2               @BackLoop:
0001E4r 2  A0 00          ldy #0
0001E6r 2  B1 32          lda (MON_TMP),y
0001E8r 2  91 2E          sta (MON_ADDR),y
0001EAr 2                 ; Check if MON_TMP == MON_END (src start, our stop address)
0001EAr 2  A5 33          lda MON_TMP+1
0001ECr 2  C5 31          cmp MON_END+1
0001EEr 2  D0 06          bne @BackDec
0001F0r 2  A5 32          lda MON_TMP
0001F2r 2  C5 30          cmp MON_END
0001F4r 2  F0 32          beq @XferDone
0001F6r 2               @BackDec:
0001F6r 2                 ; Decrement both pointers
0001F6r 2  A5 32          lda MON_TMP
0001F8r 2  D0 02          bne @BackDecTmpLo
0001FAr 2  C6 33          dec MON_TMP+1
0001FCr 2               @BackDecTmpLo:
0001FCr 2  C6 32          dec MON_TMP
0001FEr 2  A5 2E          lda MON_ADDR
000200r 2  D0 02          bne @BackDecDstLo
000202r 2  C6 2F          dec MON_ADDR+1
000204r 2               @BackDecDstLo:
000204r 2  C6 2E          dec MON_ADDR
000206r 2  80 DC          bra @BackLoop
000208r 2               
000208r 2               @CopyForward:
000208r 2                 ; Copy from MON_TMP (src) to MON_ADDR (dest), up to MON_END (src end)
000208r 2  A0 00          ldy #0
00020Ar 2               @FwdLoop:
00020Ar 2  B1 32          lda (MON_TMP),y
00020Cr 2  91 2E          sta (MON_ADDR),y
00020Er 2                 ; Check if MON_TMP == MON_END
00020Er 2  A5 33          lda MON_TMP+1
000210r 2  C5 31          cmp MON_END+1
000212r 2  D0 06          bne @FwdNext
000214r 2  A5 32          lda MON_TMP
000216r 2  C5 30          cmp MON_END
000218r 2  F0 0E          beq @XferDone
00021Ar 2               @FwdNext:
00021Ar 2                 ; Advance both pointers
00021Ar 2  E6 32          inc MON_TMP
00021Cr 2  D0 02          bne @FwdNoDstCarry
00021Er 2  E6 33          inc MON_TMP+1
000220r 2               @FwdNoDstCarry:
000220r 2  E6 2E          inc MON_ADDR
000222r 2  D0 E6          bne @FwdLoop
000224r 2  E6 2F          inc MON_ADDR+1
000226r 2  80 E2          bra @FwdLoop
000228r 2               
000228r 2               @XferDone:
000228r 2  60             rts
000229r 2               @XferError:
000229r 2  4C rr rr       jmp MonPrintError
00022Cr 2               
00022Cr 2               ; ============================================================================
00022Cr 2               ; MonCmdHunt — Search for byte pattern in memory range
00022Cr 2               ; Syntax: H ADDR1 ADDR2 XX [XX XX ...]
00022Cr 2               ; Prints address of each match on its own line.
00022Cr 2               ; ============================================================================
00022Cr 2               
00022Cr 2               ; Hunt uses a temp buffer at end of MON_LINBUF area for the pattern.
00022Cr 2               ; Pattern bytes stored at MON_LINBUF+128, max 64 pattern bytes.
00022Cr 2               MON_HUNT_PAT        = MON_LINBUF + 128
00022Cr 2               MON_HUNT_PAT_MAX    = 64
00022Cr 2               
00022Cr 2               MonCmdHunt:
00022Cr 2  20 rr rr       jsr MonSkipSpaces
00022Fr 2  20 rr rr       jsr MonParseHex4              ; Parse start address → MON_ADDR
000232r 2  90 65          bcc @HuntError
000234r 2  A5 2E          lda MON_ADDR
000236r 2  85 32          sta MON_TMP
000238r 2  A5 2F          lda MON_ADDR+1
00023Ar 2  85 33          sta MON_TMP+1                 ; MON_TMP = search start
00023Cr 2  20 rr rr       jsr MonSkipSpaces
00023Fr 2  20 rr rr       jsr MonParseHex4              ; Parse end address → MON_ADDR
000242r 2  90 55          bcc @HuntError
000244r 2  A5 2E          lda MON_ADDR
000246r 2  85 30          sta MON_END
000248r 2  A5 2F          lda MON_ADDR+1
00024Ar 2  85 31          sta MON_END+1                 ; MON_END = search end
00024Cr 2                 ; Restore start
00024Cr 2  A5 32          lda MON_TMP
00024Er 2  85 2E          sta MON_ADDR
000250r 2  A5 33          lda MON_TMP+1
000252r 2  85 2F          sta MON_ADDR+1
000254r 2                 ; Parse pattern bytes into MON_HUNT_PAT
000254r 2  A2 00          ldx #0                        ; Pattern length counter
000256r 2               @HuntParseByte:
000256r 2  DA             phx                           ; Save pattern counter (X clobbered by MonParseHex2)
000257r 2  20 rr rr       jsr MonSkipSpaces
00025Ar 2  20 rr rr       jsr MonParseHex2              ; Next byte → A
00025Dr 2  FA             plx                           ; Restore pattern counter (PLX doesn't affect carry)
00025Er 2  90 0A          bcc @HuntParseEnd
000260r 2  E0 40          cpx #MON_HUNT_PAT_MAX
000262r 2  B0 06          bcs @HuntParseEnd             ; Pattern buffer full
000264r 2  9D B4 04       sta MON_HUNT_PAT,x
000267r 2  E8             inx
000268r 2  80 EC          bra @HuntParseByte
00026Ar 2               @HuntParseEnd:
00026Ar 2  E0 00          cpx #0
00026Cr 2  F0 2B          beq @HuntError                ; No pattern bytes → error
00026Er 2  86 34          stx MON_BYTE                  ; MON_BYTE = pattern length
000270r 2                 ; Search: scan MON_ADDR to MON_END for pattern match
000270r 2               @HuntScanLoop:
000270r 2  A0 00          ldy #0                        ; Pattern match index
000272r 2               @HuntMatchLoop:
000272r 2  B1 2E          lda (MON_ADDR),y
000274r 2  D9 B4 04       cmp MON_HUNT_PAT,y
000277r 2  D0 0B          bne @HuntNoMatch
000279r 2  C8             iny
00027Ar 2  C4 34          cpy MON_BYTE                  ; Matched all pattern bytes?
00027Cr 2  90 F4          bcc @HuntMatchLoop
00027Er 2                 ; Full match — print address
00027Er 2  20 rr rr       jsr MonPrintHex4
000281r 2  20 rr rr       jsr MonPrintCRLF
000284r 2               @HuntNoMatch:
000284r 2                 ; Check if MON_ADDR == MON_END
000284r 2  A5 2F          lda MON_ADDR+1
000286r 2  C5 31          cmp MON_END+1
000288r 2  D0 06          bne @HuntAdvance
00028Ar 2  A5 2E          lda MON_ADDR
00028Cr 2  C5 30          cmp MON_END
00028Er 2  F0 08          beq @HuntDone
000290r 2               @HuntAdvance:
000290r 2  E6 2E          inc MON_ADDR
000292r 2  D0 DC          bne @HuntScanLoop
000294r 2  E6 2F          inc MON_ADDR+1
000296r 2  80 D8          bra @HuntScanLoop
000298r 2               @HuntDone:
000298r 2  60             rts
000299r 2               @HuntError:
000299r 2  4C rr rr       jmp MonPrintError
00029Cr 2               
00029Cr 2               ; ============================================================================
00029Cr 2               ; MonCmdCompare — Compare two memory regions
00029Cr 2               ; Syntax: C ADDR1 ADDR2 ADDR3
00029Cr 2               ; Compares [addr1,addr2] with block at addr3, prints differing addresses.
00029Cr 2               ; ============================================================================
00029Cr 2               
00029Cr 2               MonCmdCompare:
00029Cr 2  20 rr rr       jsr MonSkipSpaces
00029Fr 2  20 rr rr       jsr MonParseHex4              ; Parse addr1 (region1 start) → MON_ADDR
0002A2r 2  90 57          bcc @CmpError
0002A4r 2                 ; Save addr1 on stack
0002A4r 2  A5 2F          lda MON_ADDR+1
0002A6r 2  48             pha
0002A7r 2  A5 2E          lda MON_ADDR
0002A9r 2  48             pha
0002AAr 2  20 rr rr       jsr MonSkipSpaces
0002ADr 2  20 rr rr       jsr MonParseHex4              ; Parse addr2 (region1 end) → MON_ADDR
0002B0r 2  90 47          bcc @CmpErrorPop
0002B2r 2  A5 2E          lda MON_ADDR
0002B4r 2  85 30          sta MON_END
0002B6r 2  A5 2F          lda MON_ADDR+1
0002B8r 2  85 31          sta MON_END+1                 ; MON_END = region1 end (inclusive)
0002BAr 2  20 rr rr       jsr MonSkipSpaces
0002BDr 2  20 rr rr       jsr MonParseHex4              ; Parse addr3 (region2 base) → MON_ADDR
0002C0r 2  90 37          bcc @CmpErrorPop
0002C2r 2  A5 2E          lda MON_ADDR
0002C4r 2  85 32          sta MON_TMP
0002C6r 2  A5 2F          lda MON_ADDR+1
0002C8r 2  85 33          sta MON_TMP+1                 ; MON_TMP = region2 pointer
0002CAr 2                 ; Restore addr1 → MON_ADDR
0002CAr 2  68             pla
0002CBr 2  85 2E          sta MON_ADDR
0002CDr 2  68             pla
0002CEr 2  85 2F          sta MON_ADDR+1
0002D0r 2                 ; Compare loop: [MON_ADDR..MON_END] vs [MON_TMP..]
0002D0r 2  A0 00          ldy #0
0002D2r 2               @CmpLoop:
0002D2r 2  B1 2E          lda (MON_ADDR),y
0002D4r 2  D1 32          cmp (MON_TMP),y
0002D6r 2  F0 06          beq @CmpMatch
0002D8r 2                 ; Mismatch — print addr1 address
0002D8r 2  20 rr rr       jsr MonPrintHex4
0002DBr 2  20 rr rr       jsr MonPrintCRLF
0002DEr 2               @CmpMatch:
0002DEr 2                 ; Check if MON_ADDR == MON_END
0002DEr 2  A5 2F          lda MON_ADDR+1
0002E0r 2  C5 31          cmp MON_END+1
0002E2r 2  D0 06          bne @CmpNext
0002E4r 2  A5 2E          lda MON_ADDR
0002E6r 2  C5 30          cmp MON_END
0002E8r 2  F0 0E          beq @CmpDone
0002EAr 2               @CmpNext:
0002EAr 2                 ; Advance both pointers
0002EAr 2  E6 2E          inc MON_ADDR
0002ECr 2  D0 02          bne @CmpNoHi1
0002EEr 2  E6 2F          inc MON_ADDR+1
0002F0r 2               @CmpNoHi1:
0002F0r 2  E6 32          inc MON_TMP
0002F2r 2  D0 DE          bne @CmpLoop
0002F4r 2  E6 33          inc MON_TMP+1
0002F6r 2  80 DA          bra @CmpLoop
0002F8r 2               @CmpDone:
0002F8r 2  60             rts
0002F9r 2               @CmpErrorPop:
0002F9r 2  68             pla                           ; Clean up stack
0002FAr 2  68             pla
0002FBr 2               @CmpError:
0002FBr 2  4C rr rr       jmp MonPrintError
0002FEr 2               
0002FEr 2               ; ============================================================================
0002FEr 2               ; MonCmdGo — Go (JMP to address with full register restore via RTI)
0002FEr 2               ; Syntax: G [addr]
0002FEr 2               ; If addr given, sets BRK_PCL/PCH. Restores A, X, Y, P, SP via RTI.
0002FEr 2               ; Program runs until BRK returns to monitor or forever.
0002FEr 2               ; ============================================================================
0002FEr 2               
0002FEr 2               MonCmdGo:
0002FEr 2  20 rr rr       jsr MonSkipSpaces
000301r 2  20 rr rr       jsr MonParseHex4
000304r 2  90 0A          bcc @GoNoAddr
000306r 2                 ; Address given — store to BRK_PCL/PCH
000306r 2  A5 2E          lda MON_ADDR
000308r 2  8D 11 03       sta BRK_PCL
00030Br 2  A5 2F          lda MON_ADDR+1
00030Dr 2  8D 12 03       sta BRK_PCH
000310r 2               @GoNoAddr:
000310r 2  78             sei                           ; Disable interrupts during stack manipulation
000311r 2                 ; Restore user's stack pointer
000311r 2                 ; BRK_SP = SP at Break entry (user's original SP - 3 from BRK hardware push)
000311r 2                 ; We need SP = BRK_SP + 3 before our pushes, so RTI leaves SP at original
000311r 2  AE 16 03       ldx BRK_SP
000314r 2  E8             inx
000315r 2  E8             inx
000316r 2  E8             inx
000317r 2  9A             txs                           ; SP = user's original SP
000318r 2                 ; Push PCH, PCL, P for RTI (RTI pops P first, then PCL, PCH)
000318r 2  AD 12 03       lda BRK_PCH
00031Br 2  48             pha
00031Cr 2  AD 11 03       lda BRK_PCL
00031Fr 2  48             pha
000320r 2  AD 10 03       lda BRK_P
000323r 2  48             pha
000324r 2                 ; Restore registers
000324r 2  AC 15 03       ldy BRK_Y
000327r 2  AE 14 03       ldx BRK_X
00032Ar 2  AD 13 03       lda BRK_A
00032Dr 2  40             rti                           ; Pop P, PC → jump to target with full register state
00032Er 2               
00032Er 2               ; ============================================================================
00032Er 2               ; MonCmdJsr — Call subroutine and return to monitor on RTS
00032Er 2               ; Syntax: J [addr]
00032Er 2               ; Pushes monitor return address, restores A/X/Y, JMPs to target.
00032Er 2               ; When target does RTS, saves registers and re-enters monitor.
00032Er 2               ; ============================================================================
00032Er 2               
00032Er 2               MonCmdJsr:
00032Er 2  20 rr rr       jsr MonSkipSpaces
000331r 2  20 rr rr       jsr MonParseHex4
000334r 2  90 0A          bcc @JsrNoAddr
000336r 2                 ; Address given — store to BRK_PCL/PCH
000336r 2  A5 2E          lda MON_ADDR
000338r 2  8D 11 03       sta BRK_PCL
00033Br 2  A5 2F          lda MON_ADDR+1
00033Dr 2  8D 12 03       sta BRK_PCH
000340r 2               @JsrNoAddr:
000340r 2                 ; Push return address (MonJsrReturn - 1) for RTS trick
000340r 2  A9 rr          lda #>(MonJsrReturn - 1)
000342r 2  48             pha
000343r 2  A9 rr          lda #<(MonJsrReturn - 1)
000345r 2  48             pha
000346r 2                 ; Restore registers as inputs to subroutine
000346r 2  AC 15 03       ldy BRK_Y
000349r 2  AE 14 03       ldx BRK_X
00034Cr 2  AD 13 03       lda BRK_A
00034Fr 2  6C 11 03       jmp (BRK_PCL)                 ; Jump to target — its RTS returns to MonJsrReturn
000352r 2               
000352r 2               ; MonJsrReturn — Landing point when user's subroutine does RTS
000352r 2               MonJsrReturn:
000352r 2  8D 13 03       sta BRK_A                     ; Save returned A
000355r 2  8E 14 03       stx BRK_X                    ; Save returned X
000358r 2  8C 15 03       sty BRK_Y                    ; Save returned Y
00035Br 2  08             php                           ; Push current P
00035Cr 2  68             pla
00035Dr 2  8D 10 03       sta BRK_P                    ; Save processor status
000360r 2  BA             tsx
000361r 2  8E 16 03       stx BRK_SP                   ; Save current stack pointer
000364r 2                 ; Show registers and re-enter command loop
000364r 2  20 rr rr       jsr MonShowRegs
000367r 2  4C rr rr       jmp MonCmdLoop
00036Ar 2               
00036Ar 2               ; ============================================================================
00036Ar 2               ; MonCmdModRegs — Modify saved CPU registers
00036Ar 2               ; Syntax: ; PC xxxx A xx X xx Y xx SP xx P xx
00036Ar 2               ; Any subset, any order. Labels: PC, A, X, Y, SP, P
00036Ar 2               ; ============================================================================
00036Ar 2               
00036Ar 2               MonCmdModRegs:
00036Ar 2               @ModLoop:
00036Ar 2  20 rr rr       jsr MonSkipSpaces
00036Dr 2  A4 35          ldy MON_IDX
00036Fr 2  B9 34 04       lda MON_LINBUF,y
000372r 2  D0 03          bne @ModNotEnd
000374r 2  4C rr rr       jmp @ModDone                  ; End of line — trampoline (too far for beq)
000377r 2               @ModNotEnd:
000377r 2                 ; Convert to uppercase
000377r 2  C9 61          cmp #'a'
000379r 2  90 06          bcc @ModNoConv
00037Br 2  C9 7B          cmp #'z'+1
00037Dr 2  B0 02          bcs @ModNoConv
00037Fr 2  29 DF          and #$DF
000381r 2               @ModNoConv:
000381r 2  C9 50          cmp #'P'
000383r 2  F0 13          beq @ModCheckPCorP
000385r 2  C9 41          cmp #'A'
000387r 2  F0 4F          beq @ModA
000389r 2  C9 58          cmp #'X'
00038Br 2  F0 5E          beq @ModX
00038Dr 2  C9 59          cmp #'Y'
00038Fr 2  F0 6D          beq @ModY
000391r 2  C9 53          cmp #'S'
000393r 2  F0 7C          beq @ModCheckSP
000395r 2  4C rr rr       jmp @ModError                 ; Unknown label — trampoline (too far for bra)
000398r 2               
000398r 2               @ModCheckPCorP:
000398r 2                 ; Could be "PC" (program counter) or "P" (processor status)
000398r 2  E6 35          inc MON_IDX
00039Ar 2  A4 35          ldy MON_IDX
00039Cr 2  B9 34 04       lda MON_LINBUF,y
00039Fr 2                 ; Convert to uppercase
00039Fr 2  C9 61          cmp #'a'
0003A1r 2  90 06          bcc @ModPCNoConv
0003A3r 2  C9 7B          cmp #'z'+1
0003A5r 2  B0 02          bcs @ModPCNoConv
0003A7r 2  29 DF          and #$DF
0003A9r 2               @ModPCNoConv:
0003A9r 2  C9 43          cmp #'C'
0003ABr 2  F0 11          beq @ModPC
0003ADr 2                 ; It's just 'P' (processor status) — don't advance past the non-'C' char
0003ADr 2  20 rr rr       jsr MonSkipSpaces
0003B0r 2  20 rr rr       jsr MonParseHex2
0003B3r 2  B0 03          bcs @ModPOk
0003B5r 2  4C rr rr       jmp @ModError
0003B8r 2               @ModPOk:
0003B8r 2  8D 10 03       sta BRK_P
0003BBr 2  4C rr rr       jmp @ModLoop
0003BEr 2               
0003BEr 2               @ModPC:
0003BEr 2  E6 35          inc MON_IDX                   ; Advance past 'C'
0003C0r 2  20 rr rr       jsr MonSkipSpaces
0003C3r 2  20 rr rr       jsr MonParseHex4
0003C6r 2  B0 03          bcs @ModPCOk
0003C8r 2  4C rr rr       jmp @ModError
0003CBr 2               @ModPCOk:
0003CBr 2  A5 2E          lda MON_ADDR
0003CDr 2  8D 11 03       sta BRK_PCL
0003D0r 2  A5 2F          lda MON_ADDR+1
0003D2r 2  8D 12 03       sta BRK_PCH
0003D5r 2  4C rr rr       jmp @ModLoop
0003D8r 2               
0003D8r 2               @ModA:
0003D8r 2  E6 35          inc MON_IDX                   ; Advance past 'A'
0003DAr 2  20 rr rr       jsr MonSkipSpaces
0003DDr 2  20 rr rr       jsr MonParseHex2
0003E0r 2  B0 03          bcs @ModAOk
0003E2r 2  4C rr rr       jmp @ModError
0003E5r 2               @ModAOk:
0003E5r 2  8D 13 03       sta BRK_A
0003E8r 2  4C rr rr       jmp @ModLoop
0003EBr 2               
0003EBr 2               @ModX:
0003EBr 2  E6 35          inc MON_IDX                   ; Advance past 'X'
0003EDr 2  20 rr rr       jsr MonSkipSpaces
0003F0r 2  20 rr rr       jsr MonParseHex2
0003F3r 2  B0 03          bcs @ModXOk
0003F5r 2  4C rr rr       jmp @ModError
0003F8r 2               @ModXOk:
0003F8r 2  8D 14 03       sta BRK_X
0003FBr 2  4C rr rr       jmp @ModLoop
0003FEr 2               
0003FEr 2               @ModY:
0003FEr 2  E6 35          inc MON_IDX                   ; Advance past 'Y'
000400r 2  20 rr rr       jsr MonSkipSpaces
000403r 2  20 rr rr       jsr MonParseHex2
000406r 2  B0 03          bcs @ModYOk
000408r 2  4C rr rr       jmp @ModError
00040Br 2               @ModYOk:
00040Br 2  8D 15 03       sta BRK_Y
00040Er 2  4C rr rr       jmp @ModLoop
000411r 2               
000411r 2               @ModCheckSP:
000411r 2                 ; Expect "SP" — must see 'P' next
000411r 2  E6 35          inc MON_IDX
000413r 2  A4 35          ldy MON_IDX
000415r 2  B9 34 04       lda MON_LINBUF,y
000418r 2  C9 50          cmp #'P'
00041Ar 2  F0 07          beq @ModSPGotP
00041Cr 2  C9 70          cmp #'p'
00041Er 2  F0 03          beq @ModSPGotP
000420r 2  4C rr rr       jmp @ModError                 ; Just 'S' alone is invalid
000423r 2               @ModSPGotP:
000423r 2  E6 35          inc MON_IDX                   ; Advance past 'P'
000425r 2  20 rr rr       jsr MonSkipSpaces
000428r 2  20 rr rr       jsr MonParseHex2
00042Br 2  B0 03          bcs @ModSPOk
00042Dr 2  4C rr rr       jmp @ModError
000430r 2               @ModSPOk:
000430r 2  8D 16 03       sta BRK_SP
000433r 2  4C rr rr       jmp @ModLoop
000436r 2               
000436r 2               @ModError:
000436r 2  4C rr rr       jmp MonPrintError
000439r 2               @ModDone:
000439r 2                 ; Display updated registers
000439r 2  20 rr rr       jsr MonShowRegs
00043Cr 2  60             rts
00043Dr 2               
00043Dr 2               ; ============================================================================
00043Dr 2               ; MonCmdDir — Display CF directory listing
00043Dr 2               ; Syntax: @
00043Dr 2               ; ============================================================================
00043Dr 2               
00043Dr 2               MonCmdDir:
00043Dr 2  20 rr rr       jsr FsDirectory
000440r 2  60             rts
000441r 2               
000441r 2               ; ============================================================================
000441r 2               ; MonCmdNum — Number base conversion
000441r 2               ; Syntax: N $XXXX  or  N +DDDDD  or  N %BBBBBBBBBBBBBBBB
000441r 2               ; Output: $XXXX  +DDDDD  %BBBBBBBBBBBBBBBB
000441r 2               ; ============================================================================
000441r 2               
000441r 2               MonCmdNum:
000441r 2  20 rr rr       jsr MonSkipSpaces
000444r 2  A4 35          ldy MON_IDX
000446r 2  B9 34 04       lda MON_LINBUF,y
000449r 2  C9 24          cmp #'$'
00044Br 2  F0 0A          beq @NumHex
00044Dr 2  C9 2B          cmp #'+'
00044Fr 2  F0 10          beq @NumDec
000451r 2  C9 25          cmp #'%'
000453r 2  F0 16          beq @NumBin
000455r 2                 ; Default: try hex (no prefix)
000455r 2  80 02          bra @NumHexDirect
000457r 2               @NumHex:
000457r 2  E6 35          inc MON_IDX                   ; Skip '$'
000459r 2               @NumHexDirect:
000459r 2  20 rr rr       jsr MonParseHex4
00045Cr 2  B0 17          bcs @NumPrint
00045Er 2  4C rr rr       jmp MonPrintError
000461r 2               @NumDec:
000461r 2  E6 35          inc MON_IDX                   ; Skip '+'
000463r 2  20 rr rr       jsr MonParseDec16
000466r 2  B0 0D          bcs @NumPrint
000468r 2  4C rr rr       jmp MonPrintError
00046Br 2               @NumBin:
00046Br 2  E6 35          inc MON_IDX                   ; Skip '%'
00046Dr 2  20 rr rr       jsr MonParseBin16
000470r 2  B0 03          bcs @NumPrint
000472r 2  4C rr rr       jmp MonPrintError
000475r 2               @NumPrint:
000475r 2                 ; Value is in MON_ADDR
000475r 2  A9 24          lda #'$'
000477r 2  20 rr rr       jsr Chrout
00047Ar 2  20 rr rr       jsr MonPrintHex4
00047Dr 2  20 rr rr       jsr MonPrintSpace
000480r 2  20 rr rr       jsr MonPrintSpace
000483r 2  A9 2B          lda #'+'
000485r 2  20 rr rr       jsr Chrout
000488r 2  20 rr rr       jsr MonPrintDec16
00048Br 2  20 rr rr       jsr MonPrintSpace
00048Er 2  20 rr rr       jsr MonPrintSpace
000491r 2  A9 25          lda #'%'
000493r 2  20 rr rr       jsr Chrout
000496r 2  20 rr rr       jsr MonPrintBin16
000499r 2  20 rr rr       jsr MonPrintCRLF
00049Cr 2  60             rts
00049Dr 2               
00049Dr 2               ; ============================================================================
00049Dr 2               ; MonCmdLoad — Load from CF (with quoted filename) or XModem (without)
00049Dr 2               ; Syntax: L ["FILE"] [ADDR]
00049Dr 2               ; CF path:     L "FILENAME" [ADDR] — load file to addr (default $0800)
00049Dr 2               ; Serial path: L [ADDR]            — receive via XModem to addr (default $0800)
00049Dr 2               ; ============================================================================
00049Dr 2               
00049Dr 2               MonCmdLoad:
00049Dr 2  20 rr rr       jsr MonSkipSpaces
0004A0r 2  A4 35          ldy MON_IDX
0004A2r 2  B9 34 04       lda MON_LINBUF,y
0004A5r 2  C9 22          cmp #'"'
0004A7r 2  D0 03          bne @LoadSerial
0004A9r 2  4C rr rr       jmp @LoadCF
0004ACr 2               
0004ACr 2                 ; --- Serial path (XModem) ---
0004ACr 2               @LoadSerial:
0004ACr 2  20 rr rr       jsr MonParseHex4              ; Optional address
0004AFr 2  90 0A          bcc @LoadSerDefault
0004B1r 2                 ; Got address
0004B1r 2  A5 2E          lda MON_ADDR
0004B3r 2  85 2A          sta XFER_PTR
0004B5r 2  A5 2F          lda MON_ADDR+1
0004B7r 2  85 2B          sta XFER_PTR+1
0004B9r 2  80 08          bra @LoadSerStart
0004BBr 2               @LoadSerDefault:
0004BBr 2  A9 00          lda #<PROGRAM_START
0004BDr 2  85 2A          sta XFER_PTR
0004BFr 2  A9 08          lda #>PROGRAM_START
0004C1r 2  85 2B          sta XFER_PTR+1
0004C3r 2               @LoadSerStart:
0004C3r 2                 ; Save load address for success message
0004C3r 2  A5 2A          lda XFER_PTR
0004C5r 2  85 30          sta MON_END
0004C7r 2  A5 2B          lda XFER_PTR+1
0004C9r 2  85 31          sta MON_END+1
0004CBr 2                 ; Receive via XModem
0004CBr 2  20 rr rr       jsr XModemLoad
0004CEr 2  B0 0E          bcs @LoadSerErr
0004D0r 2                 ; XFER_REMAIN = total bytes received
0004D0r 2  AD 17 03       lda XFER_REMAIN
0004D3r 2  85 2E          sta MON_ADDR
0004D5r 2  AD 18 03       lda XFER_REMAIN+1
0004D8r 2  85 2F          sta MON_ADDR+1
0004DAr 2  20 rr rr       jsr MonPrintLoaded            ; Print "LOADED nnnn BYTES AT $xxxx"
0004DDr 2  60             rts
0004DEr 2               @LoadSerErr:
0004DEr 2  20 rr rr       jsr MonPrintIOErr
0004E1r 2  60             rts
0004E2r 2               
0004E2r 2                 ; --- CF path ---
0004E2r 2               @LoadCF:
0004E2r 2  E6 35          inc MON_IDX                   ; Skip opening quote
0004E4r 2                 ; Point STR_PTR into line buffer at the filename
0004E4r 2  A4 35          ldy MON_IDX
0004E6r 2  98             tya
0004E7r 2  18             clc
0004E8r 2  69 34          adc #<MON_LINBUF
0004EAr 2  85 02          sta STR_PTR
0004ECr 2  A9 04          lda #>MON_LINBUF
0004EEr 2  69 00          adc #0
0004F0r 2  85 03          sta STR_PTR+1
0004F2r 2                 ; Find closing quote and null-terminate
0004F2r 2               @LoadCFFindQ:
0004F2r 2  B9 34 04       lda MON_LINBUF,y
0004F5r 2  F0 0D          beq @LoadCFQDone              ; End of line — use as-is
0004F7r 2  C9 22          cmp #'"'
0004F9r 2  F0 03          beq @LoadCFGotQ
0004FBr 2  C8             iny
0004FCr 2  80 F4          bra @LoadCFFindQ
0004FEr 2               @LoadCFGotQ:
0004FEr 2  A9 00          lda #0
000500r 2  99 34 04       sta MON_LINBUF,y              ; Null-terminate at closing quote
000503r 2  C8             iny                           ; Advance past closing quote
000504r 2               @LoadCFQDone:
000504r 2  84 35          sty MON_IDX
000506r 2                 ; Parse filename into FS_FNAME_BUF
000506r 2  20 rr rr       jsr FsParseName
000509r 2                 ; Read directory
000509r 2  20 rr rr       jsr FsReadDir
00050Cr 2  90 03          bcc @LoadCFReadOk
00050Er 2  4C rr rr       jmp @LoadCFErr
000511r 2               @LoadCFReadOk:
000511r 2                 ; Find file
000511r 2  20 rr rr       jsr FsFindFile
000514r 2  90 03          bcc @LoadCFFound
000516r 2  4C rr rr       jmp @LoadCFNotFound
000519r 2               @LoadCFFound:
000519r 2                 ; Read file metadata
000519r 2  A0 0C          ldy #FS_ENTRY_START
00051Br 2  B1 24          lda (CF_BUF_PTR),y
00051Dr 2  8D 48 03       sta FS_START_SEC
000520r 2  C8             iny
000521r 2  B1 24          lda (CF_BUF_PTR),y
000523r 2  8D 49 03       sta FS_START_SEC+1
000526r 2  A0 0E          ldy #FS_ENTRY_FSIZE
000528r 2  B1 24          lda (CF_BUF_PTR),y
00052Ar 2  8D 4A 03       sta FS_FILE_SIZE
00052Dr 2  C8             iny
00052Er 2  B1 24          lda (CF_BUF_PTR),y
000530r 2  8D 4B 03       sta FS_FILE_SIZE+1
000533r 2                 ; Calculate sector count = ceil(size / 512)
000533r 2  AD 4B 03       lda FS_FILE_SIZE+1
000536r 2  4A             lsr a
000537r 2  8D 4C 03       sta FS_SEC_COUNT
00053Ar 2  AD 4B 03       lda FS_FILE_SIZE+1
00053Dr 2  29 01          and #$01
00053Fr 2  D0 05          bne @LoadCFRound
000541r 2  AD 4A 03       lda FS_FILE_SIZE
000544r 2  F0 03          beq @LoadCFNoRound
000546r 2               @LoadCFRound:
000546r 2  EE 4C 03       inc FS_SEC_COUNT
000549r 2               @LoadCFNoRound:
000549r 2                 ; Parse optional load address
000549r 2  20 rr rr       jsr MonSkipSpaces
00054Cr 2  20 rr rr       jsr MonParseHex4
00054Fr 2  90 0A          bcc @LoadCFDefAddr
000551r 2                 ; Got address — use it
000551r 2  A5 2E          lda MON_ADDR
000553r 2  85 24          sta CF_BUF_PTR
000555r 2  A5 2F          lda MON_ADDR+1
000557r 2  85 25          sta CF_BUF_PTR+1
000559r 2  80 08          bra @LoadCFSetLBA
00055Br 2               @LoadCFDefAddr:
00055Br 2  A9 00          lda #<PROGRAM_START
00055Dr 2  85 24          sta CF_BUF_PTR
00055Fr 2  A9 08          lda #>PROGRAM_START
000561r 2  85 25          sta CF_BUF_PTR+1
000563r 2               @LoadCFSetLBA:
000563r 2                 ; Save load base address for message
000563r 2  A5 24          lda CF_BUF_PTR
000565r 2  85 30          sta MON_END
000567r 2  A5 25          lda CF_BUF_PTR+1
000569r 2  85 31          sta MON_END+1
00056Br 2                 ; Set up LBA
00056Br 2  AD 48 03       lda FS_START_SEC
00056Er 2  85 26          sta CF_LBA
000570r 2  AD 49 03       lda FS_START_SEC+1
000573r 2  85 27          sta CF_LBA+1
000575r 2  64 28          stz CF_LBA+2
000577r 2  64 29          stz CF_LBA+3
000579r 2                 ; Read sectors
000579r 2  AE 4C 03       ldx FS_SEC_COUNT
00057Cr 2  F0 10          beq @LoadCFOk
00057Er 2               @LoadCFSec:
00057Er 2  DA             phx
00057Fr 2  20 rr rr       jsr StReadSector              ; Reads 512 bytes, advances CF_BUF_PTR
000582r 2  B0 18          bcs @LoadCFSecErr
000584r 2  E6 26          inc CF_LBA
000586r 2  D0 02          bne @LoadCFSecNext
000588r 2  E6 27          inc CF_LBA+1
00058Ar 2               @LoadCFSecNext:
00058Ar 2  FA             plx
00058Br 2  CA             dex
00058Cr 2  D0 F0          bne @LoadCFSec
00058Er 2               @LoadCFOk:
00058Er 2                 ; Print success
00058Er 2  AD 4A 03       lda FS_FILE_SIZE
000591r 2  85 2E          sta MON_ADDR
000593r 2  AD 4B 03       lda FS_FILE_SIZE+1
000596r 2  85 2F          sta MON_ADDR+1
000598r 2  20 rr rr       jsr MonPrintLoaded            ; Print "LOADED nnnn BYTES AT $xxxx"
00059Br 2  60             rts
00059Cr 2               @LoadCFSecErr:
00059Cr 2  FA             plx                           ; Balance stack
00059Dr 2               @LoadCFErr:
00059Dr 2  20 rr rr       jsr MonPrintIOErr
0005A0r 2  60             rts
0005A1r 2               @LoadCFNotFound:
0005A1r 2  A2 00          ldx #0
0005A3r 2               @LoadCFNFLoop:
0005A3r 2  BD rr rr       lda MonStrNotFound,x
0005A6r 2  F0 06          beq @LoadCFNFDone
0005A8r 2  20 rr rr       jsr Chrout
0005ABr 2  E8             inx
0005ACr 2  80 F5          bra @LoadCFNFLoop
0005AEr 2               @LoadCFNFDone:
0005AEr 2  20 rr rr       jsr MonPrintCRLF
0005B1r 2  60             rts
0005B2r 2               
0005B2r 2               ; ============================================================================
0005B2r 2               ; MonCmdSave — Save to CF (with quoted filename) or XModem (without)
0005B2r 2               ; Syntax: S ["FILE"] ADDR1 ADDR2
0005B2r 2               ; CF path:     S "FILENAME" ADDR1 ADDR2 — save [addr1,addr2) to file
0005B2r 2               ; Serial path: S ADDR1 ADDR2            — send [addr1,addr2) via XModem
0005B2r 2               ; ============================================================================
0005B2r 2               
0005B2r 2               MonCmdSave:
0005B2r 2  20 rr rr       jsr MonSkipSpaces
0005B5r 2  A4 35          ldy MON_IDX
0005B7r 2  B9 34 04       lda MON_LINBUF,y
0005BAr 2  C9 22          cmp #'"'
0005BCr 2  D0 03          bne @SaveSerial
0005BEr 2  4C rr rr       jmp @SaveCF
0005C1r 2               
0005C1r 2                 ; --- Serial path ---
0005C1r 2                 ; --- Serial path (XModem) ---
0005C1r 2               @SaveSerial:
0005C1r 2  20 rr rr       jsr MonParseHex4              ; Parse start address
0005C4r 2  B0 03          bcs @SaveSerGotStart
0005C6r 2  4C rr rr       jmp @SaveError
0005C9r 2               @SaveSerGotStart:
0005C9r 2  A5 2E          lda MON_ADDR
0005CBr 2  85 2A          sta XFER_PTR
0005CDr 2  A5 2F          lda MON_ADDR+1
0005CFr 2  85 2B          sta XFER_PTR+1
0005D1r 2  20 rr rr       jsr MonSkipSpaces
0005D4r 2  20 rr rr       jsr MonParseHex4              ; Parse end address
0005D7r 2  B0 03          bcs @SaveSerGotEnd
0005D9r 2  4C rr rr       jmp @SaveError
0005DCr 2               @SaveSerGotEnd:
0005DCr 2                 ; Calculate size = end - start
0005DCr 2  38             sec
0005DDr 2  A5 2E          lda MON_ADDR
0005DFr 2  E5 2A          sbc XFER_PTR
0005E1r 2  8D 17 03       sta XFER_REMAIN
0005E4r 2  A5 2F          lda MON_ADDR+1
0005E6r 2  E5 2B          sbc XFER_PTR+1
0005E8r 2  8D 18 03       sta XFER_REMAIN+1
0005EBr 2                 ; Save size for message
0005EBr 2  AD 17 03       lda XFER_REMAIN
0005EEr 2  85 30          sta MON_END
0005F0r 2  AD 18 03       lda XFER_REMAIN+1
0005F3r 2  85 31          sta MON_END+1
0005F5r 2                 ; Send via XModem
0005F5r 2  20 rr rr       jsr XModemSave
0005F8r 2  B0 0C          bcs @SaveSerErr
0005FAr 2                 ; Print "SAVED nnnn BYTES"
0005FAr 2  A5 30          lda MON_END
0005FCr 2  85 2E          sta MON_ADDR
0005FEr 2  A5 31          lda MON_END+1
000600r 2  85 2F          sta MON_ADDR+1
000602r 2  20 rr rr       jsr MonPrintSaved
000605r 2  60             rts
000606r 2               @SaveSerErr:
000606r 2  20 rr rr       jsr MonPrintIOErr
000609r 2  60             rts
00060Ar 2               
00060Ar 2                 ; --- CF path ---
00060Ar 2               @SaveCF:
00060Ar 2  E6 35          inc MON_IDX                   ; Skip opening quote
00060Cr 2                 ; Point STR_PTR into line buffer at the filename
00060Cr 2  A4 35          ldy MON_IDX
00060Er 2  98             tya
00060Fr 2  18             clc
000610r 2  69 34          adc #<MON_LINBUF
000612r 2  85 02          sta STR_PTR
000614r 2  A9 04          lda #>MON_LINBUF
000616r 2  69 00          adc #0
000618r 2  85 03          sta STR_PTR+1
00061Ar 2                 ; Find closing quote and null-terminate
00061Ar 2               @SaveCFFindQ:
00061Ar 2  B9 34 04       lda MON_LINBUF,y
00061Dr 2  F0 0D          beq @SaveCFQDone
00061Fr 2  C9 22          cmp #'"'
000621r 2  F0 03          beq @SaveCFGotQ
000623r 2  C8             iny
000624r 2  80 F4          bra @SaveCFFindQ
000626r 2               @SaveCFGotQ:
000626r 2  A9 00          lda #0
000628r 2  99 34 04       sta MON_LINBUF,y              ; Null-terminate at closing quote
00062Br 2  C8             iny
00062Cr 2               @SaveCFQDone:
00062Cr 2  84 35          sty MON_IDX
00062Er 2                 ; Parse filename
00062Er 2  20 rr rr       jsr FsParseName
000631r 2                 ; Parse start address
000631r 2  20 rr rr       jsr MonSkipSpaces
000634r 2  20 rr rr       jsr MonParseHex4
000637r 2  B0 03          bcs @SaveCFGotStart
000639r 2  4C rr rr       jmp @SaveError
00063Cr 2               @SaveCFGotStart:
00063Cr 2  A5 2E          lda MON_ADDR
00063Er 2  85 32          sta MON_TMP                   ; MON_TMP = start address
000640r 2  A5 2F          lda MON_ADDR+1
000642r 2  85 33          sta MON_TMP+1
000644r 2                 ; Parse end address
000644r 2  20 rr rr       jsr MonSkipSpaces
000647r 2  20 rr rr       jsr MonParseHex4
00064Ar 2  B0 03          bcs @SaveCFGotEnd
00064Cr 2  4C rr rr       jmp @SaveError
00064Fr 2               @SaveCFGotEnd:
00064Fr 2                 ; Calculate size = end - start
00064Fr 2  38             sec
000650r 2  A5 2E          lda MON_ADDR
000652r 2  E5 32          sbc MON_TMP
000654r 2  8D 4A 03       sta FS_FILE_SIZE
000657r 2  A5 2F          lda MON_ADDR+1
000659r 2  E5 33          sbc MON_TMP+1
00065Br 2  8D 4B 03       sta FS_FILE_SIZE+1
00065Er 2                 ; Read directory
00065Er 2  20 rr rr       jsr FsReadDir
000661r 2  90 03          bcc @SaveCFReadOk
000663r 2  4C rr rr       jmp @SaveCFIOErr
000666r 2               @SaveCFReadOk:
000666r 2                 ; Try to find existing file with same name
000666r 2  20 rr rr       jsr FsFindFile
000669r 2  90 08          bcc @SaveCFOverwrite
00066Br 2                 ; Not found — find a free slot
00066Br 2  20 rr rr       jsr FsFindFree
00066Er 2  90 11          bcc @SaveCFAlloc
000670r 2  4C rr rr       jmp @SaveCFDirFull
000673r 2               @SaveCFOverwrite:
000673r 2                 ; Clear old entry's flags
000673r 2  A0 0B          ldy #FS_ENTRY_FLAGS
000675r 2  A9 00          lda #$00
000677r 2  91 24          sta (CF_BUF_PTR),y
000679r 2                 ; Find a free slot (could be the one we just freed)
000679r 2  20 rr rr       jsr FsFindFree
00067Cr 2  90 03          bcc @SaveCFAllocOk
00067Er 2  4C rr rr       jmp @SaveCFDirFull
000681r 2               @SaveCFAllocOk:
000681r 2               @SaveCFAlloc:
000681r 2                 ; Save CF_BUF_PTR (points to free entry)
000681r 2  A5 24          lda CF_BUF_PTR
000683r 2  48             pha
000684r 2  A5 25          lda CF_BUF_PTR+1
000686r 2  48             pha
000687r 2                 ; Calculate next free sector
000687r 2  20 rr rr       jsr FsCalcNextSec
00068Ar 2                 ; Restore CF_BUF_PTR
00068Ar 2  68             pla
00068Br 2  85 25          sta CF_BUF_PTR+1
00068Dr 2  68             pla
00068Er 2  85 24          sta CF_BUF_PTR
000690r 2                 ; Calculate sectors needed
000690r 2  AD 4B 03       lda FS_FILE_SIZE+1
000693r 2  4A             lsr a
000694r 2  8D 4C 03       sta FS_SEC_COUNT
000697r 2  AD 4B 03       lda FS_FILE_SIZE+1
00069Ar 2  29 01          and #$01
00069Cr 2  D0 05          bne @SaveCFRound
00069Er 2  AD 4A 03       lda FS_FILE_SIZE
0006A1r 2  F0 03          beq @SaveCFNoRound
0006A3r 2               @SaveCFRound:
0006A3r 2  EE 4C 03       inc FS_SEC_COUNT
0006A6r 2               @SaveCFNoRound:
0006A6r 2                 ; Fill in directory entry
0006A6r 2                 ; Copy filename (11 bytes)
0006A6r 2  A0 00          ldy #0
0006A8r 2               @SaveCFCopyName:
0006A8r 2  B9 50 03       lda FS_FNAME_BUF,y
0006ABr 2  91 24          sta (CF_BUF_PTR),y
0006ADr 2  C8             iny
0006AEr 2  C0 0B          cpy #11
0006B0r 2  D0 F6          bne @SaveCFCopyName
0006B2r 2                 ; Set flags = in use
0006B2r 2  A9 01          lda #FS_FLAG_USED
0006B4r 2  91 24          sta (CF_BUF_PTR),y            ; Y = 11 = FS_ENTRY_FLAGS
0006B6r 2                 ; Set start sector
0006B6r 2  A0 0C          ldy #FS_ENTRY_START
0006B8r 2  AD 4E 03       lda FS_NEXT_SEC
0006BBr 2  91 24          sta (CF_BUF_PTR),y
0006BDr 2  8D 48 03       sta FS_START_SEC
0006C0r 2  C8             iny
0006C1r 2  AD 4F 03       lda FS_NEXT_SEC+1
0006C4r 2  91 24          sta (CF_BUF_PTR),y
0006C6r 2  8D 49 03       sta FS_START_SEC+1
0006C9r 2                 ; Set file size
0006C9r 2  A0 0E          ldy #FS_ENTRY_FSIZE
0006CBr 2  AD 4A 03       lda FS_FILE_SIZE
0006CEr 2  91 24          sta (CF_BUF_PTR),y
0006D0r 2  C8             iny
0006D1r 2  AD 4B 03       lda FS_FILE_SIZE+1
0006D4r 2  91 24          sta (CF_BUF_PTR),y
0006D6r 2                 ; Clear reserved bytes
0006D6r 2  A0 10          ldy #$10
0006D8r 2  A9 00          lda #$00
0006DAr 2               @SaveCFClrRsv:
0006DAr 2  91 24          sta (CF_BUF_PTR),y
0006DCr 2  C8             iny
0006DDr 2  C0 20          cpy #FS_ENTRY_SIZE
0006DFr 2  D0 F9          bne @SaveCFClrRsv
0006E1r 2                 ; Write updated directory
0006E1r 2  20 rr rr       jsr FsWriteDir
0006E4r 2  B0 3A          bcs @SaveCFIOErr
0006E6r 2                 ; Write data sectors from user-specified start address (MON_TMP)
0006E6r 2  AD 48 03       lda FS_START_SEC
0006E9r 2  85 26          sta CF_LBA
0006EBr 2  AD 49 03       lda FS_START_SEC+1
0006EEr 2  85 27          sta CF_LBA+1
0006F0r 2  64 28          stz CF_LBA+2
0006F2r 2  64 29          stz CF_LBA+3
0006F4r 2                 ; Source = MON_TMP (start address)
0006F4r 2  A5 32          lda MON_TMP
0006F6r 2  85 24          sta CF_BUF_PTR
0006F8r 2  A5 33          lda MON_TMP+1
0006FAr 2  85 25          sta CF_BUF_PTR+1
0006FCr 2  AE 4C 03       ldx FS_SEC_COUNT
0006FFr 2  F0 10          beq @SaveCFOk
000701r 2               @SaveCFSec:
000701r 2  DA             phx
000702r 2  20 rr rr       jsr StWriteSector             ; Writes 512 bytes, advances CF_BUF_PTR
000705r 2  B0 18          bcs @SaveCFSecErr
000707r 2  E6 26          inc CF_LBA
000709r 2  D0 02          bne @SaveCFSecNext
00070Br 2  E6 27          inc CF_LBA+1
00070Dr 2               @SaveCFSecNext:
00070Dr 2  FA             plx
00070Er 2  CA             dex
00070Fr 2  D0 F0          bne @SaveCFSec
000711r 2               @SaveCFOk:
000711r 2  AD 4A 03       lda FS_FILE_SIZE
000714r 2  85 2E          sta MON_ADDR
000716r 2  AD 4B 03       lda FS_FILE_SIZE+1
000719r 2  85 2F          sta MON_ADDR+1
00071Br 2  20 rr rr       jsr MonPrintSaved             ; Print "SAVED nnnn BYTES"
00071Er 2  60             rts
00071Fr 2               @SaveCFSecErr:
00071Fr 2  FA             plx                           ; Balance stack
000720r 2               @SaveCFIOErr:
000720r 2  20 rr rr       jsr MonPrintIOErr
000723r 2  60             rts
000724r 2               @SaveCFDirFull:
000724r 2  A2 00          ldx #0
000726r 2               @SaveCFDFLoop:
000726r 2  BD rr rr       lda MonStrDirFull,x
000729r 2  F0 06          beq @SaveCFDFDone
00072Br 2  20 rr rr       jsr Chrout
00072Er 2  E8             inx
00072Fr 2  80 F5          bra @SaveCFDFLoop
000731r 2               @SaveCFDFDone:
000731r 2  20 rr rr       jsr MonPrintCRLF
000734r 2  60             rts
000735r 2               @SaveError:
000735r 2  4C rr rr       jmp MonPrintError
000738r 2               
000738r 2               ; ============================================================================
000738r 2               ; MonCmdM — Memory dump (hex + ASCII, 8 bytes/row)
000738r 2               ; Syntax: M [addr] [addr]
000738r 2               ; Default: 8 lines (64 bytes). Remembers position for continuation.
000738r 2               ; ============================================================================
000738r 2               
000738r 2               MonCmdM:
000738r 2  20 rr rr       jsr MonSkipSpaces
00073Br 2  20 rr rr       jsr MonParseHex4
00073Er 2  90 2A          bcc @UseDefault               ; No address given — use current MON_ADDR
000740r 2                 ; Got first address in MON_ADDR — save it
000740r 2  A5 2E          lda MON_ADDR
000742r 2  85 32          sta MON_TMP
000744r 2  A5 2F          lda MON_ADDR+1
000746r 2  85 33          sta MON_TMP+1
000748r 2  20 rr rr       jsr MonSkipSpaces
00074Br 2  20 rr rr       jsr MonParseHex4
00074Er 2  90 12          bcc @StartOnly
000750r 2                 ; Got second address (end) in MON_ADDR
000750r 2  A5 2E          lda MON_ADDR
000752r 2  85 30          sta MON_END
000754r 2  A5 2F          lda MON_ADDR+1
000756r 2  85 31          sta MON_END+1
000758r 2                 ; Restore start address
000758r 2  A5 32          lda MON_TMP
00075Ar 2  85 2E          sta MON_ADDR
00075Cr 2  A5 33          lda MON_TMP+1
00075Er 2  85 2F          sta MON_ADDR+1
000760r 2  80 15          bra @DumpRange
000762r 2               @StartOnly:
000762r 2                 ; Only start address — restore from MON_TMP
000762r 2  A5 32          lda MON_TMP
000764r 2  85 2E          sta MON_ADDR
000766r 2  A5 33          lda MON_TMP+1
000768r 2  85 2F          sta MON_ADDR+1
00076Ar 2               @UseDefault:
00076Ar 2                 ; Set end = start + 63 (8 lines x 8 bytes)
00076Ar 2  18             clc
00076Br 2  A5 2E          lda MON_ADDR
00076Dr 2  69 3F          adc #63
00076Fr 2  85 30          sta MON_END
000771r 2  A5 2F          lda MON_ADDR+1
000773r 2  69 00          adc #0
000775r 2  85 31          sta MON_END+1
000777r 2               @DumpRange:
000777r 2  20 rr rr       jsr MonDumpLine
00077Ar 2  B0 0E          bcs @DumpDone                 ; Carry set = address wrapped past $FFFF
00077Cr 2                 ; Check if MON_ADDR > MON_END
00077Cr 2  A5 31          lda MON_END+1
00077Er 2  C5 2F          cmp MON_ADDR+1
000780r 2  90 08          bcc @DumpDone
000782r 2  D0 F3          bne @DumpRange
000784r 2  A5 30          lda MON_END
000786r 2  C5 2E          cmp MON_ADDR
000788r 2  B0 ED          bcs @DumpRange
00078Ar 2               @DumpDone:
00078Ar 2  60             rts
00078Br 2               
00078Br 2               ; MonDumpLine — Dump 8 bytes at MON_ADDR as hex + ASCII, advance by 8
00078Br 2               
00078Br 2               MonDumpLine:
00078Br 2                 ; Print ".:ADDR " (39 chars/line avoids 40-col auto-wrap + CRLF double-newline)
00078Br 2  A9 2E          lda #'.'
00078Dr 2  20 rr rr       jsr Chrout
000790r 2  A9 3A          lda #':'
000792r 2  20 rr rr       jsr Chrout
000795r 2  20 rr rr       jsr MonPrintHex4
000798r 2  20 rr rr       jsr MonPrintSpace
00079Br 2                 ; Print 8 hex bytes
00079Br 2  A0 00          ldy #0
00079Dr 2               @HexLoop:
00079Dr 2  B1 2E          lda (MON_ADDR),y
00079Fr 2  5A             phy
0007A0r 2  20 rr rr       jsr MonPrintHex2
0007A3r 2  20 rr rr       jsr MonPrintSpace
0007A6r 2  7A             ply
0007A7r 2  C8             iny
0007A8r 2  C0 08          cpy #8
0007AAr 2  90 F1          bcc @HexLoop
0007ACr 2                 ; Print 8 ASCII characters (no extra space — fits 40 cols)
0007ACr 2  A0 00          ldy #0
0007AEr 2               @AsciiLoop:
0007AEr 2  B1 2E          lda (MON_ADDR),y
0007B0r 2  C9 20          cmp #$20
0007B2r 2  90 04          bcc @NotPrint
0007B4r 2  C9 7F          cmp #$7F
0007B6r 2  90 02          bcc @DoPrint
0007B8r 2               @NotPrint:
0007B8r 2  A9 2E          lda #'.'
0007BAr 2               @DoPrint:
0007BAr 2  5A             phy
0007BBr 2  20 rr rr       jsr Chrout
0007BEr 2  7A             ply
0007BFr 2  C8             iny
0007C0r 2  C0 08          cpy #8
0007C2r 2  90 EA          bcc @AsciiLoop
0007C4r 2                 ; Advance MON_ADDR by 8
0007C4r 2  18             clc
0007C5r 2  A5 2E          lda MON_ADDR
0007C7r 2  69 08          adc #8
0007C9r 2  85 2E          sta MON_ADDR
0007CBr 2  90 04          bcc @NoCarry
0007CDr 2  E6 2F          inc MON_ADDR+1
0007CFr 2  F0 05          beq @Wrapped                  ; High byte became $00 = wrapped past $FFFF
0007D1r 2               @NoCarry:
0007D1r 2  20 rr rr       jsr MonPrintCRLF
0007D4r 2  18             clc                           ; Signal no overflow
0007D5r 2  60             rts
0007D6r 2               @Wrapped:
0007D6r 2  20 rr rr       jsr MonPrintCRLF
0007D9r 2  38             sec                           ; Signal overflow
0007DAr 2  60             rts
0007DBr 2               
0007DBr 2               ; ============================================================================
0007DBr 2               ; MonCmdD — Disassemble 65C02 instructions
0007DBr 2               ; Syntax: D [addr] [addr]
0007DBr 2               ; Default: 20 lines. Remembers position for continuation.
0007DBr 2               ; ============================================================================
0007DBr 2               
0007DBr 2               MonCmdD:
0007DBr 2  20 rr rr       jsr MonSkipSpaces
0007DEr 2  20 rr rr       jsr MonParseHex4
0007E1r 2  90 2A          bcc @UseDefault
0007E3r 2                 ; Got first address
0007E3r 2  A5 2E          lda MON_ADDR
0007E5r 2  85 32          sta MON_TMP
0007E7r 2  A5 2F          lda MON_ADDR+1
0007E9r 2  85 33          sta MON_TMP+1
0007EBr 2  20 rr rr       jsr MonSkipSpaces
0007EEr 2  20 rr rr       jsr MonParseHex4
0007F1r 2  90 12          bcc @StartOnly
0007F3r 2                 ; Got end address
0007F3r 2  A5 2E          lda MON_ADDR
0007F5r 2  85 30          sta MON_END
0007F7r 2  A5 2F          lda MON_ADDR+1
0007F9r 2  85 31          sta MON_END+1
0007FBr 2  A5 32          lda MON_TMP
0007FDr 2  85 2E          sta MON_ADDR
0007FFr 2  A5 33          lda MON_TMP+1
000801r 2  85 2F          sta MON_ADDR+1
000803r 2  80 15          bra @DisRange
000805r 2               @StartOnly:
000805r 2  A5 32          lda MON_TMP
000807r 2  85 2E          sta MON_ADDR
000809r 2  A5 33          lda MON_TMP+1
00080Br 2  85 2F          sta MON_ADDR+1
00080Dr 2               @UseDefault:
00080Dr 2                 ; Disassemble 20 lines
00080Dr 2  A2 14          ldx #20
00080Fr 2               @DisCountLoop:
00080Fr 2  DA             phx
000810r 2  20 rr rr       jsr DisOneLine
000813r 2  FA             plx
000814r 2  B0 17          bcs @DisDone                  ; Carry set = address wrapped past $FFFF
000816r 2  CA             dex
000817r 2  D0 F6          bne @DisCountLoop
000819r 2  60             rts
00081Ar 2               @DisRange:
00081Ar 2  20 rr rr       jsr DisOneLine
00081Dr 2  B0 0E          bcs @DisDone                  ; Carry set = address wrapped past $FFFF
00081Fr 2                 ; Check if MON_ADDR > MON_END
00081Fr 2  A5 31          lda MON_END+1
000821r 2  C5 2F          cmp MON_ADDR+1
000823r 2  90 08          bcc @DisDone
000825r 2  D0 F3          bne @DisRange
000827r 2  A5 30          lda MON_END
000829r 2  C5 2E          cmp MON_ADDR
00082Br 2  B0 ED          bcs @DisRange
00082Dr 2               @DisDone:
00082Dr 2  60             rts
00082Er 2               
00082Er 2               ; ============================================================================
00082Er 2               ; DisOneLine — Disassemble one instruction at MON_ADDR
00082Er 2               ; Prints line, advances MON_ADDR by instruction length.
00082Er 2               ; Uses: MON_BYTE=opcode, MON_TMP=mnemonic idx, MON_TMP+1=mode
00082Er 2               ;       Stack holds instruction length throughout.
00082Er 2               ; ============================================================================
00082Er 2               
00082Er 2               DisOneLine:
00082Er 2                 ; Read opcode and look up table
00082Er 2  A0 00          ldy #0
000830r 2  B1 2E          lda (MON_ADDR),y
000832r 2  85 34          sta MON_BYTE                  ; save opcode
000834r 2  0A             asl a                         ; opcode * 2 for table index
000835r 2  AA             tax
000836r 2  90 0C          bcc @LowHalf                  ; carry clear = opcodes $00-$7F
000838r 2  BD rr rr       lda DisOpcodeTable+256,x      ; opcodes $80-$FF: offset by 256
00083Br 2  85 32          sta MON_TMP                   ; mnemonic index
00083Dr 2  BD rr rr       lda DisOpcodeTable+257,x
000840r 2  85 33          sta MON_TMP+1                 ; addressing mode
000842r 2  80 0A          bra @GotEntry
000844r 2               @LowHalf:
000844r 2  BD rr rr       lda DisOpcodeTable,x
000847r 2  85 32          sta MON_TMP                   ; mnemonic index
000849r 2  BD rr rr       lda DisOpcodeTable+1,x
00084Cr 2  85 33          sta MON_TMP+1                 ; addressing mode
00084Er 2               @GotEntry:
00084Er 2                 ; Get instruction length from mode
00084Er 2  A6 33          ldx MON_TMP+1
000850r 2  BD rr rr       lda DisModeSizes,x
000853r 2  1A             inc a                         ; +1 for opcode = total length
000854r 2  48             pha                           ; save on stack (stays until end)
000855r 2                 ; Print prefix ".,ADDR" (no space — consistent with M command's .:ADDR)
000855r 2  A9 2E          lda #'.'
000857r 2  20 rr rr       jsr Chrout
00085Ar 2  A9 2C          lda #','
00085Cr 2  20 rr rr       jsr Chrout
00085Fr 2                 ; Print address
00085Fr 2  20 rr rr       jsr MonPrintHex4
000862r 2  20 rr rr       jsr MonPrintSpace
000865r 2  20 rr rr       jsr MonPrintSpace
000868r 2                 ; Print opcode byte
000868r 2  A5 34          lda MON_BYTE
00086Ar 2  20 rr rr       jsr MonPrintHex2
00086Dr 2                 ; Print 2nd byte or padding
00086Dr 2  68             pla
00086Er 2  48             pha                           ; peek at length
00086Fr 2  C9 02          cmp #2
000871r 2  90 0C          bcc @Pad1
000873r 2  20 rr rr       jsr MonPrintSpace
000876r 2  A0 01          ldy #1
000878r 2  B1 2E          lda (MON_ADDR),y
00087Ar 2  20 rr rr       jsr MonPrintHex2
00087Dr 2  80 09          bra @Check3
00087Fr 2               @Pad1:
00087Fr 2  20 rr rr       jsr MonPrintSpace
000882r 2  20 rr rr       jsr MonPrintSpace
000885r 2  20 rr rr       jsr MonPrintSpace
000888r 2               @Check3:
000888r 2  68             pla
000889r 2  48             pha
00088Ar 2  C9 03          cmp #3
00088Cr 2  90 0C          bcc @Pad2
00088Er 2  20 rr rr       jsr MonPrintSpace
000891r 2  A0 02          ldy #2
000893r 2  B1 2E          lda (MON_ADDR),y
000895r 2  20 rr rr       jsr MonPrintHex2
000898r 2  80 09          bra @AfterBytes
00089Ar 2               @Pad2:
00089Ar 2  20 rr rr       jsr MonPrintSpace
00089Dr 2  20 rr rr       jsr MonPrintSpace
0008A0r 2  20 rr rr       jsr MonPrintSpace
0008A3r 2               @AfterBytes:
0008A3r 2                 ; Separator before mnemonic
0008A3r 2  20 rr rr       jsr MonPrintSpace
0008A6r 2  20 rr rr       jsr MonPrintSpace
0008A9r 2                 ; Print mnemonic (3 chars)
0008A9r 2  20 rr rr       jsr DisPrintMnemonic
0008ACr 2                 ; For RMB/SMB/BBR/BBS, append bit number digit
0008ACr 2  A5 32          lda MON_TMP
0008AEr 2  C9 03          cmp #MN_BBR
0008B0r 2  F0 11          beq @BitNum
0008B2r 2  C9 04          cmp #MN_BBS
0008B4r 2  F0 0D          beq @BitNum
0008B6r 2  C9 2E          cmp #MN_RMB
0008B8r 2  F0 09          beq @BitNum
0008BAr 2  C9 37          cmp #MN_SMB
0008BCr 2  F0 05          beq @BitNum
0008BEr 2  20 rr rr       jsr MonPrintSpace             ; normal mnemonic — space separator
0008C1r 2  80 11          bra @Operand
0008C3r 2               @BitNum:
0008C3r 2  A5 34          lda MON_BYTE                  ; opcode encodes bit in upper nibble
0008C5r 2  4A             lsr a
0008C6r 2  4A             lsr a
0008C7r 2  4A             lsr a
0008C8r 2  4A             lsr a
0008C9r 2  29 07          and #$07
0008CBr 2  18             clc
0008CCr 2  69 30          adc #'0'
0008CEr 2  20 rr rr       jsr Chrout
0008D1r 2  20 rr rr       jsr MonPrintSpace
0008D4r 2               @Operand:
0008D4r 2                 ; Print operand based on addressing mode
0008D4r 2  A5 33          lda MON_TMP+1
0008D6r 2  20 rr rr       jsr DisPrintOperand
0008D9r 2                 ; CRLF
0008D9r 2  20 rr rr       jsr MonPrintCRLF
0008DCr 2                 ; Advance MON_ADDR by instruction length
0008DCr 2  68             pla                           ; length from stack
0008DDr 2  18             clc
0008DEr 2  65 2E          adc MON_ADDR
0008E0r 2  85 2E          sta MON_ADDR
0008E2r 2  90 04          bcc @NoWrap
0008E4r 2  E6 2F          inc MON_ADDR+1
0008E6r 2  F0 02          beq @DisWrapped               ; High byte became $00 = wrapped past $FFFF
0008E8r 2               @NoWrap:
0008E8r 2  18             clc                           ; Signal no overflow
0008E9r 2  60             rts
0008EAr 2               @DisWrapped:
0008EAr 2  38             sec                           ; Signal overflow
0008EBr 2  60             rts
0008ECr 2               
0008ECr 2               ; DisPrintMnemonic — Print 3-char mnemonic from MON_TMP index
0008ECr 2               
0008ECr 2               DisPrintMnemonic:
0008ECr 2  A5 32          lda MON_TMP                   ; mnemonic index
0008EEr 2  0A             asl a                         ; index * 2
0008EFr 2  18             clc
0008F0r 2  65 32          adc MON_TMP                   ; + index = index * 3
0008F2r 2  AA             tax
0008F3r 2  BD rr rr       lda DisMnemonics,x
0008F6r 2  DA             phx
0008F7r 2  20 rr rr       jsr Chrout
0008FAr 2  FA             plx
0008FBr 2  BD rr rr       lda DisMnemonics+1,x
0008FEr 2  DA             phx
0008FFr 2  20 rr rr       jsr Chrout
000902r 2  FA             plx
000903r 2  BD rr rr       lda DisMnemonics+2,x
000906r 2  4C rr rr       jmp Chrout
000909r 2               
000909r 2               ; DisPrintOperand — Dispatch to addressing mode operand printer
000909r 2               ; Input: A = addressing mode index
000909r 2               
000909r 2               DisPrintOperand:
000909r 2  0A             asl a                         ; mode * 2 for word table index
00090Ar 2  AA             tax
00090Br 2  7C rr rr       jmp (DisOperandJmpTable,x)    ; handler does RTS to our caller
00090Er 2               
00090Er 2               ; ============================================================================
00090Er 2               ; Addressing Mode Operand Handlers
00090Er 2               ; Each handler prints the operand and returns via RTS.
00090Er 2               ; ============================================================================
00090Er 2               
00090Er 2               DisOpImp:
00090Er 2  60             rts
00090Fr 2               
00090Fr 2               DisOpAcc:
00090Fr 2  A9 41          lda #'A'
000911r 2  4C rr rr       jmp Chrout
000914r 2               
000914r 2               DisOpImm:
000914r 2  A9 23          lda #'#'
000916r 2  20 rr rr       jsr Chrout
000919r 2  A9 24          lda #'$'
00091Br 2  20 rr rr       jsr Chrout
00091Er 2  A0 01          ldy #1
000920r 2  B1 2E          lda (MON_ADDR),y
000922r 2  4C rr rr       jmp MonPrintHex2
000925r 2               
000925r 2               DisOpZp:
000925r 2  A9 24          lda #'$'
000927r 2  20 rr rr       jsr Chrout
00092Ar 2  A0 01          ldy #1
00092Cr 2  B1 2E          lda (MON_ADDR),y
00092Er 2  4C rr rr       jmp MonPrintHex2
000931r 2               
000931r 2               DisOpZpx:
000931r 2  20 rr rr       jsr DisOpZp
000934r 2  A9 2C          lda #','
000936r 2  20 rr rr       jsr Chrout
000939r 2  A9 58          lda #'X'
00093Br 2  4C rr rr       jmp Chrout
00093Er 2               
00093Er 2               DisOpZpy:
00093Er 2  20 rr rr       jsr DisOpZp
000941r 2  A9 2C          lda #','
000943r 2  20 rr rr       jsr Chrout
000946r 2  A9 59          lda #'Y'
000948r 2  4C rr rr       jmp Chrout
00094Br 2               
00094Br 2               DisOpAbs:
00094Br 2  A9 24          lda #'$'
00094Dr 2  20 rr rr       jsr Chrout
000950r 2  A0 02          ldy #2
000952r 2  B1 2E          lda (MON_ADDR),y              ; high byte
000954r 2  20 rr rr       jsr MonPrintHex2
000957r 2  A0 01          ldy #1
000959r 2  B1 2E          lda (MON_ADDR),y              ; low byte
00095Br 2  4C rr rr       jmp MonPrintHex2
00095Er 2               
00095Er 2               DisOpAbx:
00095Er 2  20 rr rr       jsr DisOpAbs
000961r 2  A9 2C          lda #','
000963r 2  20 rr rr       jsr Chrout
000966r 2  A9 58          lda #'X'
000968r 2  4C rr rr       jmp Chrout
00096Br 2               
00096Br 2               DisOpAby:
00096Br 2  20 rr rr       jsr DisOpAbs
00096Er 2  A9 2C          lda #','
000970r 2  20 rr rr       jsr Chrout
000973r 2  A9 59          lda #'Y'
000975r 2  4C rr rr       jmp Chrout
000978r 2               
000978r 2               DisOpInd:
000978r 2  A9 28          lda #'('
00097Ar 2  20 rr rr       jsr Chrout
00097Dr 2  20 rr rr       jsr DisOpAbs
000980r 2  A9 29          lda #')'
000982r 2  4C rr rr       jmp Chrout
000985r 2               
000985r 2               DisOpIzx:
000985r 2  A9 28          lda #'('
000987r 2  20 rr rr       jsr Chrout
00098Ar 2  20 rr rr       jsr DisOpZp
00098Dr 2  A9 2C          lda #','
00098Fr 2  20 rr rr       jsr Chrout
000992r 2  A9 58          lda #'X'
000994r 2  20 rr rr       jsr Chrout
000997r 2  A9 29          lda #')'
000999r 2  4C rr rr       jmp Chrout
00099Cr 2               
00099Cr 2               DisOpIzy:
00099Cr 2  A9 28          lda #'('
00099Er 2  20 rr rr       jsr Chrout
0009A1r 2  20 rr rr       jsr DisOpZp
0009A4r 2  A9 29          lda #')'
0009A6r 2  20 rr rr       jsr Chrout
0009A9r 2  A9 2C          lda #','
0009ABr 2  20 rr rr       jsr Chrout
0009AEr 2  A9 59          lda #'Y'
0009B0r 2  4C rr rr       jmp Chrout
0009B3r 2               
0009B3r 2               DisOpZpi:
0009B3r 2  A9 28          lda #'('
0009B5r 2  20 rr rr       jsr Chrout
0009B8r 2  20 rr rr       jsr DisOpZp
0009BBr 2  A9 29          lda #')'
0009BDr 2  4C rr rr       jmp Chrout
0009C0r 2               
0009C0r 2               DisOpRel:
0009C0r 2                 ; Target = current_addr + 2 + signed_offset
0009C0r 2  A0 01          ldy #1
0009C2r 2  B1 2E          lda (MON_ADDR),y              ; offset byte
0009C4r 2  30 0D          bmi @Neg
0009C6r 2                 ; Positive offset
0009C6r 2  18             clc
0009C7r 2  65 2E          adc MON_ADDR
0009C9r 2  85 32          sta MON_TMP
0009CBr 2  A5 2F          lda MON_ADDR+1
0009CDr 2  69 00          adc #0
0009CFr 2  85 33          sta MON_TMP+1
0009D1r 2  80 0B          bra @Add2
0009D3r 2               @Neg:
0009D3r 2  18             clc
0009D4r 2  65 2E          adc MON_ADDR
0009D6r 2  85 32          sta MON_TMP
0009D8r 2  A5 2F          lda MON_ADDR+1
0009DAr 2  69 FF          adc #$FF                      ; sign extension
0009DCr 2  85 33          sta MON_TMP+1
0009DEr 2               @Add2:
0009DEr 2  18             clc
0009DFr 2  A5 32          lda MON_TMP
0009E1r 2  69 02          adc #2
0009E3r 2  85 32          sta MON_TMP
0009E5r 2  A5 33          lda MON_TMP+1
0009E7r 2  69 00          adc #0
0009E9r 2  85 33          sta MON_TMP+1
0009EBr 2                 ; Print "$XXXX"
0009EBr 2  A9 24          lda #'$'
0009EDr 2  20 rr rr       jsr Chrout
0009F0r 2  A5 33          lda MON_TMP+1
0009F2r 2  20 rr rr       jsr MonPrintHex2
0009F5r 2  A5 32          lda MON_TMP
0009F7r 2  4C rr rr       jmp MonPrintHex2
0009FAr 2               
0009FAr 2               DisOpZpr:
0009FAr 2                 ; ZP byte first
0009FAr 2  A9 24          lda #'$'
0009FCr 2  20 rr rr       jsr Chrout
0009FFr 2  A0 01          ldy #1
000A01r 2  B1 2E          lda (MON_ADDR),y
000A03r 2  20 rr rr       jsr MonPrintHex2
000A06r 2  A9 2C          lda #','
000A08r 2  20 rr rr       jsr Chrout
000A0Br 2                 ; Branch target = addr + 3 + signed_offset(byte 2)
000A0Br 2  A0 02          ldy #2
000A0Dr 2  B1 2E          lda (MON_ADDR),y
000A0Fr 2  30 0D          bmi @Neg
000A11r 2  18             clc
000A12r 2  65 2E          adc MON_ADDR
000A14r 2  85 32          sta MON_TMP
000A16r 2  A5 2F          lda MON_ADDR+1
000A18r 2  69 00          adc #0
000A1Ar 2  85 33          sta MON_TMP+1
000A1Cr 2  80 0B          bra @Add3
000A1Er 2               @Neg:
000A1Er 2  18             clc
000A1Fr 2  65 2E          adc MON_ADDR
000A21r 2  85 32          sta MON_TMP
000A23r 2  A5 2F          lda MON_ADDR+1
000A25r 2  69 FF          adc #$FF
000A27r 2  85 33          sta MON_TMP+1
000A29r 2               @Add3:
000A29r 2  18             clc
000A2Ar 2  A5 32          lda MON_TMP
000A2Cr 2  69 03          adc #3
000A2Er 2  85 32          sta MON_TMP
000A30r 2  A5 33          lda MON_TMP+1
000A32r 2  69 00          adc #0
000A34r 2  85 33          sta MON_TMP+1
000A36r 2  A9 24          lda #'$'
000A38r 2  20 rr rr       jsr Chrout
000A3Br 2  A5 33          lda MON_TMP+1
000A3Dr 2  20 rr rr       jsr MonPrintHex2
000A40r 2  A5 32          lda MON_TMP
000A42r 2  4C rr rr       jmp MonPrintHex2
000A45r 2               
000A45r 2               DisOpAix:
000A45r 2  A9 28          lda #'('
000A47r 2  20 rr rr       jsr Chrout
000A4Ar 2  20 rr rr       jsr DisOpAbs
000A4Dr 2  A9 2C          lda #','
000A4Fr 2  20 rr rr       jsr Chrout
000A52r 2  A9 58          lda #'X'
000A54r 2  20 rr rr       jsr Chrout
000A57r 2  A9 29          lda #')'
000A59r 2  4C rr rr       jmp Chrout
000A5Cr 2               
000A5Cr 2               ; ============================================================================
000A5Cr 2               ; MonShowRegs — Print saved register state
000A5Cr 2               ; Format: PC=xxxx A=xx X=xx Y=xx SP=xx NV-BDIZC
000A5Cr 2               ; ============================================================================
000A5Cr 2               
000A5Cr 2               MonShowRegs:
000A5Cr 2                 ; "PC="
000A5Cr 2  A9 50          lda #'P'
000A5Er 2  20 rr rr       jsr Chrout
000A61r 2  A9 43          lda #'C'
000A63r 2  20 rr rr       jsr Chrout
000A66r 2  A9 3D          lda #'='
000A68r 2  20 rr rr       jsr Chrout
000A6Br 2                 ; Print PC (adjusted: BRK_PC - 2)
000A6Br 2  38             sec
000A6Cr 2  AD 11 03       lda BRK_PCL
000A6Fr 2  E9 02          sbc #2
000A71r 2  85 2E          sta MON_ADDR
000A73r 2  AD 12 03       lda BRK_PCH
000A76r 2  E9 00          sbc #0
000A78r 2  85 2F          sta MON_ADDR + 1
000A7Ar 2  20 rr rr       jsr MonPrintHex4
000A7Dr 2  A9 20          lda #' '
000A7Fr 2  20 rr rr       jsr Chrout
000A82r 2               
000A82r 2                 ; "A="
000A82r 2  A9 41          lda #'A'
000A84r 2  20 rr rr       jsr Chrout
000A87r 2  A9 3D          lda #'='
000A89r 2  20 rr rr       jsr Chrout
000A8Cr 2  AD 13 03       lda BRK_A
000A8Fr 2  20 rr rr       jsr MonPrintHex2
000A92r 2  A9 20          lda #' '
000A94r 2  20 rr rr       jsr Chrout
000A97r 2               
000A97r 2                 ; "X="
000A97r 2  A9 58          lda #'X'
000A99r 2  20 rr rr       jsr Chrout
000A9Cr 2  A9 3D          lda #'='
000A9Er 2  20 rr rr       jsr Chrout
000AA1r 2  AD 14 03       lda BRK_X
000AA4r 2  20 rr rr       jsr MonPrintHex2
000AA7r 2  A9 20          lda #' '
000AA9r 2  20 rr rr       jsr Chrout
000AACr 2               
000AACr 2                 ; "Y="
000AACr 2  A9 59          lda #'Y'
000AAEr 2  20 rr rr       jsr Chrout
000AB1r 2  A9 3D          lda #'='
000AB3r 2  20 rr rr       jsr Chrout
000AB6r 2  AD 15 03       lda BRK_Y
000AB9r 2  20 rr rr       jsr MonPrintHex2
000ABCr 2  A9 20          lda #' '
000ABEr 2  20 rr rr       jsr Chrout
000AC1r 2               
000AC1r 2                 ; "SP="
000AC1r 2  A9 53          lda #'S'
000AC3r 2  20 rr rr       jsr Chrout
000AC6r 2  A9 50          lda #'P'
000AC8r 2  20 rr rr       jsr Chrout
000ACBr 2  A9 3D          lda #'='
000ACDr 2  20 rr rr       jsr Chrout
000AD0r 2  AD 16 03       lda BRK_SP
000AD3r 2  20 rr rr       jsr MonPrintHex2
000AD6r 2  A9 20          lda #' '
000AD8r 2  20 rr rr       jsr Chrout
000ADBr 2               
000ADBr 2                 ; Flags: NV-BDIZC
000ADBr 2  AD 10 03       lda BRK_P
000ADEr 2  85 34          sta MON_BYTE                  ; Save flags for bit testing
000AE0r 2  A2 00          ldx #0
000AE2r 2               @FlagLoop:
000AE2r 2  BD rr rr       lda MonFlagChars,x
000AE5r 2  F0 11          beq @FlagsDone
000AE7r 2  06 34          asl MON_BYTE                  ; Shift next flag bit into carry
000AE9r 2  B0 04          bcs @FlagSet
000AEBr 2  A9 2D          lda #'-'                      ; Flag clear — print dash
000AEDr 2  80 03          bra @FlagPrint
000AEFr 2               @FlagSet:
000AEFr 2                 ; A already has the flag character
000AEFr 2  BD rr rr       lda MonFlagChars,x
000AF2r 2               @FlagPrint:
000AF2r 2  20 rr rr       jsr Chrout
000AF5r 2  E8             inx
000AF6r 2  80 EA          bra @FlagLoop
000AF8r 2               @FlagsDone:
000AF8r 2  20 rr rr       jsr MonPrintCRLF
000AFBr 2  60             rts
000AFCr 2               
000AFCr 2               MonFlagChars:
000AFCr 2  4E 56 2D 42    .byte "NV-BDIZC", 0
000B00r 2  44 49 5A 43  
000B04r 2  00           
000B05r 2               
000B05r 2               ; ============================================================================
000B05r 2               ; Hex Parsing Utilities
000B05r 2               ; ============================================================================
000B05r 2               
000B05r 2               ; MonParseHex4 — Parse up to 4 hex digits from MON_LINBUF into MON_ADDR
000B05r 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000B05r 2               ; Output: MON_ADDR/MON_ADDR+1 = parsed 16-bit value, carry set if valid
000B05r 2               ;         MON_IDX advanced past parsed digits
000B05r 2               
000B05r 2               MonParseHex4:
000B05r 2  64 2E          stz MON_ADDR
000B07r 2  64 2F          stz MON_ADDR + 1
000B09r 2  A2 00          ldx #0                        ; Digit count
000B0Br 2               @ParseLoop:
000B0Br 2  A4 35          ldy MON_IDX
000B0Dr 2  B9 34 04       lda MON_LINBUF,y
000B10r 2  20 rr rr       jsr MonCharToNibble           ; Convert ASCII to 0-15, carry clear if valid
000B13r 2  B0 1B          bcs @ParseDone                ; Not a hex digit — stop
000B15r 2                 ; Shift result left 4 bits and OR in new nibble
000B15r 2  06 2E          asl MON_ADDR
000B17r 2  26 2F          rol MON_ADDR + 1
000B19r 2  06 2E          asl MON_ADDR
000B1Br 2  26 2F          rol MON_ADDR + 1
000B1Dr 2  06 2E          asl MON_ADDR
000B1Fr 2  26 2F          rol MON_ADDR + 1
000B21r 2  06 2E          asl MON_ADDR
000B23r 2  26 2F          rol MON_ADDR + 1
000B25r 2  05 2E          ora MON_ADDR
000B27r 2  85 2E          sta MON_ADDR
000B29r 2  E6 35          inc MON_IDX
000B2Br 2  E8             inx
000B2Cr 2  E0 04          cpx #4                        ; Max 4 digits
000B2Er 2  90 DB          bcc @ParseLoop
000B30r 2               @ParseDone:
000B30r 2  E0 00          cpx #0                        ; Did we parse at least one digit?
000B32r 2  F0 02          beq @ParseFail
000B34r 2  38             sec                           ; Success
000B35r 2  60             rts
000B36r 2               @ParseFail:
000B36r 2  18             clc                           ; Failure — no digits parsed
000B37r 2  60             rts
000B38r 2               
000B38r 2               ; MonParseHex2 — Parse up to 2 hex digits from MON_LINBUF into A
000B38r 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000B38r 2               ; Output: A = parsed 8-bit value, carry set if valid
000B38r 2               ;         MON_IDX advanced past parsed digits
000B38r 2               
000B38r 2               MonParseHex2:
000B38r 2  64 34          stz MON_BYTE
000B3Ar 2  A2 00          ldx #0                        ; Digit count
000B3Cr 2               @ParseLoop:
000B3Cr 2  A4 35          ldy MON_IDX
000B3Er 2  B9 34 04       lda MON_LINBUF,y
000B41r 2  20 rr rr       jsr MonCharToNibble
000B44r 2  B0 13          bcs @ParseDone
000B46r 2  06 34          asl MON_BYTE
000B48r 2  06 34          asl MON_BYTE
000B4Ar 2  06 34          asl MON_BYTE
000B4Cr 2  06 34          asl MON_BYTE
000B4Er 2  05 34          ora MON_BYTE
000B50r 2  85 34          sta MON_BYTE
000B52r 2  E6 35          inc MON_IDX
000B54r 2  E8             inx
000B55r 2  E0 02          cpx #2
000B57r 2  90 E3          bcc @ParseLoop
000B59r 2               @ParseDone:
000B59r 2  E0 00          cpx #0
000B5Br 2  F0 04          beq @ParseFail
000B5Dr 2  A5 34          lda MON_BYTE
000B5Fr 2  38             sec
000B60r 2  60             rts
000B61r 2               @ParseFail:
000B61r 2  18             clc
000B62r 2  60             rts
000B63r 2               
000B63r 2               ; MonCharToNibble — Convert ASCII hex char in A to nibble value 0-15
000B63r 2               ; Input:  A = ASCII character
000B63r 2               ; Output: A = 0-15 if valid hex digit, carry clear
000B63r 2               ;         carry set if not a valid hex digit (A preserved)
000B63r 2               
000B63r 2               MonCharToNibble:
000B63r 2  C9 30          cmp #'0'
000B65r 2  90 23          bcc @NotHex
000B67r 2  C9 3A          cmp #'9'+1
000B69r 2  90 15          bcc @IsDigit
000B6Br 2  C9 41          cmp #'A'
000B6Dr 2  90 04          bcc @CheckLower
000B6Fr 2  C9 47          cmp #'F'+1
000B71r 2  90 12          bcc @IsUpper
000B73r 2               @CheckLower:
000B73r 2  C9 61          cmp #'a'
000B75r 2  90 13          bcc @NotHex
000B77r 2  C9 67          cmp #'f'+1
000B79r 2  B0 0F          bcs @NotHex
000B7Br 2                 ; Lowercase a-f
000B7Br 2  38             sec
000B7Cr 2  E9 57          sbc #('a' - 10)
000B7Er 2  18             clc
000B7Fr 2  60             rts
000B80r 2               @IsDigit:
000B80r 2  38             sec
000B81r 2  E9 30          sbc #'0'
000B83r 2  18             clc
000B84r 2  60             rts
000B85r 2               @IsUpper:
000B85r 2  38             sec
000B86r 2  E9 37          sbc #('A' - 10)
000B88r 2  18             clc
000B89r 2  60             rts
000B8Ar 2               @NotHex:
000B8Ar 2  38             sec
000B8Br 2  60             rts
000B8Cr 2               
000B8Cr 2               ; MonSkipSpaces — Advance MON_IDX past whitespace in MON_LINBUF
000B8Cr 2               
000B8Cr 2               MonSkipSpaces:
000B8Cr 2  A4 35          ldy MON_IDX
000B8Er 2  B9 34 04       lda MON_LINBUF,y
000B91r 2  C9 20          cmp #' '
000B93r 2  D0 04          bne @Done
000B95r 2  E6 35          inc MON_IDX
000B97r 2  80 F3          bra MonSkipSpaces
000B99r 2               @Done:
000B99r 2  60             rts
000B9Ar 2               
000B9Ar 2               ; ============================================================================
000B9Ar 2               ; Decimal & Binary Parsing Utilities
000B9Ar 2               ; ============================================================================
000B9Ar 2               
000B9Ar 2               ; MonParseDec16 — Parse decimal digits from MON_LINBUF into MON_ADDR
000B9Ar 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000B9Ar 2               ; Output: MON_ADDR = parsed 16-bit value, carry set if valid
000B9Ar 2               ;         MON_IDX advanced past parsed digits
000B9Ar 2               ; Modifies: A, X, Y, MON_ADDR, MON_TMP
000B9Ar 2               
000B9Ar 2               MonParseDec16:
000B9Ar 2  64 2E          stz MON_ADDR
000B9Cr 2  64 2F          stz MON_ADDR+1
000B9Er 2  A2 00          ldx #0                        ; Digit count
000BA0r 2               @DecLoop:
000BA0r 2  A4 35          ldy MON_IDX
000BA2r 2  B9 34 04       lda MON_LINBUF,y
000BA5r 2  C9 30          cmp #'0'
000BA7r 2  90 3A          bcc @DecDone
000BA9r 2  C9 3A          cmp #'9'+1
000BABr 2  B0 36          bcs @DecDone
000BADr 2  38             sec
000BAEr 2  E9 30          sbc #'0'                      ; A = digit 0-9
000BB0r 2  48             pha                           ; Save digit
000BB1r 2                 ; MON_ADDR = MON_ADDR * 10 + digit
000BB1r 2                 ; *10 = (*2 + *8): save *2, then *8, add
000BB1r 2  06 2E          asl MON_ADDR
000BB3r 2  26 2F          rol MON_ADDR+1
000BB5r 2  A5 2E          lda MON_ADDR
000BB7r 2  85 32          sta MON_TMP
000BB9r 2  A5 2F          lda MON_ADDR+1
000BBBr 2  85 33          sta MON_TMP+1                 ; MON_TMP = *2
000BBDr 2  06 2E          asl MON_ADDR
000BBFr 2  26 2F          rol MON_ADDR+1                ; *4
000BC1r 2  06 2E          asl MON_ADDR
000BC3r 2  26 2F          rol MON_ADDR+1                ; *8
000BC5r 2  18             clc
000BC6r 2  A5 2E          lda MON_ADDR
000BC8r 2  65 32          adc MON_TMP
000BCAr 2  85 2E          sta MON_ADDR
000BCCr 2  A5 2F          lda MON_ADDR+1
000BCEr 2  65 33          adc MON_TMP+1
000BD0r 2  85 2F          sta MON_ADDR+1                ; *10
000BD2r 2                 ; + digit
000BD2r 2  68             pla
000BD3r 2  18             clc
000BD4r 2  65 2E          adc MON_ADDR
000BD6r 2  85 2E          sta MON_ADDR
000BD8r 2  90 02          bcc @DecNoCarry
000BDAr 2  E6 2F          inc MON_ADDR+1
000BDCr 2               @DecNoCarry:
000BDCr 2  E6 35          inc MON_IDX
000BDEr 2  E8             inx
000BDFr 2  E0 05          cpx #5                        ; Max 5 digits (65535)
000BE1r 2  90 BD          bcc @DecLoop
000BE3r 2               @DecDone:
000BE3r 2  E0 00          cpx #0
000BE5r 2  F0 02          beq @DecFail
000BE7r 2  38             sec                           ; Success
000BE8r 2  60             rts
000BE9r 2               @DecFail:
000BE9r 2  18             clc                           ; Failure
000BEAr 2  60             rts
000BEBr 2               
000BEBr 2               ; MonParseBin16 — Parse binary digits from MON_LINBUF into MON_ADDR
000BEBr 2               ; Input:  MON_IDX points to current position in MON_LINBUF
000BEBr 2               ; Output: MON_ADDR = parsed 16-bit value, carry set if valid
000BEBr 2               ;         MON_IDX advanced past parsed digits
000BEBr 2               ; Modifies: A, X, Y, MON_ADDR
000BEBr 2               
000BEBr 2               MonParseBin16:
000BEBr 2  64 2E          stz MON_ADDR
000BEDr 2  64 2F          stz MON_ADDR+1
000BEFr 2  A2 00          ldx #0                        ; Digit count
000BF1r 2               @BinLoop:
000BF1r 2  A4 35          ldy MON_IDX
000BF3r 2  B9 34 04       lda MON_LINBUF,y
000BF6r 2  C9 30          cmp #'0'
000BF8r 2  F0 06          beq @BinGot
000BFAr 2  C9 31          cmp #'1'
000BFCr 2  F0 02          beq @BinGot
000BFEr 2  80 0F          bra @BinDone
000C00r 2               @BinGot:
000C00r 2  38             sec
000C01r 2  E9 30          sbc #'0'                      ; A = 0 or 1
000C03r 2  4A             lsr a                         ; Bit into carry
000C04r 2  26 2E          rol MON_ADDR
000C06r 2  26 2F          rol MON_ADDR+1
000C08r 2  E6 35          inc MON_IDX
000C0Ar 2  E8             inx
000C0Br 2  E0 10          cpx #16                       ; Max 16 bits
000C0Dr 2  90 E2          bcc @BinLoop
000C0Fr 2               @BinDone:
000C0Fr 2  E0 00          cpx #0
000C11r 2  F0 02          beq @BinFail
000C13r 2  38             sec                           ; Success
000C14r 2  60             rts
000C15r 2               @BinFail:
000C15r 2  18             clc                           ; Failure
000C16r 2  60             rts
000C17r 2               
000C17r 2               ; ============================================================================
000C17r 2               ; Decimal & Binary Output Utilities
000C17r 2               ; ============================================================================
000C17r 2               
000C17r 2               ; MonPrintDec16 — Print MON_ADDR as up to 5 decimal digits
000C17r 2               ; Uses successive subtraction of powers of 10
000C17r 2               ; Modifies: A, X, Y, MON_TMP, MON_BYTE
000C17r 2               
000C17r 2               MonPrintDec16:
000C17r 2                 ; Copy value to MON_TMP so we don't destroy MON_ADDR
000C17r 2  A5 2E          lda MON_ADDR
000C19r 2  85 32          sta MON_TMP
000C1Br 2  A5 2F          lda MON_ADDR+1
000C1Dr 2  85 33          sta MON_TMP+1
000C1Fr 2  A2 00          ldx #0                        ; Leading zero suppression flag
000C21r 2  A0 00          ldy #0                        ; Power-of-10 index
000C23r 2               @Dec16Loop:
000C23r 2  A9 2F          lda #'0'-1
000C25r 2  85 34          sta MON_BYTE                  ; Digit scratch
000C27r 2               @Dec16Sub:
000C27r 2  E6 34          inc MON_BYTE
000C29r 2  A5 32          lda MON_TMP
000C2Br 2  38             sec
000C2Cr 2  F9 rr rr       sbc @Dec16Pow10Lo,y
000C2Fr 2  48             pha
000C30r 2  A5 33          lda MON_TMP+1
000C32r 2  F9 rr rr       sbc @Dec16Pow10Hi,y
000C35r 2  90 07          bcc @Dec16Digit               ; Underflow — digit done
000C37r 2  85 33          sta MON_TMP+1
000C39r 2  68             pla
000C3Ar 2  85 32          sta MON_TMP
000C3Cr 2  80 E9          bra @Dec16Sub
000C3Er 2               @Dec16Digit:
000C3Er 2  68             pla                           ; Discard underflowed low byte
000C3Fr 2  A5 34          lda MON_BYTE
000C41r 2  C9 30          cmp #'0'
000C43r 2  D0 04          bne @Dec16Print               ; Non-zero → print
000C45r 2  E0 00          cpx #0
000C47r 2  F0 08          beq @Dec16Skip                ; Leading zero → skip
000C49r 2               @Dec16Print:
000C49r 2  DA             phx
000C4Ar 2  5A             phy
000C4Br 2  20 rr rr       jsr Chrout
000C4Er 2  7A             ply
000C4Fr 2  FA             plx
000C50r 2  E8             inx                           ; Mark we've printed a digit
000C51r 2               @Dec16Skip:
000C51r 2  C8             iny
000C52r 2  C0 04          cpy #4                        ; 4 powers: 10000, 1000, 100, 10
000C54r 2  D0 CD          bne @Dec16Loop
000C56r 2                 ; Always print ones digit
000C56r 2  A5 32          lda MON_TMP
000C58r 2  09 30          ora #'0'
000C5Ar 2  20 rr rr       jsr Chrout
000C5Dr 2  60             rts
000C5Er 2  10 E8 64 0A  @Dec16Pow10Lo: .byte <10000, <1000, <100, <10
000C62r 2  27 03 00 00  @Dec16Pow10Hi: .byte >10000, >1000, >100, >10
000C66r 2               
000C66r 2               ; MonPrintBin16 — Print MON_ADDR as 16 binary digits (MSB first)
000C66r 2               ; Modifies: A, X
000C66r 2               
000C66r 2               MonPrintBin16:
000C66r 2  A5 2F          lda MON_ADDR+1                ; High byte first
000C68r 2  20 rr rr       jsr @PrintBin8
000C6Br 2  A5 2E          lda MON_ADDR                  ; Then low byte
000C6Dr 2               @PrintBin8:
000C6Dr 2  A2 08          ldx #8
000C6Fr 2               @BinBitLoop:
000C6Fr 2  0A             asl a                         ; Shift MSB into carry
000C70r 2  48             pha
000C71r 2  A9 30          lda #'0'
000C73r 2  69 00          adc #0                        ; +1 if carry → '1'
000C75r 2  20 rr rr       jsr Chrout
000C78r 2  68             pla
000C79r 2  CA             dex
000C7Ar 2  D0 F3          bne @BinBitLoop
000C7Cr 2  60             rts
000C7Dr 2               
000C7Dr 2               ; ============================================================================
000C7Dr 2               ; Message Print Helpers (Phase 5)
000C7Dr 2               ; ============================================================================
000C7Dr 2               
000C7Dr 2               ; MonPrintLoaded — Print "LOADED nnnn BYTES AT $xxxx"
000C7Dr 2               ; Input: MON_ADDR = byte count, MON_END = load address
000C7Dr 2               ; Modifies: A, X, Y, MON_TMP, MON_BYTE
000C7Dr 2               
000C7Dr 2               MonPrintLoaded:
000C7Dr 2  A2 00          ldx #0
000C7Fr 2               @PLoop1:
000C7Fr 2  BD rr rr       lda MonStrLoadPfx,x
000C82r 2  F0 06          beq @PDone1
000C84r 2  20 rr rr       jsr Chrout
000C87r 2  E8             inx
000C88r 2  80 F5          bra @PLoop1
000C8Ar 2               @PDone1:
000C8Ar 2  20 rr rr       jsr MonPrintDec16             ; Print byte count from MON_ADDR
000C8Dr 2  A2 00          ldx #0
000C8Fr 2               @PLoop2:
000C8Fr 2  BD rr rr       lda MonStrBytesAt,x
000C92r 2  F0 06          beq @PDone2
000C94r 2  20 rr rr       jsr Chrout
000C97r 2  E8             inx
000C98r 2  80 F5          bra @PLoop2
000C9Ar 2               @PDone2:
000C9Ar 2                 ; Print address from MON_END
000C9Ar 2  A5 30          lda MON_END
000C9Cr 2  85 2E          sta MON_ADDR
000C9Er 2  A5 31          lda MON_END+1
000CA0r 2  85 2F          sta MON_ADDR+1
000CA2r 2  20 rr rr       jsr MonPrintHex4
000CA5r 2  4C rr rr       jmp MonPrintCRLF
000CA8r 2               
000CA8r 2               ; MonPrintSaved — Print "SAVED nnnn BYTES"
000CA8r 2               ; Input: MON_ADDR = byte count
000CA8r 2               ; Modifies: A, X, Y, MON_TMP, MON_BYTE
000CA8r 2               
000CA8r 2               MonPrintSaved:
000CA8r 2  A2 00          ldx #0
000CAAr 2               @SLoop1:
000CAAr 2  BD rr rr       lda MonStrSavePfx,x
000CADr 2  F0 06          beq @SDone1
000CAFr 2  20 rr rr       jsr Chrout
000CB2r 2  E8             inx
000CB3r 2  80 F5          bra @SLoop1
000CB5r 2               @SDone1:
000CB5r 2  20 rr rr       jsr MonPrintDec16             ; Print byte count from MON_ADDR
000CB8r 2  A2 00          ldx #0
000CBAr 2               @SLoop2:
000CBAr 2  BD rr rr       lda MonStrBytes,x
000CBDr 2  F0 06          beq @SDone2
000CBFr 2  20 rr rr       jsr Chrout
000CC2r 2  E8             inx
000CC3r 2  80 F5          bra @SLoop2
000CC5r 2               @SDone2:
000CC5r 2  4C rr rr       jmp MonPrintCRLF
000CC8r 2               
000CC8r 2               ; MonPrintIOErr — Print "I/O ERROR"
000CC8r 2               ; Modifies: A, X
000CC8r 2               
000CC8r 2               MonPrintIOErr:
000CC8r 2  A2 00          ldx #0
000CCAr 2               @ELoop:
000CCAr 2  BD rr rr       lda MonStrIOErr,x
000CCDr 2  F0 06          beq @EDone
000CCFr 2  20 rr rr       jsr Chrout
000CD2r 2  E8             inx
000CD3r 2  80 F5          bra @ELoop
000CD5r 2               @EDone:
000CD5r 2  4C rr rr       jmp MonPrintCRLF
000CD8r 2               
000CD8r 2               ; ============================================================================
000CD8r 2               ; Hex Output Utilities
000CD8r 2               ; ============================================================================
000CD8r 2               
000CD8r 2               ; MonPrintHex2 — Print A as two hex digits
000CD8r 2               ; Input:  A = byte to print
000CD8r 2               ; Modifies: A, flags
000CD8r 2               
000CD8r 2               MonPrintHex2:
000CD8r 2  48             pha                           ; Save original byte
000CD9r 2  4A             lsr                           ; Shift high nibble down
000CDAr 2  4A             lsr
000CDBr 2  4A             lsr
000CDCr 2  4A             lsr
000CDDr 2  20 rr rr       jsr @PrintNibble              ; Print high nibble
000CE0r 2  68             pla                           ; Restore original byte
000CE1r 2  29 0F          and #$0F                      ; Isolate low nibble
000CE3r 2               @PrintNibble:
000CE3r 2  C9 0A          cmp #10
000CE5r 2  90 06          bcc @IsDigit
000CE7r 2  18             clc
000CE8r 2  69 37          adc #('A' - 10)
000CEAr 2  4C rr rr       jmp Chrout
000CEDr 2               @IsDigit:
000CEDr 2  18             clc
000CEEr 2  69 30          adc #'0'
000CF0r 2  4C rr rr       jmp Chrout
000CF3r 2               
000CF3r 2               ; MonPrintHex4 — Print MON_ADDR as four hex digits
000CF3r 2               ; Input:  MON_ADDR, MON_ADDR+1 = 16-bit value
000CF3r 2               ; Modifies: A, flags
000CF3r 2               
000CF3r 2               MonPrintHex4:
000CF3r 2  A5 2F          lda MON_ADDR + 1              ; High byte first
000CF5r 2  20 rr rr       jsr MonPrintHex2
000CF8r 2  A5 2E          lda MON_ADDR                  ; Then low byte
000CFAr 2  4C rr rr       jmp MonPrintHex2
000CFDr 2               
000CFDr 2               ; MonPrintSpace — Print a space character
000CFDr 2               
000CFDr 2               MonPrintSpace:
000CFDr 2  A9 20          lda #' '
000CFFr 2  4C rr rr       jmp Chrout
000D02r 2               
000D02r 2               ; MonPrintCRLF — Print carriage return + line feed
000D02r 2               
000D02r 2               MonPrintCRLF:
000D02r 2  A9 0D          lda #$0D
000D04r 2  20 rr rr       jsr Chrout
000D07r 2  A9 0A          lda #$0A
000D09r 2  4C rr rr       jmp Chrout
000D0Cr 2               
000D0Cr 2               ; MonPrintError — Print "?" for unrecognized command
000D0Cr 2               
000D0Cr 2               MonPrintError:
000D0Cr 2  A9 3F          lda #'?'
000D0Er 2  20 rr rr       jsr Chrout
000D11r 2  4C rr rr       jmp MonPrintCRLF
000D14r 2               
000D14r 2               ; MonPrintBanner — Print the monitor banner string
000D14r 2               
000D14r 2               MonPrintBanner:
000D14r 2  A2 00          ldx #0
000D16r 2               @Loop:
000D16r 2  BD rr rr       lda MonStrBanner,x
000D19r 2  F0 06          beq @Done
000D1Br 2  20 rr rr       jsr Chrout
000D1Er 2  E8             inx
000D1Fr 2  80 F5          bra @Loop
000D21r 2               @Done:
000D21r 2  60             rts
000D22r 2               
