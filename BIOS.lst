000AEFr 2  20 rr rr       jsr BasExpr
000AF2r 2  A9 29          lda #CH_RPAREN
000AF4r 2  20 rr rr       jsr BasExpectChar
000AF7r 2  4C rr rr       jmp BasMathAbs
