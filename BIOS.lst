001732r 2  68             pla                            ; restore year
001733r 2  20 rr rr       jsr BasPrint2Digit             ; print year (CCYY together)
001736r 2  A9 2D          lda #'-'
001738r 2  20 rr rr       jsr Chrout
00173Br 2  68             pla                            ; restore month
00173Cr 2  20 rr rr       jsr BasPrint2Digit
