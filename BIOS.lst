000A13r 2               
000A13r 2               @DoMul:
000A13r 2  20 rr rr       jsr BasAdvTxtPtr
000A16r 2  A5 0A          lda BAS_ACC
000A18r 2  48             pha
000A19r 2  A5 0B          lda BAS_ACC + 1
000A1Br 2  48             pha
000A1Cr 2  20 rr rr       jsr BasExprUnary
000A1Fr 2  68             pla
000A20r 2  85 0D          sta BAS_AUX + 1
000A22r 2  68             pla
000A23r 2  85 0C          sta BAS_AUX
000A25r 2  20 rr rr       jsr BasMathMul
000A28r 2  4C rr rr       jmp @MulLoop
000A2Br 2               
000A2Br 2               @DoDiv:
