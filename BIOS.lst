000D0Fr 2  B0 12          bcs @HexDone
000D11r 2                 ; Shift NUMTMP left 4 bits
000D11r 2  A0 04          ldy #4
000D13r 2               @HexShift:
000D13r 2  06 22          asl BAS_NUMTMP
