001650r 2               
001650r 2               ; --- SOUND voice, freq, dur ---
001650r 2               ; freq is in Hz; converted to SID register via: reg = Hz*16 + Hz - Hz/4
001650r 2               ; Approximation of Hz * 2^24 / 1000000 ≈ Hz * 16.75 (0.16% error)
001650r 2               BasCmdSound:
001650r 2  AD 0D 03       lda HW_PRESENT
001653r 2  29 40          and #HW_SID
001655r 2  D0 01          bne @SoundStart
001657r 2  60             rts
001658r 2               @SoundStart:
001658r 2  20 rr rr       jsr BasExpr                    ; voice (1-3) -> BAS_ACC
00165Br 2  A5 0A          lda BAS_ACC
00165Dr 2  3A             dec a                          ; convert to 0-indexed
00165Er 2  85 21          sta BAS_TEMP                   ; save voice
001660r 2  20 rr rr       jsr BasSkipSpaces
001663r 2  A9 2C          lda #CH_COMMA
001665r 2  20 rr rr       jsr BasExpectChar
001668r 2  20 rr rr       jsr BasExpr                    ; freq (Hz) -> BAS_ACC
00166Br 2                 ; --- Convert Hz to SID register value ---
00166Br 2  A5 0A          lda BAS_ACC                    ; save Hz in BAS_SCRATCH
00166Dr 2  85 1C          sta BAS_SCRATCH
00166Fr 2  A5 0B          lda BAS_ACC + 1
001671r 2  85 1D          sta BAS_SCRATCH + 1
001673r 2  06 0A          asl BAS_ACC                    ; BAS_ACC = Hz << 4 (multiply by 16)
001675r 2  26 0B          rol BAS_ACC + 1
001677r 2  06 0A          asl BAS_ACC
001679r 2  26 0B          rol BAS_ACC + 1
00167Br 2  06 0A          asl BAS_ACC
00167Dr 2  26 0B          rol BAS_ACC + 1
00167Fr 2  06 0A          asl BAS_ACC
001681r 2  26 0B          rol BAS_ACC + 1
001683r 2  18             clc                            ; BAS_ACC += Hz (now Hz * 17)
001684r 2  A5 0A          lda BAS_ACC
001686r 2  65 1C          adc BAS_SCRATCH
001688r 2  85 0A          sta BAS_ACC
00168Ar 2  A5 0B          lda BAS_ACC + 1
00168Cr 2  65 1D          adc BAS_SCRATCH + 1
00168Er 2  85 0B          sta BAS_ACC + 1
001690r 2  46 1D          lsr BAS_SCRATCH + 1            ; BAS_SCRATCH = Hz / 4
001692r 2  66 1C          ror BAS_SCRATCH
001694r 2  46 1D          lsr BAS_SCRATCH + 1
001696r 2  66 1C          ror BAS_SCRATCH
001698r 2  38             sec                            ; BAS_ACC -= Hz/4 (now Hz * 16.75)
001699r 2  A5 0A          lda BAS_ACC
00169Br 2  E5 1C          sbc BAS_SCRATCH
00169Dr 2  85 0A          sta BAS_ACC
00169Fr 2  A5 0B          lda BAS_ACC + 1
0016A1r 2  E5 1D          sbc BAS_SCRATCH + 1
0016A3r 2  85 0B          sta BAS_ACC + 1
0016A5r 2                 ; --- SID register value now in BAS_ACC ---
0016A5r 2  A5 0B          lda BAS_ACC + 1
0016A7r 2  48             pha                            ; save regHi on stack
0016A8r 2  A5 0A          lda BAS_ACC
0016AAr 2  48             pha                            ; save regLo on stack
0016ABr 2  20 rr rr       jsr BasSkipSpaces
0016AEr 2  A9 2C          lda #CH_COMMA
0016B0r 2  20 rr rr       jsr BasExpectChar
0016B3r 2  20 rr rr       jsr BasExpr                    ; dur (centiseconds) -> BAS_ACC
0016B6r 2                 ; BAS_ACC holds dur; stack holds freq; BAS_TEMP holds voice
0016B6r 2  68             pla                            ; freqLo
0016B7r 2  AA             tax                            ; X = freqLo
0016B8r 2  68             pla                            ; freqHi
0016B9r 2  A8             tay                            ; Y = freqHi
0016BAr 2  A5 21          lda BAS_TEMP                   ; A = voice (0-indexed)
0016BCr 2  20 rr rr       jsr SidPlayNote
0016BFr 2  A5 0A          lda BAS_ACC                    ; A = dur_lo (BAS_ACC not changed by SidPlayNote)
0016C1r 2  A6 0B          ldx BAS_ACC + 1                ; X = dur_hi
0016C3r 2  20 rr rr       jsr SysDelay
0016C6r 2  20 rr rr       jsr SidSilence
0016C9r 2  60             rts
0016CAr 2               
0016CAr 2               ; --- VOL n ---
