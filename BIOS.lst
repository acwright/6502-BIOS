000B57r 2  20 rr rr       jsr BasExpectChar
000B5Ar 2  20 rr rr       jsr BasExpr                    ; n -> BAS_ACC
000B5Dr 2  A9 29          lda #CH_RPAREN
000B5Fr 2  20 rr rr       jsr BasExpectChar
000B62r 2  A5 0A          lda BAS_ACC
000B64r 2  C9 02          cmp #2
000B66r 2  D0 05          bne @JoyPort1
000B68r 2  20 rr rr       jsr ReadJoystick2
000B6Br 2  80 03          bra @JoyDone
