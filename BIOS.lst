0009EAr 2  48             pha
0009EBr 2  A5 0B          lda BAS_ACC + 1
0009EDr 2  48             pha
0009EEr 2  20 rr rr       jsr BasExprMul
0009F1r 2  68             pla
0009F2r 2  85 0D          sta BAS_AUX + 1
0009F4r 2  68             pla
0009F5r 2  85 0C          sta BAS_AUX
0009F7r 2  20 rr rr       jsr BasMathSub
0009FAr 2  4C rr rr       jmp @AddLoop
