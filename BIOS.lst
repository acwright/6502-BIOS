001B8Br 2  20 rr rr       jsr BasPrintCRLF
001B8Er 2  60             rts
001B8Fr 2               
001B8Fr 2               ; BasMemHexByte — print A as 2 hex digits
001B8Fr 2               BasMemHexByte:
001B8Fr 2  48             pha
001B90r 2  4A             lsr
001B91r 2  4A             lsr
001B92r 2  4A             lsr
001B93r 2  4A             lsr
001B94r 2  20 rr rr       jsr @MemNibble
001B97r 2  68             pla
001B98r 2  29 0F          and #$0F
001B9Ar 2               @MemNibble:
001B9Ar 2  C9 0A          cmp #$0A
001B9Cr 2  90 04          bcc @MemDigit
001B9Er 2  69 36          adc #('A' - $0A - 1)
001BA0r 2  80 02          bra @MemPrint
001BA2r 2               @MemDigit:
001BA2r 2  09 30          ora #'0'
001BA4r 2               @MemPrint:
001BA4r 2  4C rr rr       jmp Chrout
001BA7r 2               
001BA7r 2               ; ============================================================================
001BA7r 2               ; DIM var(size) [, var(size) ...] — Dimension arrays
001BA7r 2               ; ============================================================================
001BA7r 2               
001BA7r 2               BasCmdDim:
001BA7r 2               @DimNext:
001BA7r 2  20 rr rr       jsr BasSkipSpaces
001BAAr 2  20 rr rr       jsr BasGetTokChar
001BADr 2               
001BADr 2                 ; Must be a variable A-Z
001BADr 2  C9 41          cmp #'A'
001BAFr 2  B0 03          bcs @DimNotLow
001BB1r 2  4C rr rr       jmp @DimErr
001BB4r 2               @DimNotLow:
001BB4r 2  C9 5B          cmp #'Z' + 1
001BB6r 2  90 03          bcc @DimNotHigh
001BB8r 2  4C rr rr       jmp @DimErr
001BBBr 2               @DimNotHigh:
001BBBr 2               
001BBBr 2  38             sec
001BBCr 2  E9 41          sbc #'A'
001BBEr 2  0A             asl                            ; ×2 for descriptor table index
001BBFr 2  85 21          sta BAS_TEMP                   ; Save var offset
001BC1r 2               
001BC1r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip variable letter
001BC4r 2               
001BC4r 2                 ; Expect '('
001BC4r 2  A9 28          lda #CH_LPAREN
001BC6r 2  20 rr rr       jsr BasExpectChar
001BC9r 2               
001BC9r 2  20 rr rr       jsr BasExpr                    ; size -> BAS_ACC (max valid index)
001BCCr 2               
001BCCr 2                 ; Expect ')'
001BCCr 2  A9 29          lda #CH_RPAREN
001BCEr 2  20 rr rr       jsr BasExpectChar
001BD1r 2               
001BD1r 2                 ; Check if already dimensioned
001BD1r 2  A6 21          ldx BAS_TEMP
001BD3r 2  BD 5B 03       lda BAS_ARYDESC,x
001BD6r 2  1D 5C 03       ora BAS_ARYDESC + 1,x
001BD9r 2  F0 03          beq @DimNotRedim
001BDBr 2  4C rr rr       jmp @DimRedim
001BDEr 2               @DimNotRedim:
001BDEr 2               
001BDEr 2                 ; BAS_ACC = max index (0-based), elements = ACC + 1
001BDEr 2                 ; Total bytes = 2 (dim size) + (ACC + 1) * 2
001BDEr 2                 ; Check non-negative
001BDEr 2  A5 0B          lda BAS_ACC + 1
001BE0r 2  10 03          bpl @DimNotNeg
001BE2r 2  4C rr rr       jmp @DimIllegal
001BE5r 2               @DimNotNeg:
001BE5r 2               
001BE5r 2                 ; Compute total size: (ACC + 1) * 2 + 2
001BE5r 2  18             clc
001BE6r 2  A5 0A          lda BAS_ACC
001BE8r 2  69 01          adc #$01
001BEAr 2  85 0C          sta BAS_AUX
001BECr 2  A5 0B          lda BAS_ACC + 1
001BEEr 2  69 00          adc #$00
001BF0r 2  85 0D          sta BAS_AUX + 1                ; AUX = element count
001BF2r 2  06 0C          asl BAS_AUX
001BF4r 2  26 0D          rol BAS_AUX + 1                ; AUX = element count * 2
001BF6r 2  18             clc
001BF7r 2  A5 0C          lda BAS_AUX
001BF9r 2  69 02          adc #$02                       ; + 2 for dim size header
001BFBr 2  85 0C          sta BAS_AUX
001BFDr 2  A5 0D          lda BAS_AUX + 1
001BFFr 2  69 00          adc #$00
001C01r 2  85 0D          sta BAS_AUX + 1                ; AUX = total bytes needed
001C03r 2               
001C03r 2                 ; New array top = BAS_ARYTOP - total_bytes
001C03r 2  38             sec
001C04r 2  AD 8F 03       lda BAS_ARYTOP
001C07r 2  E5 0C          sbc BAS_AUX
001C09r 2  85 10          sta BAS_TMP2
001C0Br 2  AD 90 03       lda BAS_ARYTOP + 1
001C0Er 2  E5 0D          sbc BAS_AUX + 1
001C10r 2  85 11          sta BAS_TMP2 + 1               ; TMP2 = proposed new ARYTOP
001C12r 2               
001C12r 2                 ; Check for collision with program: new top must be > PRGEND
001C12r 2  A5 11          lda BAS_TMP2 + 1
001C14r 2  C5 13          cmp BAS_PRGEND + 1
001C16r 2  90 78          bcc @DimOOM
001C18r 2  D0 08          bne @DimOK
001C1Ar 2  A5 10          lda BAS_TMP2
001C1Cr 2  C5 12          cmp BAS_PRGEND
001C1Er 2  90 70          bcc @DimOOM
001C20r 2  F0 6E          beq @DimOOM
001C22r 2               @DimOK:
001C22r 2                 ; Commit: update ARYTOP
001C22r 2  A5 10          lda BAS_TMP2
001C24r 2  8D 8F 03       sta BAS_ARYTOP
001C27r 2  A5 11          lda BAS_TMP2 + 1
001C29r 2  8D 90 03       sta BAS_ARYTOP + 1
001C2Cr 2               
001C2Cr 2                 ; Store base pointer in descriptor table
001C2Cr 2  A6 21          ldx BAS_TEMP
001C2Er 2  A5 10          lda BAS_TMP2
001C30r 2  9D 5B 03       sta BAS_ARYDESC,x
001C33r 2  A5 11          lda BAS_TMP2 + 1
001C35r 2  9D 5C 03       sta BAS_ARYDESC + 1,x
001C38r 2               
001C38r 2                 ; Write max index at base pointer
001C38r 2  A0 00          ldy #$00
001C3Ar 2  A5 0A          lda BAS_ACC
001C3Cr 2  91 10          sta (BAS_TMP2),y
001C3Er 2  C8             iny
001C3Fr 2  A5 0B          lda BAS_ACC + 1
001C41r 2  91 10          sta (BAS_TMP2),y
001C43r 2               
001C43r 2                 ; Zero-fill element data (starts at base + 2, length = element_count * 2)
001C43r 2  18             clc
001C44r 2  A5 10          lda BAS_TMP2
001C46r 2  69 02          adc #$02
001C48r 2  85 10          sta BAS_TMP2
001C4Ar 2  A5 11          lda BAS_TMP2 + 1
001C4Cr 2  69 00          adc #$00
001C4Er 2  85 11          sta BAS_TMP2 + 1
001C50r 2               
001C50r 2                 ; AUX still holds total_bytes; element data = AUX - 2
001C50r 2  38             sec
001C51r 2  A5 0C          lda BAS_AUX
001C53r 2  E9 02          sbc #$02
001C55r 2  85 0C          sta BAS_AUX
001C57r 2  A5 0D          lda BAS_AUX + 1
001C59r 2  E9 00          sbc #$00
001C5Br 2  85 0D          sta BAS_AUX + 1
001C5Dr 2               
001C5Dr 2  A9 00          lda #$00
001C5Fr 2  A0 00          ldy #$00
001C61r 2               @DimZeroLoop:
001C61r 2  A5 0C          lda BAS_AUX
001C63r 2  05 0D          ora BAS_AUX + 1
001C65r 2  F0 13          beq @DimZeroDone
001C67r 2  A9 00          lda #$00
001C69r 2  91 10          sta (BAS_TMP2),y
001C6Br 2  C8             iny
001C6Cr 2  D0 02          bne @DimNoPage
001C6Er 2  E6 11          inc BAS_TMP2 + 1
001C70r 2               @DimNoPage:
001C70r 2                 ; Decrement AUX
001C70r 2  A5 0C          lda BAS_AUX
001C72r 2  D0 02          bne :+
001C74r 2  C6 0D          dec BAS_AUX + 1
001C76r 2  C6 0C        : dec BAS_AUX
001C78r 2  80 E7          bra @DimZeroLoop
001C7Ar 2               @DimZeroDone:
001C7Ar 2               
001C7Ar 2                 ; Check for comma (multiple DIM declarations)
001C7Ar 2  20 rr rr       jsr BasSkipSpaces
001C7Dr 2  20 rr rr       jsr BasGetTokChar
001C80r 2  C9 2C          cmp #CH_COMMA
001C82r 2  D0 06          bne @DimDone
001C84r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip ','
001C87r 2  4C rr rr       jmp @DimNext
001C8Ar 2               @DimDone:
001C8Ar 2  60             rts
001C8Br 2               
001C8Br 2               @DimRedim:
001C8Br 2  A9 0C          lda #ERR_REDIM
001C8Dr 2  4C rr rr       jmp BasError
001C90r 2               @DimOOM:
001C90r 2  A9 03          lda #ERR_OUT_OF_MEM
001C92r 2  4C rr rr       jmp BasError
001C95r 2               @DimIllegal:
001C95r 2  A9 08          lda #ERR_ILLEGAL_QTY
001C97r 2  4C rr rr       jmp BasError
001C9Ar 2               @DimErr:
001C9Ar 2  A9 00          lda #ERR_SYNTAX
001C9Cr 2  4C rr rr       jmp BasError
001C9Fr 2               
001C9Fr 2               ; ============================================================================
001C9Fr 2               ; BasArrayRead — Read array element: X = var_offset (already ×2)
001C9Fr 2               ; ============================================================================
001C9Fr 2               ; Called from BasExprPrimary when A(expr) is found
001C9Fr 2               ; TXTPTR points at '('
001C9Fr 2               
001C9Fr 2               BasArrayRead:
001C9Fr 2  86 21          stx BAS_TEMP                   ; Save var offset
001CA1r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
001CA4r 2  20 rr rr       jsr BasExpr                    ; index -> BAS_ACC
001CA7r 2  A9 29          lda #CH_RPAREN
001CA9r 2  20 rr rr       jsr BasExpectChar              ; Expect ')'
001CACr 2               
001CACr 2                 ; Resolve element address into BAS_TMP2
001CACr 2  A5 0A          lda BAS_ACC
001CAEr 2  85 0C          sta BAS_AUX
001CB0r 2  A5 0B          lda BAS_ACC + 1
001CB2r 2  85 0D          sta BAS_AUX + 1                ; AUX = index
001CB4r 2  20 rr rr       jsr BasArrayAddr               ; BAS_TMP2 = element address
001CB7r 2               
001CB7r 2                 ; Read element
001CB7r 2  A0 00          ldy #$00
001CB9r 2  B1 10          lda (BAS_TMP2),y
001CBBr 2  85 0A          sta BAS_ACC
001CBDr 2  C8             iny
001CBEr 2  B1 10          lda (BAS_TMP2),y
001CC0r 2  85 0B          sta BAS_ACC + 1
001CC2r 2  60             rts
001CC3r 2               
001CC3r 2               ; ============================================================================
001CC3r 2               ; BasArrayWrite — Write array element: X = var_offset (already ×2)
001CC3r 2               ; ============================================================================
001CC3r 2               ; Called from BasCmdLet when A(expr) = expr is found
001CC3r 2               ; TXTPTR points at '('
001CC3r 2               
001CC3r 2               BasArrayWrite:
001CC3r 2  86 21          stx BAS_TEMP                   ; Save var offset
001CC5r 2  20 rr rr       jsr BasAdvTxtPtr               ; Skip '('
001CC8r 2  20 rr rr       jsr BasExpr                    ; index -> BAS_ACC
001CCBr 2  A9 29          lda #CH_RPAREN
001CCDr 2  20 rr rr       jsr BasExpectChar              ; Expect ')'
001CD0r 2               
001CD0r 2                 ; Save index on stack
001CD0r 2  A5 0A          lda BAS_ACC
001CD2r 2  48             pha
001CD3r 2  A5 0B          lda BAS_ACC + 1
001CD5r 2  48             pha
001CD6r 2               
001CD6r 2  20 rr rr       jsr BasSkipSpaces
001CD9r 2  A9 3D          lda #CH_EQUALS
001CDBr 2  20 rr rr       jsr BasExpectChar              ; Expect '='
001CDEr 2               
001CDEr 2  20 rr rr       jsr BasExpr                    ; value -> BAS_ACC
001CE1r 2               
001CE1r 2                 ; Pop index into AUX
001CE1r 2  68             pla
001CE2r 2  85 0D          sta BAS_AUX + 1
001CE4r 2  68             pla
001CE5r 2  85 0C          sta BAS_AUX                    ; AUX = index
001CE7r 2               
001CE7r 2                 ; Resolve element address into BAS_TMP2
001CE7r 2  20 rr rr       jsr BasArrayAddr               ; BAS_TMP2 = element address
001CEAr 2               
001CEAr 2                 ; Write element
001CEAr 2  A0 00          ldy #$00
001CECr 2  A5 0A          lda BAS_ACC
001CEEr 2  91 10          sta (BAS_TMP2),y
001CF0r 2  C8             iny
001CF1r 2  A5 0B          lda BAS_ACC + 1
001CF3r 2  91 10          sta (BAS_TMP2),y
001CF5r 2  60             rts
001CF6r 2               
001CF6r 2               ; ============================================================================
001CF6r 2               ; BasArrayAddr — Compute array element address
001CF6r 2               ; ============================================================================
001CF6r 2               ; Input: BAS_TEMP = var_offset (×2), BAS_AUX = index
001CF6r 2               ; Output: BAS_TMP2 = element address
001CF6r 2               ; Errors: ERR_SYNTAX if not dimensioned, ERR_BAD_SUBSCRIPT if out of range
001CF6r 2               
001CF6r 2               BasArrayAddr:
001CF6r 2                 ; Look up array base pointer
001CF6r 2  A6 21          ldx BAS_TEMP
001CF8r 2  BD 5B 03       lda BAS_ARYDESC,x
001CFBr 2  85 10          sta BAS_TMP2
001CFDr 2  BD 5C 03       lda BAS_ARYDESC + 1,x
001D00r 2  85 11          sta BAS_TMP2 + 1
001D02r 2               
001D02r 2                 ; Check if dimensioned
001D02r 2  05 10          ora BAS_TMP2
001D04r 2  F0 38          beq @AANotDim
001D06r 2               
001D06r 2                 ; Bounds check: AUX must be 0..max_index
001D06r 2  A5 0D          lda BAS_AUX + 1
001D08r 2  30 39          bmi @AABadSub                 ; Negative index
001D0Ar 2  A0 00          ldy #$00
001D0Cr 2  B1 10          lda (BAS_TMP2),y               ; max_index lo
001D0Er 2  85 1C          sta BAS_SCRATCH
001D10r 2  C8             iny
001D11r 2  B1 10          lda (BAS_TMP2),y               ; max_index hi
001D13r 2  C5 0D          cmp BAS_AUX + 1
001D15r 2  90 2C          bcc @AABadSub
001D17r 2  D0 06          bne @AAInBounds
001D19r 2  A5 1C          lda BAS_SCRATCH
001D1Br 2  C5 0C          cmp BAS_AUX
001D1Dr 2  90 24          bcc @AABadSub
001D1Fr 2               @AAInBounds:
001D1Fr 2                 ; Address = base + 2 + AUX * 2
001D1Fr 2  06 0C          asl BAS_AUX
001D21r 2  26 0D          rol BAS_AUX + 1               ; AUX = index * 2
001D23r 2  18             clc
001D24r 2  A5 10          lda BAS_TMP2
001D26r 2  69 02          adc #$02
001D28r 2  85 10          sta BAS_TMP2
001D2Ar 2  A5 11          lda BAS_TMP2 + 1
001D2Cr 2  69 00          adc #$00
001D2Er 2  85 11          sta BAS_TMP2 + 1               ; base + 2
001D30r 2  18             clc
001D31r 2  A5 10          lda BAS_TMP2
001D33r 2  65 0C          adc BAS_AUX
001D35r 2  85 10          sta BAS_TMP2
001D37r 2  A5 11          lda BAS_TMP2 + 1
001D39r 2  65 0D          adc BAS_AUX + 1
001D3Br 2  85 11          sta BAS_TMP2 + 1               ; final address
001D3Dr 2  60             rts
001D3Er 2               
001D3Er 2               @AANotDim:
001D3Er 2  A9 00          lda #ERR_SYNTAX
001D40r 2  4C rr rr       jmp BasError
001D43r 2               @AABadSub:
001D43r 2  A9 0D          lda #ERR_BAD_SUBSCRIPT
001D45r 2  4C rr rr       jmp BasError
