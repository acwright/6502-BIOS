001010r 2               BasRunExec:
001010r 2                 ; Execute the line (CONT re-enters here with TXTPTR already set)
001010r 2  20 rr rr       jsr BasExecLine
001013r 2               
001013r 2                 ; Check if END was executed (flags cleared)
001013r 2  A5 17          lda BAS_FLAGS
001015r 2  29 01          and #BAS_FLAG_RUN
001017r 2  F0 34          beq BasRunDone
001019r 2               
001019r 2                 ; Check if GOTO/GOSUB changed CURLINE (or GOTO flag set for same-line GOTO)
001019r 2  A5 17          lda BAS_FLAGS
00101Br 2  29 08          and #BAS_FLAG_GOTO
00101Dr 2  D0 25          bne @GotoDone
00101Fr 2  A5 06          lda BAS_CURLINE
001021r 2  C5 14          cmp BAS_VARPTR
001023r 2  D0 B0          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
001025r 2  A5 07          lda BAS_CURLINE + 1
001027r 2  C5 15          cmp BAS_VARPTR + 1
001029r 2  D0 AA          bne BasRunLoop                 ; Changed — re-execute from new CURLINE
00102Br 2               
00102Br 2                 ; Advance to next line by scanning for end of current line
00102Br 2  A0 04          ldy #LINE_PAYLOAD
00102Dr 2               @RunScanNull:
