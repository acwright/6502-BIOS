000A30r 2  48             pha
000A31r 2  A5 0B          lda BAS_ACC + 1
000A33r 2  48             pha
000A34r 2  20 rr rr       jsr BasExprUnary
000A37r 2  68             pla
000A38r 2  85 0D          sta BAS_AUX + 1
000A3Ar 2  68             pla
000A3Br 2  85 0C          sta BAS_AUX
000A3Dr 2  20 rr rr       jsr BasMathDiv
000A40r 2  4C rr rr       jmp @MulLoop
000A43r 2               
000A43r 2               @DoMod:
000A43r 2  20 rr rr       jsr BasAdvTxtPtr
