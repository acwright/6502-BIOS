000FFBr 2  D0 0D          bne @SkipTxtSet
000FFDr 2  18             clc
000FFEr 2  A5 06          lda BAS_CURLINE
001000r 2  69 04          adc #LINE_PAYLOAD
001002r 2  85 04          sta BAS_TXTPTR
001004r 2  A5 07          lda BAS_CURLINE + 1
001006r 2  69 00          adc #$00
001008r 2  85 05          sta BAS_TXTPTR + 1
